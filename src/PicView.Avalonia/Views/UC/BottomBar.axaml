<UserControl
    x:Class="PicView.Avalonia.Views.UC.BottomBar"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    Height="{CompiledBinding BottombarHeight.Value}"
    x:DataType="viewModels:MainWindowViewModel"
    IsVisible="{CompiledBinding IsBottomToolbarShown.Value}">

    <UserControl.Resources>

        <ContextMenu x:Key="MainContextMenu">

            <!--  Next  -->
            <MenuItem
                Command="{CompiledBinding WindowTabs.NextFile}"
                Header="{CompiledBinding Translation.NextImage.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateForwards.Value,
                                            FallbackValue=False}"
                StaysOpenOnClick="True">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource NextImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Prev  -->
            <MenuItem
                Command="{CompiledBinding WindowTabs.PrevFile}"
                Header="{CompiledBinding Translation.PrevImage,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateBackwards.Value,
                                            FallbackValue=False}"
                StaysOpenOnClick="True">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource PrevImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />


            <!--  Next 10  -->
            <MenuItem
                Command="{CompiledBinding WindowTabs.Next10}"
                Header="{CompiledBinding Translation.AdvanceBy10Images,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateForwards.Value}"
                StaysOpenOnClick="True">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource NextImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Next 100  -->
            <MenuItem
                Command="{CompiledBinding WindowTabs.Next100}"
                Header="{CompiledBinding Translation.AdvanceBy100Images.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateForwards.Value}"
                StaysOpenOnClick="True">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource NextImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Prev 10  -->
            <MenuItem
                Command="{CompiledBinding WindowTabs.Prev10}"
                Header="{CompiledBinding Translation.GoBackBy10Images.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateBackwards.Value}"
                StaysOpenOnClick="True">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource PrevImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Prev 100  -->
            <MenuItem
                Command="{CompiledBinding WindowTabs.Prev100}"
                Header="{CompiledBinding Translation.GoBackBy100Images.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateBackwards.Value}"
                StaysOpenOnClick="True">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource PrevImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  First Image  -->
            <MenuItem
                Command="{CompiledBinding WindowTabs.FirstFile}"
                Header="{CompiledBinding Translation.FirstImage.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateBackwards.Value}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource FirstImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Last Image  -->
            <MenuItem
                Command="{CompiledBinding WindowTabs.LastFile}"
                Header="{CompiledBinding Translation.LastImage.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateForwards.Value}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource LastImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Next folder  -->
            <MenuItem
                Command="{CompiledBinding NextFolderCommand}"
                Header="{CompiledBinding Translation.NextFolder.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Image
                        Width="14"
                        Height="14"
                        Source="{StaticResource NextFolderImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Prev folder  -->
            <MenuItem
                Command="{CompiledBinding PrevFolderCommand}"
                Header="{CompiledBinding Translation.PrevFolder.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Image
                        Width="14"
                        Height="14"
                        Source="{StaticResource PrevFolderImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Next archive  -->
            <MenuItem
                Command="{CompiledBinding NextArchiveCommand}"
                Header="{CompiledBinding Translation.NextArchive.Value,
                                         Mode=OneWay}"
                IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}}">
                <MenuItem.Icon>
                    <Image
                        Width="14"
                        Height="14"
                        Source="{StaticResource ArchiveFile}" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Prev archive  -->
            <MenuItem
                Command="{CompiledBinding PrevArchiveCommand}"
                Header="{CompiledBinding Translation.PrevArchive.Value,
                                         Mode=OneWay}"
                IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}}">
                <MenuItem.Icon>
                    <Image
                        Width="14"
                        Height="14"
                        Source="{StaticResource ArchiveFile}" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Slideshow  -->
            <MenuItem
                Command="{CompiledBinding SlideshowCommand}"
                Header="{CompiledBinding Translation.Slideshow.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Image
                        Width="14"
                        Height="14"
                        Source="{StaticResource SlideshowImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Hide bottom bar  -->
            <MenuItem Command="{Binding ToggleBottomToolbarCommand}" Header="{CompiledBinding Translation.HideBottomToolbar.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource Panel-Bottom}" />
                </MenuItem.Icon>
            </MenuItem>

        </ContextMenu>

        <ContextMenu x:Key="RotationContextMenu">
            <MenuItem
                x:Name="Rotation0Item"
                Command="{Binding Rotate0Command}"
                GroupName="RotationGroup"
                Header="0°"
                IsChecked="{Binding WindowTabs.ActiveTab.Value.IsRotated0.Value}"
                ToggleType="Radio" />
            <MenuItem
                x:Name="Rotation90Item"
                Command="{Binding Rotate90Command}"
                GroupName="RotationGroup"
                Header="90°"
                IsChecked="{Binding WindowTabs.ActiveTab.Value.IsRotated90.Value}"
                ToggleType="Radio" />
            <MenuItem
                x:Name="Rotation180Item"
                Command="{Binding Rotate180Command}"
                GroupName="RotationGroup"
                Header="180°"
                IsChecked="{Binding WindowTabs.ActiveTab.Value.IsRotated180.Value}"
                ToggleType="Radio" />
            <MenuItem
                x:Name="Rotation270Item"
                Command="{Binding Rotate270Command}"
                GroupName="RotationGroup"
                Header="270°"
                IsChecked="{Binding WindowTabs.ActiveTab.Value.IsRotated270.Value}"
                ToggleType="Radio" />
            <Separator />
            <MenuItem Command="{CompiledBinding FlipCommand}" Header="{CompiledBinding Translation.IsFlipped.Value}">
                <MenuItem.Icon>
                    <Path
                        Width="12"
                        Height="12"
                        Data="{StaticResource FlipGeometry}"
                        Fill="{DynamicResource MainTextColor}"
                        Stretch="Fill">
                        <Path.RenderTransform>
                            <ScaleTransform ScaleX="{CompiledBinding WindowTabs.ActiveTab.Value.ScaleX.Value}" />
                        </Path.RenderTransform>
                    </Path>
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Hide bottom bar  -->
            <MenuItem Command="{Binding ToggleBottomToolbarCommand}" Header="{CompiledBinding Translation.HideBottomToolbar.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource Panel-Bottom}" />
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <ContextMenu x:Key="SettingsContextMenu">
            <!--  Change background  -->
            <MenuItem
                Command="{CompiledBinding ChangeBackgroundCommand}"
                Header="{CompiledBinding Translation.ChangeBackground.Value,
                                         Mode=OneWay}"
                StaysOpenOnClick="True">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource PaletteImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Toggle Subdirectories  -->
            <MenuItem
                Command="{CompiledBinding ToggleSubdirectoriesCommand}"
                Header="{CompiledBinding Translation.SearchSubdirectory.Value,
                                         Mode=OneWay}"
                IsChecked="{Binding GlobalSettings.IsIncludingSubdirectories.Value}"
                ToggleType="CheckBox" />

            <Separator />

            <!--  Toggle looping  -->
            <MenuItem
                Command="{CompiledBinding ToggleLoopingCommand}"
                Header="{CompiledBinding Translation.IsLooping.Value,
                                         Mode=OneWay}"
                IsChecked="{Binding GlobalSettings.IsLooping.Value}"
                ToggleType="CheckBox" />

            <Separator />

            <!--  Toggle scrolling  -->
            <MenuItem
                Header="{CompiledBinding Translation.IsScrolling.Value,
                                         Mode=OneWay}"
                IsChecked="{CompiledBinding IsScrollingEnabled.Value}"
                ToggleType="CheckBox" />

            <!--  Zoom to fit  -->
            <MenuItem
                Command="{CompiledBinding ZoomToFitCommand}"
                Header="{CompiledBinding Translation.ZoomToFit.Value,
                                         Mode=OneWay}"
                IsChecked="{CompiledBinding IsZoomedToFit.Value}"
                ToggleType="CheckBox" />

            <Separator />

            <!--  Toggle topmost  -->
            <MenuItem
                Command="{CompiledBinding SetTopMostCommand}"
                Header="{CompiledBinding Translation.StayTopMost.Value,
                                         Mode=OneWay}"
                IsChecked="{CompiledBinding IsTopMost.Value}"
                ToggleType="CheckBox" />

            <!--  Toggle auto fit  -->
            <MenuItem
                Command="{CompiledBinding AutoFitWindowCommand}"
                Header="{CompiledBinding Translation.AutoFitWindow.Value,
                                         Mode=OneWay}"
                IsChecked="{CompiledBinding IsAutoFit.Value}"
                ToggleType="CheckBox" />

            <!--  Toggle ctrl zoom  -->
            <MenuItem Command="{CompiledBinding ChangeCtrlZoomCommand}" Header="{CompiledBinding Translation.IsCtrlToZoom.Value, Mode=OneWay}">
                <!-- <MenuItem.Icon> -->
                <!--  <Image  -->
                <!--  Height="12"  -->
                <!--  Source="{CompiledBinding MainWindow.ChangeCtrlZoomImage.Value}"  -->
                <!--  Width="12" />  -->
                <!-- </MenuItem.Icon> -->
            </MenuItem>

            <Separator />

            <!--  Show about window  -->
            <MenuItem Command="{CompiledBinding AboutWindowCommand}" Header="{CompiledBinding Translation.About.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource AboutImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Show Settings window  -->
            <MenuItem Command="{CompiledBinding SettingsWindowCommand}" Header="{CompiledBinding Translation.ShowAllSettingsWindow.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Image Classes="CogImage" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Toggle UI  -->
            <MenuItem Command="{Binding ToggleInterfaceCommand}" Header="{Binding Translation.IsShowingUI.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource EyeOffImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Hide bottom bar  -->
            <MenuItem Command="{Binding ToggleBottomToolbarCommand}" Header="{CompiledBinding Translation.HideBottomToolbar.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource Panel-Bottom}" />
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <ContextMenu x:Key="OpenMenu">
            <!--  Open  -->
            <MenuItem
                MinWidth="180"
                Command="{CompiledBinding OpenCommand}"
                Header="{CompiledBinding Translation.Open.Value,
                                         Mode=OneWay}">
                <MenuItem.Icon>
                    <Image Classes="OpenImage" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Save  -->
            <MenuItem
                Command="{CompiledBinding SaveCommand}"
                Header="{CompiledBinding Translation.Save.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Path Classes="SavePath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Save as  -->
            <MenuItem
                Command="{CompiledBinding SaveAsCommand}"
                Header="{CompiledBinding Translation.SaveAs.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull}}">
                <MenuItem.Icon>
                    <Path Classes="SavePath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Print  -->
            <MenuItem
                x:Name="PrintMenuItem"
                Command="{CompiledBinding PrintCommand}"
                Header="{CompiledBinding Translation.Print.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="PrintPath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Open with  -->
            <MenuItem
                x:Name="OpenWithMenuItem"
                Command="{CompiledBinding OpenWithCommand}"
                Header="{CompiledBinding Translation.OpenWith.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource OpenExternalImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Locate on disk  -->
            <MenuItem
                Command="{CompiledBinding OpenInExplorerCommand}"
                Header="{CompiledBinding Translation.ShowInFolder.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Path Classes="ShowInFolderPath" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Delete file  -->
            <MenuItem
                x:Name="DeleteFileMenuItem"
                Command="{CompiledBinding DeleteFileCommand}"
                Header="{CompiledBinding Translation.DeleteFile.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="RecyclePath" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Paste  -->
            <MenuItem Command="{CompiledBinding PasteCommand}" Header="{CompiledBinding Translation.Paste.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="PastePath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Copy  -->
            <MenuItem Header="{CompiledBinding Translation.Copy.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="CopyPath" />
                </MenuItem.Icon>

                <!--  Copy image  -->
                <MenuItem Header="{CompiledBinding Translation.CopyImage.Value, Mode=OneWay}" IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path Classes="CopyPath" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Copy file path  -->
                <MenuItem
                    Command="{CompiledBinding CopyFileCommand}"
                    Header="{Binding Translation.FileCopyPath.Value, Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path Classes="CopyPath" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Copy base64  -->
                <MenuItem Command="{CompiledBinding CopyBase64Command}" IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False, Mode=OneWay}">
                    <MenuItem.Header>
                        <TextBlock>
                            <Run Text="{CompiledBinding Translation.Copy.Value, Mode=OneWay}" />
                            <Run Text=" base64" />
                        </TextBlock>
                    </MenuItem.Header>
                    <MenuItem.Icon>
                        <Path Classes="CopyPath" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Duplicate file  -->
                <MenuItem
                    Command="{CompiledBinding DuplicateFileCommand}"
                    Header="{CompiledBinding Translation.DuplicateFile.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path Classes="DuplicatePath" />
                    </MenuItem.Icon>
                </MenuItem>

            </MenuItem>

            <!--  Copy file  -->
            <MenuItem
                Command="{CompiledBinding CopyFileCommand}"
                Header="{CompiledBinding Translation.CopyFile.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="CopyPath" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Hide bottom bar  -->
            <MenuItem Command="{Binding ToggleBottomToolbarCommand}" Header="{CompiledBinding Translation.HideBottomToolbar.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource Panel-Bottom}" />
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <ContextMenu x:Key="BottomMenu">
            <!--  Hide bottom bar  -->
            <MenuItem Command="{Binding ToggleBottomToolbarCommand}" Header="{CompiledBinding Translation.HideBottomToolbar.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource Panel-Bottom}" />
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

    </UserControl.Resources>

    <Border
        x:Name="MainBottomBorder"
        Height="{CompiledBinding BottombarHeight.Value,
                                 Mode=OneWay}"
        Background="{DynamicResource MenuBackgroundColor}"
        BorderBrush="{DynamicResource WindowBorderColor}"
        BorderThickness="0,1,0,0"
        ContextMenu="{StaticResource BottomMenu}">
        <Panel>
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">

                <customControls:IconButton
                    x:Name="FileMenuButton"
                    Width="38"
                    Height="{CompiledBinding BottombarHeight.Value}"
                    Background="{DynamicResource SecondaryButtonBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1,0,1,0"
                    Classes="noBorderHover"
                    Command="{CompiledBinding OpenCommand}"
                    ContextMenu="{StaticResource OpenMenu}"
                    Foreground="{DynamicResource MainTextColor}"
                    Icon="{StaticResource OpenFolderImage}"
                    IconHeight="17"
                    IconWidth="20"
                    IsTabStop="False"
                    ToolTip.HorizontalOffset="15"
                    ToolTip.Tip="{CompiledBinding Translation.OpenFileDialog.Value}" />

                <customControls:IconButton
                    x:Name="ZoomOutButton"
                    Width="38"
                    Height="{CompiledBinding BottombarHeight.Value}"
                    Background="{DynamicResource AltBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="0,0,1,0"
                    Classes="noBorderHover"
                    Command="{CompiledBinding ZoomOutCommand}"
                    ContextMenu="{StaticResource RotationContextMenu}"
                    Icon="{StaticResource ZoomOutImage}"
                    IconHeight="16"
                    IconWidth="18"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}"
                    IsTabStop="False"
                    ToolTip.HorizontalOffset="15"
                    ToolTip.Tip="{CompiledBinding Translation.ZoomOut.Value}" />

                <customControls:IconButton
                    x:Name="ZoomInButton"
                    Width="38"
                    Height="{CompiledBinding BottombarHeight.Value}"
                    Background="{DynamicResource AltBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="0,0,1,0"
                    Classes="noBorderHover"
                    Command="{CompiledBinding ZoomInCommand}"
                    ContextMenu="{StaticResource RotationContextMenu}"
                    Icon="{StaticResource ZoomImage}"
                    IconHeight="16"
                    IconWidth="18"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}"
                    IsTabStop="False"
                    ToolTip.HorizontalOffset="15"
                    ToolTip.Tip="{CompiledBinding Translation.ZoomIn.Value}" />

                <customControls:IconButton
                    x:Name="ResetZoomButton"
                    Width="38"
                    Height="25"
                    Background="{DynamicResource AltBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="0,0,1,0"
                    Classes="noBorderHover"
                    Command="{CompiledBinding ResetZoomAndRotationsCommand}"
                    ContextMenu="{StaticResource RotationContextMenu}"
                    Icon="{StaticResource RefreshCcwOff}"
                    IconHeight="17"
                    IconWidth="17"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}"
                    IsTabStop="False"
                    ToolTip.HorizontalOffset="15"
                    ToolTip.Tip="{CompiledBinding Translation.ResetZoom.Value}" />

                <customControls:IconButton
                    x:Name="PreviousButton"
                    Width="80"
                    Height="{CompiledBinding BottombarHeight.Value}"
                    Background="{DynamicResource MainButtonBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="0,0,1,0"
                    Classes="hover"
                    Command="{CompiledBinding WindowTabs.PrevFile}"
                    ContextMenu="{StaticResource MainContextMenu}"
                    Data="{StaticResource FilledArrowLeftGeometry}"
                    Focusable="False"
                    Foreground="{DynamicResource MainTextColor}"
                    IconHeight="20"
                    IconWidth="17"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateBackwards.Value,
                                                FallbackValue=False}"
                    IsTabStop="False" />

                <customControls:IconButton
                    x:Name="NextButton"
                    Width="80"
                    Height="{CompiledBinding BottombarHeight.Value}"
                    Background="{DynamicResource MainButtonBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="0,0,1,0"
                    Classes="hover"
                    Command="{CompiledBinding WindowTabs.NextFile}"
                    ContextMenu="{StaticResource MainContextMenu}"
                    Data="{StaticResource FilledArrowRightGeometry}"
                    Focusable="False"
                    Foreground="{DynamicResource MainTextColor}"
                    IconHeight="20"
                    IconWidth="17"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateForwards.Value,
                                                FallbackValue=False}"
                    IsTabStop="False" />

                <customControls:IconButton
                    x:Name="RotateRightButton"
                    Width="38"
                    Height="{CompiledBinding BottombarHeight.Value}"
                    Margin="0"
                    Background="{DynamicResource AltBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="0,0,1,0"
                    Classes="noBorderHover"
                    Command="{CompiledBinding RotateRightCommand}"
                    ContextMenu="{StaticResource RotationContextMenu}"
                    DockPanel.Dock="Left"
                    Foreground="{DynamicResource MainTextColor}"
                    Icon="{StaticResource RotateCwImage}"
                    IconHeight="16"
                    IconWidth="16"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}"
                    IsRepeatEnabled="False"
                    ToolTip.HorizontalOffset="15"
                    ToolTip.Tip="{CompiledBinding Translation.RotateRight.Value,
                                                  Mode=OneWay}" />

                <customControls:IconButton
                    x:Name="RotateLeftButton"
                    Width="38"
                    Height="{CompiledBinding BottombarHeight.Value}"
                    Margin="0"
                    Background="{DynamicResource AltBackgroundColor}"
                    Classes="noBorderHover"
                    Command="{CompiledBinding RotateLeftCommand}"
                    ContextMenu="{StaticResource RotationContextMenu}"
                    DockPanel.Dock="Left"
                    Foreground="{DynamicResource MainTextColor}"
                    Icon="{StaticResource RotateCcwImage}"
                    IconHeight="16"
                    IconWidth="16"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}"
                    IsRepeatEnabled="False"
                    ToolTip.HorizontalOffset="15"
                    ToolTip.Tip="{CompiledBinding Translation.RotateLeft.Value,
                                                  Mode=OneWay}" />

                <customControls:IconButton
                    x:Name="FlipButton"
                    Width="38"
                    Height="{CompiledBinding BottombarHeight.Value}"
                    Margin="0"
                    Background="{DynamicResource AltBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1,0,1,0"
                    Classes="noBorderHover"
                    Command="{CompiledBinding FlipCommand}"
                    ContextMenu="{StaticResource RotationContextMenu}"
                    DockPanel.Dock="Left"
                    Foreground="{DynamicResource MainTextColor}"
                    Icon="{StaticResource RepeatImage}"
                    IconHeight="16"
                    IconWidth="16"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}"
                    IsRepeatEnabled="False"
                    ToolTip.HorizontalOffset="15"
                    ToolTip.Tip="{CompiledBinding Translation.IsFlipped.Value,
                                                  Mode=OneWay}">
                    <Button.RenderTransform>
                        <ScaleTransform ScaleX="{Binding WindowTabs.ActiveTab.Value.ScaleX.Value}" />
                    </Button.RenderTransform>
                </customControls:IconButton>

                <customControls:IconButton
                    x:Name="SettingsMenuButton"
                    Width="38"
                    Height="{CompiledBinding BottombarHeight.Value}"
                    Background="{DynamicResource SecondaryButtonBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="0,0,1,0"
                    Classes="noBorderHover"
                    Command="{CompiledBinding SettingsWindowCommand}"
                    ContextMenu="{StaticResource SettingsContextMenu}"
                    Foreground="{DynamicResource MainTextColor}"
                    Icon="{StaticResource CogImage}"
                    IconHeight="18"
                    IconWidth="18"
                    IsTabStop="False"
                    ToolTip.HorizontalOffset="15"
                    ToolTip.Tip="{CompiledBinding Translation.Settings.Value}"
                    ZIndex="1" />

            </StackPanel>

            <Path
                Width="12"
                Height="12"
                Margin="0,0,2,2"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Data="{StaticResource GripGeometry}"
                Fill="{DynamicResource MainTextColor}"
                IsVisible="{Binding !IsAutoFit.Value}"
                Stretch="Fill"
                Stroke="{DynamicResource MainBorderColor}"
                StrokeThickness="1" />
        </Panel>
    </Border>
</UserControl>