<UserControl
    x:Class="PicView.Avalonia.Views.UC.ImageViewer2"
    x:DataType="viewModels1:TabViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:viewModels="clr-namespace:PicView.Avalonia.ViewModels"
    xmlns:viewModels1="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <LayoutTransformControl x:Name="ImageLayoutTransformControl">
        <customControls:ZoomPanControl x:Name="ZoomPanControl">
            <customControls:AutoScrollViewer
                Focusable="False"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Disabled"
                x:Name="ImageScrollViewer">
                <!--  ReSharper disable once Xaml.PossibleNullReferenceException  -->
                <Border Background="{Binding $parent[Window].((viewModels:MainViewModel)DataContext).MainWindow.ConstrainedImageBackground.Value}" x:Name="MainBorder">
                    <customControls:PicBox2 Source="{CompiledBinding CurrentModel.Value.Image}" x:Name="MainImage" />
                </Border>
            </customControls:AutoScrollViewer>
        </customControls:ZoomPanControl>
    </LayoutTransformControl>
</UserControl>