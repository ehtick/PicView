<UserControl
    x:Class="PicView.Avalonia.Views.UC.ImageViewer2"
    x:DataType="viewModels1:TabViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:buttons="clr-namespace:PicView.Avalonia.Views.UC.Buttons"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:uc="clr-namespace:PicView.Avalonia.Views.UC"
    xmlns:viewModels1="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:vm="clr-namespace:PicView.Avalonia.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <LayoutTransformControl x:Name="ImageLayoutTransformControl">
        <Panel x:Name="MainPanel">
            <customControls:ZoomPanControl2 x:Name="ZoomPanControl">
                <customControls:AutoScrollViewer
                    Focusable="False"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Disabled"
                    x:Name="ImageScrollViewer">
                    <Border x:Name="MainBorder">
                        <UniformGrid Rows="1">
                            <customControls:PicBox2 Source="{CompiledBinding Model.Value.Image}" x:Name="MainImage" />
                            <customControls:PicBox2
                                IsVisible="False"
                                Source="{CompiledBinding SecondaryModel.Value.Image}"
                                x:Name="SecondaryImage" />
                        </UniformGrid>
                    </Border>
                </customControls:AutoScrollViewer>
            </customControls:ZoomPanControl2>
            <buttons:ClickArrowRight2
                HorizontalAlignment="Right"
                Margin="{CompiledBinding $parent[Window].((vm:MainWindowViewModel)DataContext).RightControlOffSetMargin.Value}"
                Opacity="0"
                VerticalAlignment="Center" />
            <buttons:ClickArrowLeft2
                HorizontalAlignment="Left"
                Opacity="0"
                VerticalAlignment="Center" />
            <uc:ZoomPreviewer2
                HorizontalAlignment="Right"
                IsVisible="False"
                Margin="0,0,25,25"
                VerticalAlignment="Bottom"
                ZIndex="90"
                x:Name="ZoomPreview" />
            <uc:HoverBar2 VerticalAlignment="Bottom" x:Name="HoverBar" />
        </Panel>
    </LayoutTransformControl>
</UserControl>