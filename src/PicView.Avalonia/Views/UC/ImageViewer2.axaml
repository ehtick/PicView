<UserControl
    x:Class="PicView.Avalonia.Views.UC.ImageViewer2"
    x:DataType="viewModels1:TabViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:buttons="clr-namespace:PicView.Avalonia.Views.UC.Buttons"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:gallery="clr-namespace:PicView.Avalonia.Views.Gallery"
    xmlns:uc="clr-namespace:PicView.Avalonia.Views.UC"
    xmlns:viewModels1="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel LastChildFill="True">
        <gallery:GalleryView2
            Background="{DynamicResource MenuBackgroundColor}"
            DockPanel.Dock="Bottom"
            ZIndex="1"
            x:Name="GalleryView" />
        <Panel Background="{CompiledBinding $parent[Window].((viewModels1:MainWindowViewModel)DataContext).ImageBackground.Value, Mode=OneWay}" x:Name="MainPanel">
            <customControls:ZoomPanControl2 x:Name="ZoomPanControl">
                <customControls:AutoScrollViewer
                    Focusable="False"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Disabled"
                    x:Name="ImageScrollViewer">
                    <Border
                        Background="{CompiledBinding $parent[Window].((viewModels1:MainWindowViewModel)DataContext).ConstrainedImageBackground.Value,
                                                     Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        x:Name="MainBorder">
                        <UniformGrid Rows="1">
                            <LayoutTransformControl x:Name="MainTransform">
                                <customControls:PicBox2 Source="{CompiledBinding Image.Value}" x:Name="MainImage" />
                            </LayoutTransformControl>
                            <LayoutTransformControl IsVisible="False" x:Name="SecondaryTransform">
                                <customControls:PicBox2 Source="{CompiledBinding SecondaryImage.Value}" x:Name="SecondaryImage" />
                            </LayoutTransformControl>
                        </UniformGrid>
                    </Border>
                </customControls:AutoScrollViewer>
            </customControls:ZoomPanControl2>
            <uc:ZoomPreviewer2
                HorizontalAlignment="Right"
                IsVisible="False"
                Margin="0,0,25,25"
                VerticalAlignment="Bottom"
                ZIndex="90"
                x:Name="ZoomPreview" />
            <uc:HoverBar2 VerticalAlignment="Bottom" x:Name="HoverBar" />
            <buttons:ClickArrowRight2
                HorizontalAlignment="Right"
                Opacity="0"
                VerticalAlignment="Center"
                ZIndex="2"
                x:Name="ClickArrowRight" />
            <buttons:ClickArrowLeft2
                HorizontalAlignment="Left"
                Opacity="0"
                VerticalAlignment="Center"
                ZIndex="2"
                x:Name="ClickArrowLeft" />
            <buttons:GalleryShortcut2
                HorizontalAlignment="Right"
                Opacity="0"
                VerticalAlignment="Bottom"
                ZIndex="9"
                x:Name="GalleryShortcut" />
        </Panel>
    </DockPanel>
</UserControl>