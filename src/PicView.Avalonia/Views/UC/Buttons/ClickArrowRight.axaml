<UserControl
    Background="Transparent"
    Focusable="False"
    Height="200"
    Width="100"
    x:Class="PicView.Avalonia.Views.UC.Buttons.ClickArrowRight"
    x:DataType="viewModels:TabViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <RepeatButton
        Background="{StaticResource AltBackgroundColor}"
        BorderBrush="{StaticResource MainBorderColor}"
        BorderThickness="1,1,0,1"
        Classes="hover"
        Command="{CompiledBinding Next}"
        CornerRadius="2,0,0,2"
        Height="60"
        HorizontalAlignment="Right"
        IsVisible="{CompiledBinding CanNavigateForwards.Value,
                                    FallbackValue=False}"
        Width="50"
        x:Name="PolyButton">
        <Polygon
            Fill="{StaticResource MainTextColor}"
            Height="40"
            Margin="5,5,0,0"
            Points="160,128.4 192.3,96 352,256 352,256 352,256 192.3,416 160,383.6 287.3,256"
            RenderTransformOrigin="0.5,0.5"
            Stretch="Uniform"
            Width="20" />
    </RepeatButton>
</UserControl>