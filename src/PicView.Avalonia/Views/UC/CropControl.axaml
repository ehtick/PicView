<UserControl
    x:Class="PicView.Avalonia.Views.UC.CropControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    x:DataType="viewModels:TabViewModel"
    ClipToBounds="False">
    <UserControl.Resources>
        <SolidColorBrush x:Key="Brush0" Color="{DynamicResource MainTextColor}" />
    </UserControl.Resources>
    <UserControl.Styles>
        <Styles>
            <Style Selector="Border.x">
                <Setter Property="Background" Value="{DynamicResource SecondaryButtonBackgroundColor}" />
                <Setter Property="BorderBrush" Value="#fff" />
                <Setter Property="BorderThickness" Value="2" />
                <Setter Property="Width" Value="20" />
                <Setter Property="Height" Value="20" />
                <Setter Property="ZIndex" Value="1" />
                <Setter Property="CornerRadius" Value="2" />
            </Style>
        </Styles>
    </UserControl.Styles>
    <UserControl.ContextMenu>
        <ContextMenu x:Name="CropContextMenu">
            <MenuItem Command="{CompiledBinding Crop.CropImageCommand}" Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Crop.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource CropImage}" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Command="{CompiledBinding Crop.CopyCropImageCommand}" Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Copy.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path
                        Width="12"
                        Height="12"
                        Data="{StaticResource CopyGeometry}"
                        Fill="{StaticResource Brush0}"
                        Stretch="Fill" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Command="{CompiledBinding Crop.CloseCropCommand}" Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Close.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path
                        Width="12"
                        Height="12"
                        Data="{StaticResource CloseGeometry}"
                        Fill="{StaticResource Brush0}"
                        Stretch="Fill" />
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </UserControl.ContextMenu>
    <Panel>
        <!--  Image control to display the bitmap  -->
        <customControls:PicBox
            x:Name="ImageControl"
            CurrentFileInfo="{Binding FileInfo.Value}"
            ImageType="{Binding ImageType.Value}"
            Source="{Binding Image.Value}" />

        <Canvas x:Name="RootCanvas" Background="Transparent">

            <!--  Size Border  -->
            <Border
                x:Name="SizeBorder"
                Padding="8,5"
                Background="{DynamicResource SecondaryButtonBackgroundColor}"
                BorderBrush="{DynamicResource MainBorderColor}"
                BorderThickness="1"
                CornerRadius="4"
                IsHitTestVisible="False"
                ZIndex="2">
                <TextBlock
                    Classes="txt"
                    FontSize="14"
                    Foreground="{DynamicResource MainTextColor}">
                    <Run Text="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Width.Value, Mode=OneWay}" />
                    <Run Text=": " />
                    <Run Text="{CompiledBinding Crop.PixelSelectionWidth.Value, Mode=OneWay}" />
                    <Run Text=" x " />
                    <Run Text="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Height.Value, Mode=OneWay}" />
                    <Run Text=": " />
                    <Run Text="{CompiledBinding Crop.PixelSelectionHeight.Value, Mode=OneWay}" />
                </TextBlock>
            </Border>

            <!--  Main Rectangle  -->
            <Border
                x:Name="MainRectangle"
                Width="{CompiledBinding Crop.SelectionWidth.Value}"
                Height="{CompiledBinding Crop.SelectionHeight.Value}"
                Background="Transparent"
                BorderBrush="#fff"
                BorderThickness="2"
                Cursor="Hand" />

            <!--  Top Left  -->
            <Border
                x:Name="TopLeftButton"
                Classes="x"
                Cursor="TopLeftCorner" />

            <!--  Top Right  -->
            <Border
                x:Name="TopRightButton"
                Classes="x"
                Cursor="TopRightCorner" />

            <!--  Top Middle  -->
            <Border
                x:Name="TopMiddleButton"
                Classes="x"
                Cursor="SizeNorthSouth" />

            <!--  Bottom Right  -->
            <Border
                x:Name="BottomRightButton"
                Classes="x"
                Cursor="BottomRightCorner" />

            <!--  Bottom Middle  -->
            <Border
                x:Name="BottomMiddleButton"
                Classes="x"
                Cursor="SizeNorthSouth" />

            <!--  Bottom Left  -->
            <Border
                x:Name="BottomLeftButton"
                Classes="x"
                Cursor="BottomLeftCorner" />

            <!--  Left Middle  -->
            <Border
                x:Name="LeftMiddleButton"
                Classes="x"
                Cursor="SizeWestEast" />

            <!--  Right Middle  -->
            <Border
                x:Name="RightMiddleButton"
                Classes="x"
                Cursor="SizeWestEast" />

            <!--  Surrounding rectangles  -->
            <Rectangle x:Name="TopRectangle" Fill="#80000000" />
            <Rectangle x:Name="BottomRectangle" Fill="#80000000" />
            <Rectangle x:Name="LeftRectangle" Fill="#80000000" />
            <Rectangle x:Name="RightRectangle" Fill="#80000000" />
        </Canvas>
    </Panel>
</UserControl>
