<UserControl
    Focusable="False"
    x:Class="PicView.Avalonia.Views.UC.ZoomPreviewer2"
    x:DataType="vm:TabViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:vm="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border
        Background="{DynamicResource MainBackgroundColor}"
        BorderBrush="{DynamicResource MainBorderColor}"
        BorderThickness="1"
        CornerRadius="6,6,1,1"
        x:Name="MainBorder">
        <StackPanel>
            <Border
                Background="{DynamicResource MainBackgroundColor}"
                BorderBrush="{DynamicResource MainBorderColor}"
                BorderThickness="0,0,1,1"
                CornerRadius="6,6,1,1">
                <Grid ColumnDefinitions="*,*">
                    <customControls:IconButton
                        Classes="altHover mainBtn"
                        CornerRadius="6,0,0,0"
                        Data="{StaticResource ReloadGeometry}"
                        Foreground="{DynamicResource MainTextColor}"
                        Grid.Column="0"
                        Height="22"
                        IconHeight="11"
                        IconWidth="11"
                        Padding="1"
                        ToolTip.Tip="{CompiledBinding $parent[Window].((vm:MainWindowViewModel)DataContext).Translation.ResetZoom.Value}"
                        x:Name="ResetZoomButton" />

                    <customControls:IconButton
                        Classes="altHover mainBtn"
                        CornerRadius="0,6,0,0"
                        Data="{StaticResource CloseGeometry}"
                        Foreground="{DynamicResource MainTextColor}"
                        Grid.Column="1"
                        Height="22"
                        IconHeight="10"
                        IconWidth="10"
                        Padding="1"
                        ToolTip.Tip="{CompiledBinding $parent[Window].((vm:MainWindowViewModel)DataContext).Translation.Close.Value}"
                        x:Name="CloseButton" />
                </Grid>
            </Border>
            <LayoutTransformControl>
                <LayoutTransformControl.LayoutTransform>
                    <RotateTransform Angle="{CompiledBinding Model.Rotation}" />
                </LayoutTransformControl.LayoutTransform>
                <Panel>
                    <customControls:PicBox
                        ImageType="{CompiledBinding ImageType.Value,
                                                    Mode=OneWay,
                                                    FallbackValue=0}"
                        Source="{CompiledBinding Image.Value}"
                        x:Name="OverlayImage" />
                    <Canvas x:Name="OverlayCanvas">
                        <Rectangle
                            Fill="Transparent"
                            Stroke="{DynamicResource AccentColor}"
                            StrokeThickness="2"
                            x:Name="ViewportBorder" />
                    </Canvas>
                </Panel>
            </LayoutTransformControl>
        </StackPanel>
    </Border>
</UserControl>