<UserControl
    x:Class="PicView.Avalonia.Views.UC.ImageViewer"
    x:DataType="vm:TabViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:buttons="clr-namespace:PicView.Avalonia.Views.UC.Buttons"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:gallery="clr-namespace:PicView.Avalonia.Views.Gallery"
    xmlns:uc="clr-namespace:PicView.Avalonia.Views.UC"
    xmlns:vm="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel LastChildFill="True">
        <gallery:GalleryView2 ZIndex="1" x:Name="GalleryView" />

        <Panel
            Background="{CompiledBinding $parent[Window].((vm:MainWindowViewModel)DataContext).GlobalSettings.ImageBackground.Value,
                                         Mode=OneWay}"
            DockPanel.Dock="Left"
            x:Name="MainPanel">
            <LayoutTransformControl x:Name="MainTransform">
                <LayoutTransformControl.LayoutTransform>
                    <RotateTransform Angle="{Binding RotationAngle.Value}" />
                </LayoutTransformControl.LayoutTransform>
                <customControls:ZoomPanControl2 x:Name="ZoomPanControl">
                    <customControls:AutoScrollViewer
                        Focusable="False"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Disabled"
                        x:Name="ImageScrollViewer">
                        <Border
                            Background="{CompiledBinding $parent[Window].((vm:MainWindowViewModel)DataContext).GlobalSettings.ConstrainedImageBackground.Value,
                                                         Mode=OneWay}"
                            Height="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ImageHeight.Value}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ImageWidth.Value}"
                            x:Name="MainBorder">
                            <DockPanel
                                HorizontalAlignment="Center"
                                LastChildFill="False"
                                VerticalAlignment="Center">
                                <customControls:PicBox2
                                    DockPanel.Dock="Left"
                                    Source="{CompiledBinding Image.Value}"
                                    x:Name="MainImage" />
                                <customControls:PicBox2
                                    DockPanel.Dock="Right"
                                    IsVisible="{CompiledBinding $parent[Window].((vm:MainWindowViewModel)DataContext).IsSideBySide.Value}"
                                    Source="{CompiledBinding SecondaryImage.Value}"
                                    x:Name="SecondaryImage" />
                            </DockPanel>
                        </Border>
                    </customControls:AutoScrollViewer>
                </customControls:ZoomPanControl2>
            </LayoutTransformControl>
            <uc:ZoomPreviewer
                HorizontalAlignment="Right"
                IsVisible="False"
                Margin="0,0,25,25"
                VerticalAlignment="Bottom"
                ZIndex="90"
                x:Name="ZoomPreview" />
            <uc:HoverBar VerticalAlignment="Bottom" x:Name="HoverBar" />
            <buttons:ClickArrowRight2
                HorizontalAlignment="Right"
                Opacity="0"
                VerticalAlignment="Center"
                ZIndex="2"
                x:Name="ClickArrowRight" />
            <buttons:ClickArrowLeft2
                HorizontalAlignment="Left"
                Opacity="0"
                VerticalAlignment="Center"
                ZIndex="2"
                x:Name="ClickArrowLeft" />
            <buttons:GalleryShortcut2
                HorizontalAlignment="Right"
                IsVisible="{CompiledBinding !$parent[Window].((vm:MainWindowViewModel)DataContext).IsUIShown.Value}"
                Opacity="0"
                VerticalAlignment="Bottom"
                ZIndex="9"
                x:Name="GalleryShortcut" />
        </Panel>
    </DockPanel>
</UserControl>