                                    <customControls:CustomSlider
                                        Height="30"
                                        IsSnapToTickEnabled="False"
                                        LargeChange="0.1"
                                        Margin="0,1,10,1"
                                        Maximum="3"
                                        Minimum="0.3"
                                        SmallChange="0.01"
                                        Theme="{StaticResource SetBg}"
                                        TickFrequency="0.01"
                                        Value="1"
                                        Width="400"
                                        x:Name="GammaSlider">
                                        <customControls:CustomSlider.Background>
                                            <LinearGradientBrush EndPoint="100%,50%" StartPoint="0%,50%">
                                                <GradientStop Color="#1A1A1A" Offset="0" />
                                                <GradientStop Color="#A0A0A0" Offset="0.5" />
                                                <GradientStop Color="#F5F5F5" Offset="1" />
                                            </LinearGradientBrush>
                                        </customControls:CustomSlider.Background>
                                    </customControls:CustomSlider>

                                    <NumericUpDown
                                        Increment="0.01"
                                        Maximum="{Binding Path=Maximum, ElementName=GammaSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=GammaSlider}"
                                        Value="{Binding Path=Value, ElementName=GammaSlider}" />

                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetGammaBtn" />
                                </StackPanel>

                                <TextBlock Classes="txt sectionHeader" Text="{Binding Translation.Tonal.Value}" />

                                <!--  Highlights  -->
                                <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Highlights.Value}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        Maximum="100"
                                        Minimum="-100"
                                        Theme="{StaticResource SetBg}"
                                        Value="0"
                                        Width="400"
                                        x:Name="HighlightsSlider">
                                        <customControls:CustomSlider.Background>
                                            <LinearGradientBrush EndPoint="100%,50%" StartPoint="0%,50%">
                                                <GradientStop Color="#C0C0C0" Offset="0" />
                                                <GradientStop Color="#FFFFFF" Offset="1" />
                                            </LinearGradientBrush>
                                        </customControls:CustomSlider.Background>
                                    </customControls:CustomSlider>
                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=HighlightsSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=HighlightsSlider}"
                                        Value="{Binding Path=Value, ElementName=HighlightsSlider}" />
                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetHighlightsBtn" />
                                </StackPanel>

                                <!--  Shadows  -->
                                <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Shadows.Value}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        Maximum="100"
                                        Minimum="-100"
                                        Theme="{StaticResource SetBg}"
                                        Value="0"
                                        Width="400"
                                        x:Name="ShadowsSlider">
                                        <customControls:CustomSlider.Background>
                                            <LinearGradientBrush EndPoint="100%,50%" StartPoint="0%,50%">
                                                <GradientStop Color="#000000" Offset="0" />
                                                <GradientStop Color="#808080" Offset="1" />
                                            </LinearGradientBrush>
                                        </customControls:CustomSlider.Background>
                                    </customControls:CustomSlider>
                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=ShadowsSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=ShadowsSlider}"
                                        Value="{Binding Path=Value, ElementName=ShadowsSlider}" />
                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetShadowsBtn" />
                                </StackPanel>

                                <!--  Blacks / Whites  -->
                                <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Blacks.Value}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        Maximum="50"
                                        Minimum="-50"
                                        Theme="{StaticResource SetBg}"
                                        Value="0"
                                        Width="400"
                                        x:Name="BlacksSlider">
                                        <customControls:CustomSlider.Background>
                                            <LinearGradientBrush EndPoint="100%,50%" StartPoint="0%,50%">
                                                <GradientStop Color="#000000" Offset="0" />
                                                <GradientStop Color="#404040" Offset="0.5" />
                                                <GradientStop Color="#808080" Offset="1" />
                                            </LinearGradientBrush>
                                        </customControls:CustomSlider.Background>
                                    </customControls:CustomSlider>
                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=BlacksSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=BlacksSlider}"
                                        Value="{Binding Path=Value, ElementName=BlacksSlider}" />
                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetBlacksBtn" />
                                </StackPanel>

                                <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Whites.Value}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        Maximum="50"
                                        Minimum="-50"
                                        Theme="{StaticResource SetBg}"
                                        Value="0"
                                        Width="400"
                                        x:Name="WhitesSlider">
                                        <customControls:CustomSlider.Background>
                                            <LinearGradientBrush EndPoint="100%,50%" StartPoint="0%,50%">
                                                <GradientStop Color="#D0D0D0" Offset="0" />
                                                <GradientStop Color="#FFFFFF" Offset="1" />
                                            </LinearGradientBrush>
                                        </customControls:CustomSlider.Background>
                                    </customControls:CustomSlider>
                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=WhitesSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=WhitesSlider}"
                                        Value="{Binding Path=Value, ElementName=WhitesSlider}" />
                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetWhitesBtn" />
                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!--  EFFECTS TAB  -->
                    <TabItem Header="{Binding Translation.Effects.Value}" Margin="0">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="15,10">

                                <DockPanel LastChildFill="True" Margin="0,0,-10,0">
                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        DockPanel.Dock="Right"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Height="30"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        ToolTip.Tip="{Binding Translation.ResetButtonText.Value}"
                                        Width="30"
                                        x:Name="ResetEffectsTabBtn" />

                                    <TextBlock
                                        Classes="txt sectionHeader"
                                        DockPanel.Dock="Left"
                                        Text="{CompiledBinding Translation.Effects.Value,
                                                               Mode=OneWay}" />
                                </DockPanel>

                                <!--  Dehaze  -->
                                <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Dehaze.Value}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        Margin="0,1,10,1"
                                        Maximum="100"
                                        Minimum="0"
                                        Value="0"
                                        Width="400"
                                        x:Name="DehazeSlider" />

                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=DehazeSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=DehazeSlider}"
                                        Value="{Binding Path=Value, ElementName=DehazeSlider}" />

                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetDehazeBtn" />
                                </StackPanel>

                                <!--  Clarity  -->
                                <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Clarity.Value}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        Margin="0,1,10,1"
                                        Maximum="100"
                                        Minimum="0"
                                        Value="0"
                                        Width="400"
                                        x:Name="ClaritySlider" />

                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=ClaritySlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=ClaritySlider}"
                                        Value="{Binding Path=Value, ElementName=ClaritySlider}" />

                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetClarityBtn" />
                                </StackPanel>

                                <!--  Grain  -->
                                <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.FilmGrain.Value}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        Margin="0,1,10,1"
                                        Maximum="100"
                                        Minimum="0"
                                        Value="0"
                                        Width="400"
                                        x:Name="GrainSlider" />

                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=GrainSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=GrainSlider}"
                                        Value="{Binding Path=Value, ElementName=GrainSlider}" />

                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetGrainBtn" />
                                </StackPanel>

                                <!--  Sharpen  -->
                                <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Sharpen.Value}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        Margin="0,1,10,1"
                                        Maximum="100"
                                        Minimum="0"
                                        Value="0"
                                        Width="400"
                                        x:Name="SharpenSlider" />

                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=SharpenSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=SharpenSlider}"
                                        Value="{Binding Path=Value, ElementName=SharpenSlider}" />

                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetSharpenBtn" />
                                </StackPanel>

                                <!--  Vignette  -->
                                <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Vignette.Value}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        Margin="0,1,10,1"
                                        Maximum="100"
                                        Minimum="0"
                                        Value="0"
                                        Width="400"
                                        x:Name="VignetteSlider" />

                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=VignetteSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=VignetteSlider}"
                                        Value="{Binding Path=Value, ElementName=VignetteSlider}" />

                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetVignetteBtn" />
                                </StackPanel>

                                <!--  Blur  -->
                                <TextBlock Classes="txt fieldLabel" Text="{CompiledBinding Translation.Blur.Value, Mode=OneWay}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        LargeChange="1"
                                        Margin="0,1,10,1"
                                        Maximum="30"
                                        Minimum="0"
                                        SmallChange="0.1"
                                        TickFrequency="0.1"
                                        Value="0"
                                        Width="400"
                                        x:Name="BlurSlider" />

                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=BlurSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=BlurSlider}"
                                        Value="{Binding Path=Value, ElementName=BlurSlider}" />

                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetBlurBtn" />
                                </StackPanel>

                                <!--  Pencil Sketch  -->
                                <TextBlock Classes="txt fieldLabel" Text="{CompiledBinding Translation.PencilSketch.Value, Mode=OneWay}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        LargeChange="0.5"
                                        Margin="0,1,10,1"
                                        Maximum="6"
                                        Minimum="0"
                                        SmallChange="0.1"
                                        TickFrequency="0.1"
                                        Value="0"
                                        Width="400"
                                        x:Name="PencilSketchSlider" />

                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=PencilSketchSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=PencilSketchSlider}"
                                        Value="{Binding Path=Value, ElementName=PencilSketchSlider}" />

                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetPencilSketchBtn" />
                                </StackPanel>

                                <!--  Posterize  -->
                                <TextBlock Classes="txt fieldLabel" Text="{CompiledBinding Translation.Posterize.Value, Mode=OneWay}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        LargeChange="2"
                                        Margin="0,1,10,1"
                                        Maximum="32"
                                        Minimum="0"
                                        SmallChange="1"
                                        TickFrequency="1"
                                        Width="400"
                                        x:Name="PosterizeSlider" />

                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=PosterizeSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=PosterizeSlider}"
                                        Value="{Binding Path=Value, ElementName=PosterizeSlider}" />

                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetPosterizeBtn" />
                                </StackPanel>

                                <!--  Solarize  -->
                                <TextBlock Classes="txt fieldLabel" Text="{CompiledBinding Translation.Solarize.Value, Mode=OneWay}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        LargeChange="5"
                                        Margin="0,1,10,1"
                                        Maximum="100"
                                        Minimum="0"
                                        SmallChange="1"
                                        TickFrequency="5"
                                        Value="0"
                                        Width="400"
                                        x:Name="SolarizeSlider" />

                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=SolarizeSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=SolarizeSlider}"
                                        Value="{Binding Path=Value, ElementName=SolarizeSlider}" />

                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetSolarizeBtn" />
                                </StackPanel>

                                <!--  Black And White Toggle  -->
                                <ToggleButton
                                    Background="Transparent"
                                    Classes="altHover"
                                    Margin="0,12,0,0"
                                    x:Name="BlackAndWhiteToggleButton">
                                    <TextBlock
                                        Classes="txt"
                                        Foreground="{StaticResource SecondaryTextColor}"
                                        HorizontalAlignment="Left"
                                        Text="{CompiledBinding Translation.BlackAndWhite.Value,
                                                               Mode=OneWay}"
                                        VerticalAlignment="Center" />
                                </ToggleButton>

                                <!--  Negative Toggle  -->
                                <ToggleButton
                                    Background="Transparent"
                                    Classes="altHover"
                                    x:Name="NegativeToggleButton">
                                    <TextBlock
                                        Classes="txt"
                                        Foreground="{StaticResource SecondaryTextColor}"
                                        HorizontalAlignment="Left"
                                        Text="{CompiledBinding Translation.NegativeColors.Value,
                                                               Mode=OneWay}"
                                        VerticalAlignment="Center" />
                                </ToggleButton>

                                <!--  Old Movie  -->
                                <ToggleButton
                                    Background="Transparent"
                                    Classes="altHover"
                                    x:Name="OldMovieToggleButton">
                                    <TextBlock
                                        Classes="txt"
                                        Foreground="{StaticResource SecondaryTextColor}"
                                        HorizontalAlignment="Left"
                                        Text="{CompiledBinding Translation.OldMovie.Value,
                                                               Mode=OneWay}"
                                        VerticalAlignment="Center" />
                                </ToggleButton>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!--  PRESETS TAB  -->
                    <TabItem Header="{Binding Translation.Presets.Value}" Margin="0">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="15,10">
                                <TextBlock Classes="txt sectionHeader" Text="{Binding Translation.SmartPresets.Value}" />

                                <TextBlock
                                    Classes="txt"
                                    Foreground="{StaticResource SecondaryTextColor}"
                                    Margin="0,0,0,10"
                                    Text="{Binding Translation.PresetDescription.Value}" />

                                <StackPanel Orientation="Horizontal">
                                    <ComboBox
                                        Classes="CStyle"
                                        Foreground="{StaticResource SecondaryTextColor}"
                                        Width="340"
                                        x:Name="PresetCombo" />
                                    <Button
                                        Classes="BorderStyle altHover"
                                        Margin="10,0,0,0"
                                        Width="120"
                                        x:Name="ApplyPresetBtn">
                                        <TextBlock
                                            Classes="txt"
                                            Foreground="{DynamicResource MainTextColor}"
                                            HorizontalAlignment="Center"
                                            Text="{Binding Translation.Apply.Value}" />
                                    </Button>
                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        ToolTip.Tip="{Binding Translation.ResetPreset.Value}"
                                        Width="30"
                                        x:Name="ResetAllBtn" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </DockPanel>
        </Border>
    </Panel>
</UserControl>