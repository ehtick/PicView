                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetBrightnessBtn" />
                                </StackPanel>

                                <!--  Contrast  -->
