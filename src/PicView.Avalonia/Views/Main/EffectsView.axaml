<UserControl
    x:Class="PicView.Avalonia.Views.Main.EffectsView"
    x:DataType="viewModels:CoreViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:uc="clr-namespace:PicView.Avalonia.Views.UC"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Styles>
        <Styles>
            <Style Selector="NumericUpDown">
                <Setter Property="Width" Value="64" />
                <Setter Property="FormatString" Value="N0" />
                <Setter Property="Foreground" Value="{DynamicResource MainTextColor}" />
            </Style>

            <Style Selector="TextBlock.sectionHeader">
                <Setter Property="FontFamily" Value="/Assets/Fonts/Roboto-Bold.ttf#Roboto" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Foreground" Value="{StaticResource MainTextColor}" />
                <Setter Property="Margin" Value="0,12,0,8" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <Style Selector="TextBlock.fieldLabel">
                <Setter Property="Foreground" Value="{StaticResource SecondaryTextColor}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style Selector="TabControl">
                <Setter Property="Margin" Value="10,10,10,0" />
            </Style>
        </Styles>


        <Style Selector="TabControl">
            <Setter Property="ItemsPanel">
                <ItemsPanelTemplate>
                    <UniformGrid Columns="{Binding $parent[TabControl].Items.Count}" />
                </ItemsPanelTemplate>
            </Setter>
        </Style>

        <Style Selector="TabControl TabItem">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="CornerRadius" Value="2,2,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}" />
        </Style>


        <!--  Small reset button style (per-tab reset)  -->
        <Style Selector="Button.tabResetBtn">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource MainButtonBackgroundColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource MainBorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>


    </UserControl.Styles>
    <UserControl.ContextMenu>
        <ContextMenu x:Name="EffectsContextMenu">
            <MenuItem Command="{Binding MainWindows.ActiveWindow.Value.SaveCommand}" Header="{CompiledBinding Translation.Save.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path
                        Data="{StaticResource SaveGeometry}"
                        Fill="{DynamicResource MainTextColor}"
                        Height="12"
                        Stretch="Fill"
                        Width="12" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Command="{Binding MainWindows.ActiveWindow.Value.SaveAsCommand}" Header="{CompiledBinding Translation.SaveAs.Value}">
                <MenuItem.Icon>
                    <Path
                        Data="{StaticResource SaveGeometry}"
                        Fill="{DynamicResource MainTextColor}"
                        Height="12"
                        Stretch="Fill"
                        Width="12" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Command="{Binding MainWindows.ActiveWindow.Value.CopyImageCommand}" Header="{CompiledBinding Translation.CopyImage.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path
                        Data="{StaticResource CopyGeometry}"
                        Fill="{DynamicResource MainTextColor}"
                        Height="12"
                        Stretch="Fill"
                        Width="12" />
                </MenuItem.Icon>
            </MenuItem>
            <Separator />
            <MenuItem
                Command="{Binding MainWindows.ActiveWindow.Value.SetAsWallpaperCommand}"
                Header="{CompiledBinding Translation.SetAsWallpaper.Value,
                                         Mode=OneWay}"
                IsVisible="{CompiledBinding GlobalSettings.ShowSetAsWallpaper.Value}">
                <MenuItem.Icon>
                    <Path
                        Data="{StaticResource PanoramaGeometry}"
                        Fill="{DynamicResource MainTextColor}"
                        Height="10.40"
                        Stretch="Fill"
                        Width="13" />
                </MenuItem.Icon>
            </MenuItem>
            <Separator IsVisible="{CompiledBinding GlobalSettings.ShowSetAsWallpaper.Value}" />
            <MenuItem Header="{CompiledBinding Translation.ClearEffects.Value, Mode=OneWay}" x:Name="ClearEffectsItem">
                <MenuItem.Icon>
                    <Image
                        Height="12"
                        Source="{StaticResource ClearImage}"
                        Width="12" />
                </MenuItem.Icon>
            </MenuItem>
            <Separator />
            <MenuItem Header="{CompiledBinding Translation.Close.Value, Mode=OneWay}" x:Name="CloseItem">
                <MenuItem.Icon>
                    <Path
                        Data="{StaticResource CloseGeometry}"
                        Fill="{DynamicResource MainTextColor}"
                        Height="12"
                        Stretch="Fill"
                        Width="12" />
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </UserControl.ContextMenu>

    <UserControl.Resources>
        <SolidColorBrush Color="{DynamicResource MainTextColor}" x:Key="CancelBrush" />

        <LinearGradientBrush EndPoint="100%,50%" StartPoint="0%,50%" x:Key="CB_CyanRed">
            <GradientStop Color="#4FC3F7" Offset="0" />
            <GradientStop Color="#E0E0E0" Offset="0.5" />
            <GradientStop Color="#E57373" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush EndPoint="100%,50%" StartPoint="0%,50%" x:Key="CB_MagentaGreen">
            <GradientStop Color="#CE93D8" Offset="0" />
            <GradientStop Color="#E0E0E0" Offset="0.5" />
            <GradientStop Color="#81C784" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush EndPoint="100%,50%" StartPoint="0%,50%" x:Key="CB_YellowBlue">
            <GradientStop Color="#FFF176" Offset="0" />
            <GradientStop Color="#E0E0E0" Offset="0.5" />
            <GradientStop Color="#64B5F6" Offset="1" />
        </LinearGradientBrush>

    </UserControl.Resources>

    <Panel>
        <uc:SpinWaiter
            HorizontalAlignment="Center"
            IsVisible="{CompiledBinding MainWindows.ActiveWindow.Value.IsLoadingIndicatorShown.Value,
                                        Mode=OneWay}"
            VerticalAlignment="Center"
            x:Name="SpinWaiter" />

        <Border
            Background="{DynamicResource MainBackgroundColor}"
            Width="550"
            x:Name="ParentContainer">
            <DockPanel>

                <!--  Footer (always visible)  -->
                <StackPanel
                    Background="{DynamicResource TertiaryBackgroundColor}"
                    DockPanel.Dock="Bottom"
                    Height="80"
                    Orientation="Horizontal"
                    PointerPressed="MoveWindow"
                    x:Name="LowerPanel">

                    <Button
                        Classes="BorderStyle altHover mainBtn"
                        CornerRadius="4"
                        IsVisible="False"
                        Margin="30,0,60,0"
                        Width="195"
                        x:Name="ResetButton">
                        <TextBlock
                            Classes="txt"
                            Foreground="{StaticResource CancelBrush}"
                            Text="{CompiledBinding Translation.ClearEffects.Value,
                                                   Mode=OneWay}"
                            TextAlignment="Center" />
                    </Button>

                    <Button
                        Classes="BorderStyle altHover mainBtn"
                        CornerRadius="4"
                        Margin="30,0,60,0"
                        Width="195"
                        x:Name="CancelButton">
                        <TextBlock
                            Classes="txt"
                            Foreground="{StaticResource CancelBrush}"
                            Text="{CompiledBinding Translation.Cancel.Value,
                                                   Mode=OneWay}"
                            TextAlignment="Center" />
                    </Button>


                    <SplitButton
                        Background="{DynamicResource AccentColor}"
                        Classes="BorderStyle accentHover mainBtn"
                        Command="{Binding MainWindows.ActiveWindow.Value.SaveCommand}"
                        CornerRadius="4"
                        Width="195"
                        x:Name="SaveButton">
                        <TextBlock
                            Classes="txt"
                            Foreground="{StaticResource SecondaryTextColor}"
                            Text="{CompiledBinding Translation.Save.Value,
                                                   Mode=OneWay}"
                            TextAlignment="Center" />
                        <SplitButton.Flyout>
                            <MenuFlyout FlyoutPresenterClasses="noCornerRadius" Placement="Bottom">
                                <MenuItem
                                    Command="{Binding MainWindows.ActiveWindow.Value.SaveAsCommand}"
                                    Header="{CompiledBinding Translation.SaveAs.Value,
                                                             Mode=OneWay}"
                                    HorizontalAlignment="Center"
                                    Width="195" />
                            </MenuFlyout>
                        </SplitButton.Flyout>
                    </SplitButton>
                </StackPanel>

                <!--  Tabs  -->
                <TabControl x:Name="EffectsTabs">

                    <!--  COLOR TAB  -->
                    <TabItem Header="{Binding Translation.Color.Value}" Margin="0">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="15,10">

                                <DockPanel LastChildFill="True" Margin="0,0,-10,0">
                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        DockPanel.Dock="Right"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Height="30"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        ToolTip.Tip="Reset Color"
                                        Width="30"
                                        x:Name="ResetColorTabBtn" />

                                    <TextBlock
                                        Classes="txt sectionHeader"
                                        DockPanel.Dock="Left"
                                        Text="{Binding Translation.Color.Value}" />
                                </DockPanel>

                                <!--  Hue  -->
                                <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Hue.Value}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        IsSnapToTickEnabled="False"
                                        LargeChange="10"
                                        Margin="0,1,10,1"
                                        Maximum="180"
                                        Minimum="-180"
                                        SmallChange="1"
                                        Theme="{StaticResource SetBg}"
                                        TickFrequency="1"
                                        Value="0"
                                        Width="400"
                                        x:Name="HueSlider">
                                        <customControls:CustomSlider.Background>
                                            <LinearGradientBrush EndPoint="100%,50%" StartPoint="0%,50%">
                                                <GradientStop Color="#FF0000" Offset="0" />
                                                <GradientStop Color="#FFFF00" Offset="0.17" />
                                                <GradientStop Color="#00FF00" Offset="0.33" />
                                                <GradientStop Color="#00FFFF" Offset="0.5" />
                                                <GradientStop Color="#0000FF" Offset="0.67" />
                                                <GradientStop Color="#FF00FF" Offset="0.83" />
                                                <GradientStop Color="#FF0000" Offset="1" />
                                            </LinearGradientBrush>
                                        </customControls:CustomSlider.Background>
                                    </customControls:CustomSlider>

                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=HueSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=HueSlider}"
                                        Value="{Binding Path=Value, ElementName=HueSlider}" />

                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetHueBtn" />
                                </StackPanel>

                                <!--  Saturation  -->
                                <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Saturation.Value, Mode=OneWay}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        IsSnapToTickEnabled="False"
                                        LargeChange="10"
                                        Margin="0,1,10,1"
                                        Maximum="100"
                                        Minimum="-100"
                                        SmallChange="1"
                                        Theme="{StaticResource SetBg}"
                                        TickFrequency="1"
                                        Value="0"
                                        Width="400"
                                        x:Name="SaturationSlider">
                                        <customControls:CustomSlider.Background>
                                            <LinearGradientBrush EndPoint="100%,50%" StartPoint="0%,50%">
                                                <GradientStop Color="#808080" Offset="0" />
                                                <GradientStop Color="#D0D0D0" Offset="0.6" />
                                                <GradientStop Color="#F0F0F0" Offset="1" />
                                            </LinearGradientBrush>
                                        </customControls:CustomSlider.Background>
                                    </customControls:CustomSlider>

                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=SaturationSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=SaturationSlider}"
                                        Value="{Binding Path=Value, ElementName=SaturationSlider}" />

                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetSaturationBtn" />
                                </StackPanel>

                                <!--  Temperature  -->
                                <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Temperature.Value}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        IsSnapToTickEnabled="False"
                                        LargeChange="10"
                                        Margin="0,1,10,1"
                                        Maximum="100"
                                        Minimum="-100"
                                        SmallChange="1"
                                        Theme="{StaticResource SetBg}"
                                        TickFrequency="1"
                                        Value="0"
                                        Width="400"
                                        x:Name="TemperatureSlider">
                                        <customControls:CustomSlider.Background>
                                            <LinearGradientBrush EndPoint="100%,50%" StartPoint="0%,50%">
                                                <GradientStop Color="#4D8CC9" Offset="0" />
                                                <GradientStop Color="#FFFFFF" Offset="0.5" />
                                                <GradientStop Color="#FFB36B" Offset="1" />
                                            </LinearGradientBrush>
                                        </customControls:CustomSlider.Background>
                                    </customControls:CustomSlider>

                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=TemperatureSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=TemperatureSlider}"
                                        Value="{Binding Path=Value, ElementName=TemperatureSlider}" />

                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetTemperatureBtn" />
                                </StackPanel>

                                <!--  Tint  -->
                                <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Tint.Value}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        IsSnapToTickEnabled="False"
                                        LargeChange="10"
                                        Margin="0,1,10,1"
                                        Maximum="100"
                                        Minimum="-100"
                                        SmallChange="1"
                                        Theme="{StaticResource SetBg}"
                                        TickFrequency="1"
                                        Value="0"
                                        Width="400"
                                        x:Name="TintSlider">
                                        <customControls:CustomSlider.Background>
                                            <LinearGradientBrush EndPoint="100%,50%" StartPoint="0%,50%">
                                                <GradientStop Color="#55FF55" Offset="0" />
                                                <GradientStop Color="#FFFFFF" Offset="0.5" />
                                                <GradientStop Color="#FF66CC" Offset="1" />
                                            </LinearGradientBrush>
                                        </customControls:CustomSlider.Background>
                                    </customControls:CustomSlider>

                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=TintSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=TintSlider}"
                                        Value="{Binding Path=Value, ElementName=TintSlider}" />

                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetTintBtn" />
                                </StackPanel>

                                <!--  Vibrance  -->
                                <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Tint.Value}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        IsSnapToTickEnabled="False"
                                        LargeChange="10"
                                        Margin="0,1,10,1"
                                        Maximum="100"
                                        Minimum="-100"
                                        SmallChange="1"
                                        Theme="{StaticResource SetBg}"
                                        TickFrequency="1"
                                        Value="0"
                                        Width="400"
                                        x:Name="VibranceSlider">
                                        <customControls:CustomSlider.Background>
                                            <LinearGradientBrush EndPoint="100%,50%" StartPoint="0%,50%">
                                                <GradientStop Color="#909090" Offset="0" />
                                                <GradientStop Color="#D8D8D8" Offset="0.7" />
                                                <GradientStop Color="#F2F2F2" Offset="1" />
                                            </LinearGradientBrush>
                                        </customControls:CustomSlider.Background>
                                    </customControls:CustomSlider>

                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=VibranceSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=VibranceSlider}"
                                        Value="{Binding Path=Value, ElementName=VibranceSlider}" />

                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetVibranceBtn" />
                                </StackPanel>

                                <Border
                                    Background="{DynamicResource MainBorderColor}"
                                    Height="1"
                                    Margin="0,10,0,0" />

                                <!--  Color Balance  -->
                                <TextBlock Classes="txt sectionHeader" Text="{Binding Translation.ColorBalance.Value, Mode=OneWay}" />

                                <TabControl Margin="0,6,0,0" x:Name="ColorBalanceTabs">

                                    <TabItem Header="{Binding Translation.Shadows.Value}" Margin="0">
                                        <StackPanel Margin="0,8,0,0">

                                            <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Red.Value}" />
                                            <StackPanel Orientation="Horizontal">
                                                <customControls:CustomSlider
                                                    Background="{StaticResource CB_CyanRed}"
                                                    Height="30"
                                                    Maximum="100"
                                                    Minimum="-100"
                                                    Theme="{StaticResource SetBg}"
                                                    Value="0"
                                                    Width="400"
                                                    x:Name="CBShadowsCR" />
                                                <NumericUpDown
                                                    Maximum="{Binding Path=Maximum, ElementName=CBShadowsCR}"
                                                    Minimum="{Binding Path=Minimum, ElementName=CBShadowsCR}"
                                                    Value="{Binding Path=Value, ElementName=CBShadowsCR}" />
                                            </StackPanel>

                                            <TextBlock
                                                Classes="txt fieldLabel"
                                                Margin="0,8,0,0"
                                                Text="{Binding Translation.Green.Value}" />
                                            <StackPanel Orientation="Horizontal">
                                                <customControls:CustomSlider
                                                    Background="{StaticResource CB_MagentaGreen}"
                                                    Height="30"
                                                    Maximum="100"
                                                    Minimum="-100"
                                                    Theme="{StaticResource SetBg}"
                                                    Value="0"
                                                    Width="400"
                                                    x:Name="CBShadowsMG" />

                                                <NumericUpDown
                                                    Maximum="{Binding Path=Maximum, ElementName=CBShadowsMG}"
                                                    Minimum="{Binding Path=Minimum, ElementName=CBShadowsMG}"
                                                    Value="{Binding Path=Value, ElementName=CBShadowsMG}" />
                                            </StackPanel>

                                            <TextBlock
                                                Classes="txt fieldLabel"
                                                Margin="0,8,0,0"
                                                Text="{Binding Translation.Blue.Value}" />
                                            <StackPanel Orientation="Horizontal">
                                                <customControls:CustomSlider
                                                    Background="{StaticResource CB_YellowBlue}"
                                                    Height="30"
                                                    Maximum="100"
                                                    Minimum="-100"
                                                    Theme="{StaticResource SetBg}"
                                                    Value="0"
                                                    Width="400"
                                                    x:Name="CBShadowsYB" />
                                                <NumericUpDown
                                                    Maximum="{Binding Path=Maximum, ElementName=CBShadowsYB}"
                                                    Minimum="{Binding Path=Minimum, ElementName=CBShadowsYB}"
                                                    Value="{Binding Path=Value, ElementName=CBShadowsYB}" />
                                            </StackPanel>

                                        </StackPanel>
                                    </TabItem>

                                    <TabItem Header="{Binding Translation.Midtones.Value}" Margin="0">
                                        <StackPanel Margin="0,8,0,0">

                                            <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Red.Value}" />
                                            <StackPanel Orientation="Horizontal">
                                                <customControls:CustomSlider
                                                    Background="{StaticResource CB_CyanRed}"
                                                    Height="30"
                                                    Maximum="100"
                                                    Minimum="-100"
                                                    Theme="{StaticResource SetBg}"
                                                    Value="0"
                                                    Width="400"
                                                    x:Name="CBMidCR" />
                                                <NumericUpDown
                                                    Maximum="{Binding Path=Maximum, ElementName=CBMidCR}"
                                                    Minimum="{Binding Path=Minimum, ElementName=CBMidCR}"
                                                    Value="{Binding Path=Value, ElementName=CBMidCR}" />
                                            </StackPanel>

                                            <TextBlock
                                                Classes="txt fieldLabel"
                                                Margin="0,8,0,0"
                                                Text="{Binding Translation.Green.Value}" />
                                            <StackPanel Orientation="Horizontal">
                                                <customControls:CustomSlider
                                                    Background="{StaticResource CB_MagentaGreen}"
                                                    Height="30"
                                                    Maximum="100"
                                                    Minimum="-100"
                                                    Theme="{StaticResource SetBg}"
                                                    Value="0"
                                                    Width="400"
                                                    x:Name="CBMidMG" />
                                                <NumericUpDown
                                                    Maximum="{Binding Path=Maximum, ElementName=CBMidMG}"
                                                    Minimum="{Binding Path=Minimum, ElementName=CBMidMG}"
                                                    Value="{Binding Path=Value, ElementName=CBMidMG}" />
                                            </StackPanel>

                                            <TextBlock
                                                Classes="txt fieldLabel"
                                                Margin="0,8,0,0"
                                                Text="{Binding Translation.Blue.Value}" />
                                            <StackPanel Orientation="Horizontal">
                                                <customControls:CustomSlider
                                                    Background="{StaticResource CB_YellowBlue}"
                                                    Height="30"
                                                    Maximum="100"
                                                    Minimum="-100"
                                                    Theme="{StaticResource SetBg}"
                                                    Value="0"
                                                    Width="400"
                                                    x:Name="CBMidYB" />
                                                <NumericUpDown
                                                    Maximum="{Binding Path=Maximum, ElementName=CBMidYB}"
                                                    Minimum="{Binding Path=Minimum, ElementName=CBMidYB}"
                                                    Value="{Binding Path=Value, ElementName=CBMidYB}" />
                                            </StackPanel>

                                        </StackPanel>
                                    </TabItem>

                                    <TabItem Header="{Binding Translation.Highlights.Value}" Margin="0">
                                        <StackPanel Margin="0,8,0,0">

                                            <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Red.Value}" />
                                            <StackPanel Orientation="Horizontal">
                                                <customControls:CustomSlider
                                                    Background="{StaticResource CB_CyanRed}"
                                                    Height="30"
                                                    Maximum="100"
                                                    Minimum="-100"
                                                    Theme="{StaticResource SetBg}"
                                                    Value="0"
                                                    Width="400"
                                                    x:Name="CBHighCR" />
                                                <NumericUpDown
                                                    Maximum="{Binding Path=Maximum, ElementName=CBHighCR}"
                                                    Minimum="{Binding Path=Minimum, ElementName=CBHighCR}"
                                                    Value="{Binding Path=Value, ElementName=CBHighCR}" />
                                            </StackPanel>

                                            <TextBlock
                                                Classes="txt fieldLabel"
                                                Margin="0,8,0,0"
                                                Text="{Binding Translation.Green.Value}" />
                                            <StackPanel Orientation="Horizontal">
                                                <customControls:CustomSlider
                                                    Background="{StaticResource CB_MagentaGreen}"
                                                    Height="30"
                                                    Maximum="100"
                                                    Minimum="-100"
                                                    Theme="{StaticResource SetBg}"
                                                    Value="0"
                                                    Width="400"
                                                    x:Name="CBHighMG" />
                                                <NumericUpDown
                                                    Maximum="{Binding Path=Maximum, ElementName=CBHighMG}"
                                                    Minimum="{Binding Path=Minimum, ElementName=CBHighMG}"
                                                    Value="{Binding Path=Value, ElementName=CBHighMG}" />
                                            </StackPanel>

                                            <TextBlock
                                                Classes="txt fieldLabel"
                                                Margin="0,8,0,0"
                                                Text="{Binding Translation.Blue.Value}" />
                                            <StackPanel Orientation="Horizontal">
                                                <customControls:CustomSlider
                                                    Background="{StaticResource CB_YellowBlue}"
                                                    Height="30"
                                                    Maximum="100"
                                                    Minimum="-100"
                                                    Theme="{StaticResource SetBg}"
                                                    Value="0"
                                                    Width="400"
                                                    x:Name="CBHighYB" />
                                                <NumericUpDown
                                                    Maximum="{Binding Path=Maximum, ElementName=CBHighYB}"
                                                    Minimum="{Binding Path=Minimum, ElementName=CBHighYB}"
                                                    Value="{Binding Path=Value, ElementName=CBHighYB}" />
                                            </StackPanel>

                                        </StackPanel>
                                    </TabItem>

                                </TabControl>


                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!--  LIGHTING TAB  -->
                    <TabItem Header="{Binding Translation.Lighting.Value}" Margin="0">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="15,10">

                                <DockPanel LastChildFill="True" Margin="0,0,-10,0">
                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        DockPanel.Dock="Right"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Height="30"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        ToolTip.Tip="Reset Lighting"
                                        Width="30"
                                        x:Name="ResetLightingTabBtn" />

                                    <TextBlock
                                        Classes="txt sectionHeader"
                                        DockPanel.Dock="Left"
                                        Text="{CompiledBinding Translation.Lighting.Value,
                                                               Mode=OneWay}" />
                                </DockPanel>

                                <!--  Exposure  -->
                                <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.ExposureBias.Value}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        IsSnapToTickEnabled="False"
                                        LargeChange="0.25"
                                        Margin="0,1,10,1"
                                        Maximum="2"
                                        Minimum="-2"
                                        SmallChange="0.05"
                                        Theme="{StaticResource SetBg}"
                                        TickFrequency="0.05"
                                        Value="0"
                                        Width="400"
                                        x:Name="ExposureSlider">
                                        <customControls:CustomSlider.Background>
                                            <LinearGradientBrush EndPoint="100%,50%" StartPoint="0%,50%">
                                                <GradientStop Color="#101010" Offset="0" />
                                                <GradientStop Color="#808080" Offset="0.5" />
                                                <GradientStop Color="#FFFFFF" Offset="1" />
                                            </LinearGradientBrush>
                                        </customControls:CustomSlider.Background>
                                    </customControls:CustomSlider>

                                    <NumericUpDown
                                        Increment="0.05"
                                        Maximum="{Binding Path=Maximum, ElementName=ExposureSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=ExposureSlider}"
                                        Value="{Binding Path=Value, ElementName=ExposureSlider}" />

                                    <customControls:IconButton
                                        Background="{DynamicResource MainButtonBackgroundColor}"
                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetExposureBtn" />
                                </StackPanel>

                                <!--  Brightness  -->
                                <TextBlock Classes="txt fieldLabel" Text="{CompiledBinding Translation.Brightness.Value, Mode=OneWay}" />
                                <StackPanel Orientation="Horizontal">
                                    <customControls:CustomSlider
                                        Height="30"
                                        IsSnapToTickEnabled="False"
                                        LargeChange="10"
                                        Margin="0,1,10,1"
                                        Maximum="100"
                                        Minimum="-100"
                                        SmallChange="1"
                                        Theme="{StaticResource SetBg}"
                                        TickFrequency="1"
                                        Value="0"
                                        Width="400"
                                        x:Name="BrightnessSlider">
                                        <customControls:CustomSlider.Background>
                                            <LinearGradientBrush EndPoint="100%,50%" StartPoint="0%,50%">
                                                <GradientStop Color="#111111" Offset="0" />
                                                <GradientStop Color="#FFFFFF" Offset="1" />
                                            </LinearGradientBrush>
                                        </customControls:CustomSlider.Background>
                                    </customControls:CustomSlider>

                                    <NumericUpDown
                                        Maximum="{Binding Path=Maximum, ElementName=BrightnessSlider}"
                                        Minimum="{Binding Path=Minimum, ElementName=BrightnessSlider}"
                                        Value="{Binding Path=Value, ElementName=BrightnessSlider}" />

