                                        BorderBrush="{DynamicResource MainBorderColor}"
                                        BorderThickness="1"
                                        Classes="hover"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Icon="{StaticResource UndoImage}"
                                        IconHeight="12"
                                        IconWidth="12"
                                        Margin="5,0,0,0"
                                        Width="30"
                                        x:Name="ResetContrastBtn" />
                                </StackPanel>

                                <!--  Gamma  -->
                                <TextBlock Classes="txt fieldLabel" Text="{Binding Translation.Gamma.Value}" />
