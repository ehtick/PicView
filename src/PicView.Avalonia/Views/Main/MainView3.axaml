<UserControl
    x:Class="PicView.Avalonia.Views.Main.MainView3"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:buttons="clr-namespace:PicView.Avalonia.Views.UC.Buttons"
    xmlns:converters="clr-namespace:PicView.Avalonia.Converters"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:uc="clr-namespace:PicView.Avalonia.Views.UC"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    x:DataType="viewModels:MainWindowViewModel"
    Background="Transparent"
    DragDrop.AllowDrop="True"
    Focusable="True">
    <UserControl.Resources>
        <converters:SortFilesByToBoolConverter x:Key="EnumToBoolConverter" />
        <SolidColorBrush x:Key="Brush0" Color="{DynamicResource MainTextColor}" />

        <ContextMenu x:Key="MainContextMenu">

            <!--  Open  -->
            <MenuItem
                MinWidth="180"
                Command="{CompiledBinding OpenCommand}"
                Header="{CompiledBinding Translation.Open.Value,
                                         Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="OpenPath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Save  -->
            <MenuItem
                Command="{CompiledBinding SaveCommand}"
                Header="{CompiledBinding Translation.Save.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Path Classes="SavePath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Save as  -->
            <MenuItem
                Command="{CompiledBinding SaveAsCommand}"
                Header="{CompiledBinding Translation.SaveAs.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull}}">
                <MenuItem.Icon>
                    <Path Classes="SavePath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Print  -->
            <MenuItem
                x:Name="PrintMenuItem"
                Command="{CompiledBinding PrintCommand}"
                Header="{CompiledBinding Translation.Print.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="PrintPath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Open with  -->
            <MenuItem
                x:Name="OpenWithMenuItem"
                Command="{CompiledBinding OpenWithCommand}"
                Header="{CompiledBinding Translation.OpenWith.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Image Width="12" Height="12">
                        <Image.Source>
                            <DrawingImage>
                                <DrawingGroup>
                                    <GeometryDrawing Geometry="F1 M12 6L6 6Q5.90175 6 5.80397 6.00963Q5.70618 6.01926 5.60982 6.03843Q5.51345 6.0576 5.41943 6.08612Q5.32541 6.11464 5.23463 6.15224Q5.14386 6.18984 5.05721 6.23616Q4.97055 6.28247 4.88886 6.33706Q4.80716 6.39165 4.73121 6.45398Q4.65526 6.51631 4.58579 6.58579Q4.51631 6.65526 4.45398 6.73121Q4.39165 6.80717 4.33706 6.88886Q4.28247 6.97056 4.23616 7.05721Q4.18984 7.14386 4.15224 7.23463Q4.11464 7.32541 4.08612 7.41943Q4.0576 7.51345 4.03843 7.60982Q4.01926 7.70619 4.00963 7.80397Q4 7.90175 4 8L4 18Q4 18.0983 4.00963 18.196Q4.01926 18.2938 4.03843 18.3902Q4.0576 18.4865 4.08612 18.5806Q4.11464 18.6746 4.15224 18.7654Q4.18984 18.8561 4.23616 18.9428Q4.28247 19.0294 4.33706 19.1111Q4.39165 19.1928 4.45398 19.2688Q4.51631 19.3447 4.58579 19.4142Q4.65526 19.4837 4.73121 19.546Q4.80716 19.6083 4.88886 19.6629Q4.97055 19.7175 5.05721 19.7638Q5.14386 19.8102 5.23463 19.8478Q5.32541 19.8854 5.41943 19.9139Q5.51345 19.9424 5.60982 19.9616Q5.70618 19.9807 5.80397 19.9904Q5.90175 20 6 20L16 20Q16.0983 20 16.196 19.9904Q16.2938 19.9807 16.3902 19.9616Q16.4865 19.9424 16.5806 19.9139Q16.6746 19.8854 16.7654 19.8478Q16.8561 19.8102 16.9428 19.7638Q17.0294 19.7175 17.1111 19.6629Q17.1928 19.6084 17.2688 19.546Q17.3447 19.4837 17.4142 19.4142Q17.4837 19.3447 17.546 19.2688Q17.6084 19.1928 17.6629 19.1111Q17.7175 19.0294 17.7638 18.9428Q17.8102 18.8561 17.8478 18.7654Q17.8854 18.6746 17.9139 18.5806Q17.9424 18.4865 17.9616 18.3902Q17.9807 18.2938 17.9904 18.196Q18 18.0983 18 18L18 12">
                                        <GeometryDrawing.Pen>
                                            <Pen
                                                Brush="{DynamicResource MainTextColor}"
                                                LineCap="Round"
                                                LineJoin="Round"
                                                MiterLimit="4"
                                                Thickness="2" />
                                        </GeometryDrawing.Pen>
                                    </GeometryDrawing>
                                    <GeometryDrawing Geometry="F1 M11 13L20 4">
                                        <GeometryDrawing.Pen>
                                            <Pen
                                                Brush="{DynamicResource MainTextColor}"
                                                LineCap="Round"
                                                LineJoin="Round"
                                                MiterLimit="4"
                                                Thickness="2" />
                                        </GeometryDrawing.Pen>
                                    </GeometryDrawing>
                                    <GeometryDrawing Geometry="F1 M15 4L20 4L20 9">
                                        <GeometryDrawing.Pen>
                                            <Pen
                                                Brush="{DynamicResource MainTextColor}"
                                                LineCap="Round"
                                                LineJoin="Round"
                                                MiterLimit="4"
                                                Thickness="2" />
                                        </GeometryDrawing.Pen>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingImage>
                        </Image.Source>
                    </Image>
                </MenuItem.Icon>
            </MenuItem>

            <!--  Locate on disk  -->
            <MenuItem
                Command="{CompiledBinding OpenInExplorerCommand}"
                Header="{CompiledBinding Translation.ShowInFolder.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Path Classes="ShowInFolderPath" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Sort files by  -->
            <MenuItem Header="{CompiledBinding Translation.SortFilesBy.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="SortFilesPath" />
                </MenuItem.Icon>

                <!--  Sort files by name  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesByNameCommand}"
                    GroupName="SortType"
                    Header="{CompiledBinding Translation.FileName.Value,
                                             Mode=OneWay}"
                    IsChecked="{CompiledBinding WindowTabs.SortOrder.Value,
                                                Converter={StaticResource EnumToBoolConverter},
                                                ConverterParameter=Name}"
                    ToggleType="Radio" />

                <!--  Sort files by size  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesBySizeCommand}"
                    GroupName="SortType"
                    Header="{CompiledBinding Translation.FileSize.Value,
                                             Mode=OneWay}"
                    IsChecked="{CompiledBinding WindowTabs.SortOrder.Value,
                                                Converter={StaticResource EnumToBoolConverter},
                                                ConverterParameter=FileSize}"
                    ToggleType="Radio" />

                <!--  Sort files by extension  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesByExtensionCommand}"
                    GroupName="SortType"
                    Header="{CompiledBinding Translation.FileExtension.Value,
                                             Mode=OneWay}"
                    IsChecked="{CompiledBinding WindowTabs.SortOrder.Value,
                                                Converter={StaticResource EnumToBoolConverter},
                                                ConverterParameter=Extension}"
                    ToggleType="Radio" />

                <!--  Sort files by creation time  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesByCreationTimeCommand}"
                    GroupName="SortType"
                    Header="{CompiledBinding Translation.Created.Value,
                                             Mode=OneWay}"
                    IsChecked="{CompiledBinding WindowTabs.SortOrder.Value,
                                                Converter={StaticResource EnumToBoolConverter},
                                                ConverterParameter=CreationTime}"
                    ToggleType="Radio" />

                <!--  Sort files by last access time  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesByLastAccessTimeCommand}"
                    GroupName="SortType"
                    Header="{CompiledBinding Translation.LastAccessTime.Value,
                                             Mode=OneWay}"
                    IsChecked="{CompiledBinding WindowTabs.SortOrder.Value,
                                                Converter={StaticResource EnumToBoolConverter},
                                                ConverterParameter=LastAccessTime}"
                    ToggleType="Radio" />

                <!--  Sort files randomly  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesRandomlyCommand}"
                    GroupName="SortType"
                    Header="{CompiledBinding Translation.Random.Value,
                                             Mode=OneWay}"
                    IsChecked="{CompiledBinding WindowTabs.SortOrder.Value,
                                                Converter={StaticResource EnumToBoolConverter},
                                                ConverterParameter=Random}"
                    ToggleType="Radio" />

                <Separator />

                <!--  Sort files ascending  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesAscendingCommand}"
                    GroupName="SortDirection"
                    Header="{CompiledBinding Translation.Ascending.Value,
                                             Mode=OneWay}"
                    IsChecked="{CompiledBinding WindowTabs.IsAscending.Value}"
                    ToggleType="Radio" />

                <!--  Sort files descending  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesDescendingCommand}"
                    GroupName="SortDirection"
                    Header="{CompiledBinding Translation.Descending.Value,
                                             Mode=OneWay}"
                    IsChecked="{CompiledBinding !WindowTabs.IsAscending.Value}"
                    ToggleType="Radio" />
            </MenuItem>


            <!--  Recent files  -->
            <MenuItem Header="{Binding Translation.RecentFiles, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="RecentFilesPath" />
                </MenuItem.Icon>
                <MenuItem x:Name="RecentFilesHeader" Theme="{StaticResource Slim}">
                    <MenuItem.Header>
                        <DockPanel LastChildFill="False">
                            <Button
                                x:Name="HistoryClearButton"
                                Margin="0,0,5,0"
                                Padding="8,4"
                                Classes="errorHover"
                                CornerRadius="8,0,0,0"
                                DockPanel.Dock="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Path
                                        x:Name="HistoryClearPath"
                                        Width="12"
                                        Height="12"
                                        Data="{StaticResource RecycleGeometry}"
                                        Fill="{StaticResource Brush0}"
                                        Stretch="Fill" />
                                    <TextBlock
                                        x:Name="HistoryClearTextBlock"
                                        Margin="5,0,0,0"
                                        Classes="txt"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Text="{CompiledBinding Translation.Clear.Value,
                                                               Mode=OneWay}" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="HistoryFileButton"
                                Margin="0,0,5,0"
                                Padding="8,4"
                                Classes="hover"
                                ClickMode="Release"
                                DockPanel.Dock="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Image
                                        x:Name="HistoryFileButtonPath"
                                        Width="12"
                                        Height="12"
                                        Source="{StaticResource SquareLibrary}"
                                        Stretch="Fill" />
                                    <TextBlock
                                        x:Name="HistoryFileNameTextBlock"
                                        Margin="5,0,0,0"
                                        Classes="txt"
                                        Foreground="{DynamicResource MainTextColor}"
                                        Text="{CompiledBinding Translation.OpenFileHistory.Value,
                                                               Mode=OneWay}" />
                                </StackPanel>
                            </Button>

                            <customControls:IconButton
                                x:Name="HistorySortButton"
                                Margin="5,0,0,0"
                                Padding="8,4"
                                Background="Transparent"
                                Classes="hover"
                                CornerRadius="0,8,0,0"
                                DockPanel.Dock="Right"
                                Foreground="{DynamicResource MainTextColor}"
                                Icon="{StaticResource SortDescImage}"
                                IconHeight="12"
                                IconWidth="12" />

                        </DockPanel>
                    </MenuItem.Header>
                </MenuItem>
                <Separator Background="{DynamicResource TertiaryBorderColor}" />
                <MenuItem
                    x:Name="RecentFilesContent"
                    StaysOpenOnClick="True"
                    Theme="{StaticResource Slim}">
                    <MenuItem.Header>
                        <customControls:AutoScrollViewer MaxHeight="450" Theme="{StaticResource Inline}">
                            <StackPanel x:Name="RecentFilesCM" Margin="0,0,15,0" />
                        </customControls:AutoScrollViewer>
                    </MenuItem.Header>
                </MenuItem>
            </MenuItem>

            <!--  Settings  -->
            <MenuItem Header="{CompiledBinding Translation.Settings.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path
                        Width="12"
                        Height="12"
                        Data="{StaticResource WrenchGeometry}"
                        Fill="{StaticResource Brush0}"
                        Stretch="Fill" />
                </MenuItem.Icon>

                <!--  Toggle Subdirectories  -->
                <MenuItem
                    Command="{CompiledBinding ToggleSubdirectoriesCommand}"
                    Header="{CompiledBinding Translation.SearchSubdirectory.Value,
                                             Mode=OneWay}"
                    ToggleType="CheckBox" />

                <Separator />

                <!--  Toggle looping  -->
                <MenuItem
                    Command="{CompiledBinding ToggleLoopingCommand}"
                    Header="{CompiledBinding Translation.IsLooping.Value,
                                             Mode=OneWay}"
                    ToggleType="CheckBox" />

                <Separator />

                <!--  Toggle scrolling  -->
                <MenuItem
                    Command="{CompiledBinding ToggleScrollCommand}"
                    Header="{CompiledBinding Translation.IsScrolling.Value,
                                             Mode=OneWay}"
                    ToggleType="CheckBox" />

                <!--  Toggle stretching  -->
                <MenuItem
                    Command="{CompiledBinding StretchCommand}"
                    Header="{CompiledBinding Translation.Stretch.Value,
                                             Mode=OneWay}"
                    ToggleType="CheckBox" />

                <!--  Toggle side-by-side  -->
                <MenuItem
                    Command="{CompiledBinding SideBySideCommand}"
                    Header="{CompiledBinding Translation.SideBySide.Value,
                                             Mode=OneWay}"
                    ToggleType="CheckBox" />

                <Separator />

                <!--  Toggle topmost  -->
                <MenuItem
                    Command="{CompiledBinding SetTopMostCommand}"
                    Header="{CompiledBinding Translation.StayTopMost.Value,
                                             Mode=OneWay}"
                    ToggleType="CheckBox" />

                <!--  Toggle auto fit  -->
                <MenuItem
                    Command="{CompiledBinding AutoFitWindowCommand}"
                    Header="{CompiledBinding Translation.AutoFitWindow.Value,
                                             Mode=OneWay}"
                    ToggleType="CheckBox" />

                <Separator />

                <!--  Toggle ctrl zoom  -->
                <MenuItem Command="{CompiledBinding ChangeCtrlZoomCommand}" Header="{CompiledBinding Translation.IsCtrlToZoom.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image Width="12" Height="12" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Toggle UI  -->
                <MenuItem
                    Command="{CompiledBinding ToggleInterfaceCommand}"
                    Header="{CompiledBinding Translation.IsShowingUI.Value,
                                             Mode=OneWay}"
                    IsVisible="{CompiledBinding IsUIShown.Value,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource EyeOffImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    Command="{CompiledBinding ToggleInterfaceCommand}"
                    Header="{CompiledBinding Translation.IsShowingUI.Value,
                                             Mode=OneWay}"
                    IsVisible="{CompiledBinding !IsUIShown.Value,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource EyeImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Change background  -->
                <MenuItem
                    Command="{CompiledBinding ChangeBackgroundCommand}"
                    Header="{CompiledBinding Translation.ChangeBackground.Value,
                                             Mode=OneWay}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource PaletteImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Toggle bottom gallery  -->
                <MenuItem Header="{CompiledBinding Translation.IsShowingDockedGallery.Value, Mode=OneWay}" IsChecked="{CompiledBinding WindowTabs.ActiveTab.Value.Gallery.IsDockedGalleryVisible.Value}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource GalleryImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Toggle bottom bar  -->
                <MenuItem
                    Header="{CompiledBinding Translation.ShowBottomToolbar.Value,
                                             Mode=OneWay}"
                    IsChecked="{CompiledBinding IsBottomToolbarShown.Value}"
                    IsVisible="{CompiledBinding !IsBottomToolbarShown.Value}"
                    ToggleType="CheckBox">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource Panel-Bottom}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Show Settings window  -->
                <MenuItem Command="{CompiledBinding SettingsWindowCommand}" Header="{CompiledBinding Translation.ShowAllSettingsWindow.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path
                            Width="12"
                            Height="12"
                            Data="{StaticResource CogGeometry}"
                            Fill="{StaticResource Brush0}"
                            Stretch="Fill" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <Separator />

            <!--  Navigation  -->
            <MenuItem Header="{CompiledBinding Translation.Navigation.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Image
                        Width="14"
                        Height="14"
                        Source="{StaticResource SignPostImage}" />
                </MenuItem.Icon>

                <!--  Next  -->
                <MenuItem
                    Command="{CompiledBinding NextCommand}"
                    Header="{CompiledBinding Translation.NextImage.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateForwards.Value,
                                                FallbackValue=False}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource NextImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Prev  -->
                <MenuItem
                    Command="{CompiledBinding PrevCommand}"
                    Header="{CompiledBinding Translation.PrevImage.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateBackwards.Value,
                                                FallbackValue=False}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource PrevImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Next 10  -->
                <MenuItem
                    Command="{CompiledBinding Next10Command}"
                    Header="{CompiledBinding Translation.AdvanceBy10Images.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.CanActiveTabNavigate.Value}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource NextImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Next 100  -->
                <MenuItem
                    Command="{CompiledBinding Next100Command}"
                    Header="{CompiledBinding Translation.AdvanceBy100Images.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.CanActiveTabNavigate.Value}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource NextImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Prev 10  -->
                <MenuItem
                    Command="{CompiledBinding Prev10Command}"
                    Header="{CompiledBinding Translation.GoBackBy10Images.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.CanActiveTabNavigate.Value}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource PrevImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Prev 100  -->
                <MenuItem
                    Command="{CompiledBinding Prev100Command}"
                    Header="{CompiledBinding Translation.GoBackBy100Images.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.CanActiveTabNavigate.Value}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource PrevImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  First Image  -->
                <MenuItem
                    Command="{CompiledBinding FirstCommand}"
                    Header="{CompiledBinding Translation.FirstImage.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.CanActiveTabNavigate.Value}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource FirstImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Last Image  -->
                <MenuItem
                    Command="{CompiledBinding LastCommand}"
                    Header="{CompiledBinding Translation.LastImage.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.CanActiveTabNavigate.Value}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource LastImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Next folder  -->
                <MenuItem
                    Command="{CompiledBinding NextFolderCommand}"
                    Header="{CompiledBinding Translation.NextFolder.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="14"
                            Height="14"
                            Source="{StaticResource NextFolderImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Prev folder  -->
                <MenuItem
                    Command="{CompiledBinding PrevFolderCommand}"
                    Header="{CompiledBinding Translation.PrevFolder.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="14"
                            Height="14"
                            Source="{StaticResource PrevFolderImage}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <Separator />

            <!--  Set as wallpaper  -->
            <MenuItem
                Command="{CompiledBinding SetAsWallpaperFittedCommand}"
                CommandParameter="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                   FallbackValue=''}"
                Header="{CompiledBinding Translation.SetAsWallpaper.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Path
                        Width="13"
                        Height="10.40"
                        Data="{StaticResource PanoramaGeometry}"
                        Fill="{StaticResource Brush0}"
                        Stretch="Fill" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Image  -->
            <MenuItem Header="{CompiledBinding Translation.Image.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource Image}" />
                </MenuItem.Icon>

                <!--  Exif window  -->
                <MenuItem Command="{CompiledBinding ImageInfoWindowCommand}" Header="{CompiledBinding Translation.ImageInfo.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path Classes="ImageInfoPath" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  File properties  -->
                <MenuItem
                    Command="{CompiledBinding ShowFilePropertiesCommand}"
                    Header="{CompiledBinding Translation.FileProperties.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource FileUserImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Image effects  -->
                <MenuItem Header="{CompiledBinding Translation.Effects.Value, Mode=OneWay}" ToolTip.Tip="{CompiledBinding Translation.EffectsTooltip.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource FlaskImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Single image resize  -->
                <MenuItem Header="{CompiledBinding Translation.ResizeImage.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource UpscaleImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Batch resize  -->
                <MenuItem Header="{CompiledBinding Translation.BatchResize.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource UpscaleImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Optimize image  -->
                <MenuItem
                    x:Name="OptimizeMenuItem"
                    Header="{CompiledBinding Translation.OptimizeImage.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource PortalImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Crop  -->
                <MenuItem
                    x:Name="CropMenuItem"
                    Header="{CompiledBinding Translation.Crop.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path Classes="CropPath" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Flip  -->
                <MenuItem
                    Header="{CompiledBinding Translation.IsFlipped.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Path Classes="FlipPath">
                            <Path.RenderTransform />
                        </Path>
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Rotate left  -->
                <MenuItem
                    Header="{CompiledBinding Translation.RotateLeft.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Path Classes="RotateLeftPath" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Rotate right  -->
                <MenuItem
                    Header="{CompiledBinding Translation.RotateRight.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Path Classes="RotateRightPath" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <Separator />

            <!--  Delete file  -->
            <MenuItem
                x:Name="DeleteFileMenuItem"
                Command="{CompiledBinding DeleteFileCommand}"
                Header="{CompiledBinding Translation.DeleteFile.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="RecyclePath" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Paste  -->
            <MenuItem Command="{CompiledBinding PasteCommand}" Header="{CompiledBinding Translation.Paste.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="PastePath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Copy  -->
            <MenuItem Header="{CompiledBinding Translation.Copy.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path
                        Width="12"
                        Height="12"
                        Data="{StaticResource CopyGeometry}"
                        Fill="{StaticResource Brush0}"
                        Stretch="Fill" />
                </MenuItem.Icon>

                <!--  Copy image  -->
                <MenuItem Header="{CompiledBinding Translation.CopyImage.Value, Mode=OneWay}" IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path Classes="CopyPath" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Copy file path  -->
                <MenuItem
                    Command="{CompiledBinding CopyFileCommand}"
                    Header="{Binding Translation.FileCopyPath.Value, Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path Classes="CopyPath" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Copy base64  -->
                <MenuItem Command="{CompiledBinding CopyBase64Command}" IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False, Mode=OneWay}">
                    <MenuItem.Header>
                        <TextBlock>
                            <Run Text="{CompiledBinding Translation.Copy.Value, Mode=OneWay}" />
                            <Run Text=" base64" />
                        </TextBlock>
                    </MenuItem.Header>
                    <MenuItem.Icon>
                        <Path Classes="CopyPath" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Duplicate file  -->
                <MenuItem
                    Command="{CompiledBinding DuplicateFileCommand}"
                    Header="{CompiledBinding Translation.DuplicateFile.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path Classes="DuplicatePath" />
                    </MenuItem.Icon>
                </MenuItem>

            </MenuItem>

            <!--  Copy file  -->
            <MenuItem
                Command="{CompiledBinding CopyFileCommand}"
                Header="{CompiledBinding Translation.CopyFile.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="CopyPath" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Fullscreen  -->
            <MenuItem
                Command="{CompiledBinding ToggleFullscreenCommand}"
                Header="{CompiledBinding Translation.Fullscreen.Value,
                                         Mode=OneWay}"
                IsVisible="{CompiledBinding !IsFullscreen.Value,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="FullscreenPath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Maximize  -->
            <MenuItem
                x:Name="MaximizeMenuItem"
                Command="{CompiledBinding MaximizeCommand}"
                Header="{CompiledBinding Translation.Maximize.Value,
                                         Mode=OneWay}"
                IsVisible="{CompiledBinding ShouldMaximizeBeShown.Value,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Image Classes="MaximizeImage" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Restore  -->
            <MenuItem
                Command="{CompiledBinding RestoreCommand}"
                Header="{CompiledBinding Translation.RestoreDown.Value,
                                         Mode=OneWay}"
                IsVisible="{CompiledBinding ShouldRestore.Value,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="RestorePath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Close  -->
            <MenuItem Command="{CompiledBinding ExitCommand}" Header="{CompiledBinding Translation.Close.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path
                        Width="12"
                        Height="12"
                        Data="{StaticResource CloseGeometry}"
                        Fill="{StaticResource Brush0}"
                        Stretch="Fill" />
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </UserControl.Resources>

    <Panel x:Name="MainPanel" ContextMenu="{StaticResource MainContextMenu}">
        <uc:SpinWaiter
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsVisible="{CompiledBinding IsLoadingIndicatorShown.Value,
                                        Mode=OneWay}"
            ZIndex="3" />
        <customControls:DraggableTabControl
            x:Name="MainTabControl"
            Background="{DynamicResource SecondaryBackgroundColor}"
            BorderBrush="{DynamicResource TertiaryBorderColor}"
            BorderThickness="0,0,0,1"
            DataContext="{CompiledBinding WindowTabs}"
            ItemsSource="{CompiledBinding Tabs.Value}"
            SelectedIndex="{CompiledBinding ActiveTabIndex.Value,
                                            Mode=TwoWay}"
            Tag="{CompiledBinding IsTabPanelVisible.Value}">

            <customControls:DraggableTabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="Theme" Value="{StaticResource DraggableTabItem}" />
                </Style>
            </customControls:DraggableTabControl.Styles>

            <customControls:DraggableTabControl.ItemTemplate>
                <DataTemplate>
                    <DockPanel Background="Transparent" LastChildFill="True">
                        <customControls:IconButton
                            Height="32"
                            Padding="9,0"
                            Background="Transparent"
                            Classes="altHover"
                            Command="{CompiledBinding CloseTab}"
                            Data="{StaticResource CloseGeometry}"
                            DockPanel.Dock="Right"
                            Foreground="{DynamicResource MainTextColor}"
                            IconHeight="12"
                            IconWidth="12" />
                        <TextBlock
                            Margin="7,0,0,0"
                            Classes="txt"
                            Text="{CompiledBinding TabTitle.Value,
                                                   Mode=OneWay}"
                            TextWrapping="NoWrap" />
                        <ToolTip.Tip>
                            <DockPanel Width="140" Height="235">
                                <TextBlock
                                    MaxWidth="135"
                                    HorizontalAlignment="Center"
                                    Classes="txt bold"
                                    DockPanel.Dock="Top"
                                    FontSize="12"
                                    Text="{CompiledBinding TabTitle.Value,
                                                           Mode=OneWay}" />
                                <customControls:ThumbImage
                                    HorizontalAlignment="Center"
                                    DockPanel.Dock="Bottom"
                                    Source="{CompiledBinding Image.Value,
                                                             Mode=OneWay,
                                                             TargetNullValue={StaticResource LogoImage}}" />
                            </DockPanel>
                        </ToolTip.Tip>
                    </DockPanel>
                </DataTemplate>
            </customControls:DraggableTabControl.ItemTemplate>

            <customControls:DraggableTabControl.ContentTemplate>
                <DataTemplate DataType="viewModels:TabViewModel">
                    <ContentControl ClipToBounds="True" Content="{CompiledBinding CurrentView.Value, Mode=OneWay}" />
                </DataTemplate>
            </customControls:DraggableTabControl.ContentTemplate>

        </customControls:DraggableTabControl>

        <StackPanel
            x:Name="AltButtonsPanel"
            Height="150"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Background="Transparent"
            IsVisible="{CompiledBinding !IsUIShown.Value}"
            Opacity="0"
            Orientation="Horizontal">
            <buttons:AltMinimize x:Name="AltMinimize" />
            <buttons:AltRestore x:Name="AltRestore" />
            <buttons:AltClose x:Name="AltClose" />
        </StackPanel>
        <uc:ToolTipMessage2
            x:Name="ToolTipMessage"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Opacity="0" />
    </Panel>
</UserControl>