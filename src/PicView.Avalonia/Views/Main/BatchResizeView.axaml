<UserControl
    x:Class="PicView.Avalonia.Views.Main.BatchResizeView"
    x:DataType="viewModels:MainViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:converters="clr-namespace:PicView.Avalonia.Converters"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:viewModels="clr-namespace:PicView.Avalonia.ViewModels;assembly=PicView.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <converters:IndexBiggerThanBooleanConverter x:Key="IndexBiggerThanBooleanConverter" />
        <converters:IndexToStringSizeConverter x:Key="IndexToStringSizeConverter" />
        <converters:IndexToPercentageSizeConverter x:Key="IndexToPercentageSizeConverter" />
    </UserControl.Resources>

    <Panel Margin="0,15,0,30">

        <!--  Files processing panel log  -->
        <Panel
            Background="Transparent"
            IsVisible="{CompiledBinding BatchResizeViewModel.IsRunning.Value}"
            x:Name="ProcessingPanel">
            <Border
                Background="{DynamicResource TertiaryBackgroundColor}"
                BorderBrush="{DynamicResource MainBorderColor}"
                BorderThickness="0,0,0,1"
                CornerRadius="6"
                Effect="{StaticResource MenuShadowButtonBorder}"
                Margin="10,0,10,70">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{CompiledBinding Translation.Cancel, Mode=OneWay}">
                            <MenuItem.Icon>
                                <Path Classes="RestorePath" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>
                <customControls:AutoScrollViewer MinHeight="50">
                    <ItemsControl ItemsSource="{CompiledBinding BatchResizeViewModel.ProcessedFiles.Value}"
                                  Padding="15,10,10,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*, 65, 65" ColumnSpacing="10">
                                    <TextBlock
                                        Background="Transparent"
                                        Classes="txt"
                                        Margin="0,5"
                                        Text="{Binding FileName}" />
                                    <TextBlock
                                        Background="Transparent"
                                        Classes="txt"
                                        Foreground="Red"
                                        Grid.Column="1"
                                        Text="{Binding OldSize}"
                                        TextDecorations="StrikeThrough" />
                                    <TextBlock
                                        Background="Transparent"
                                        Classes="txt"
                                        Foreground="ForestGreen"
                                        Grid.Column="2"
                                        Text="{Binding NewSize}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </customControls:AutoScrollViewer>
            </Border>

            <ProgressBar
                CornerRadius="6"
                FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                Height="32"
                IsIndeterminate="{CompiledBinding BatchResizeViewModel.IsIndeterminate.Value,
                                                  Mode=OneWay}"
                Margin="10,0,10,25"
                Maximum="{CompiledBinding BatchResizeViewModel.ProgressMaximum.Value}"
                Minimum="0"
                ShowProgressText="True"
                Value="{CompiledBinding BatchResizeViewModel.Progress.Value,
                                        Mode=OneWay}"
                VerticalAlignment="Bottom" />

            <StackPanel
                HorizontalAlignment="Center"
                Margin="10,0,10,-20"
                Orientation="Horizontal"
                VerticalAlignment="Bottom">
                <Button
                    Classes="BorderStyle altHover mainBtn"
                    Command="{CompiledBinding BatchResizeViewModel.CancelCommand}"
                    CornerRadius="4"
                    DockPanel.Dock="Left"
                    IsVisible="{CompiledBinding !BatchResizeViewModel.IsFinished.Value}">
                    <TextBlock
                        Classes="txt"
                        Padding="15,0"
                        Text="{CompiledBinding Translation.Cancel.Value,
                                               Mode=OneWay}"
                        TextAlignment="Center" />
                </Button>
                <Button
                    Classes="BorderStyle altHover mainBtn"
                    Command="{CompiledBinding BatchResizeViewModel.CloseProgressCommand}"
                    CornerRadius="4"
                    DockPanel.Dock="Left"
                    IsVisible="{CompiledBinding BatchResizeViewModel.IsFinished.Value}">
                    <TextBlock
                        Classes="txt"
                        Padding="15,0"
                        Text="{CompiledBinding Translation.Close.Value,
                                               Mode=OneWay}"
                        TextAlignment="Center" />
                </Button>
                <Button
                    Classes="BorderStyle altHover mainBtn"
                    Click="ShowInFolderButton_OnClick"
                    CornerRadius="4"
                    DockPanel.Dock="Left"
                    IsVisible="{CompiledBinding BatchResizeViewModel.IsFinished.Value}"
                    x:Name="ShowInFolderButton">
                    <TextBlock
                        Classes="txt"
                        Padding="15,0"
                        Text="{CompiledBinding Translation.ShowInFolder.Value,
                                               Mode=OneWay}"
                        TextAlignment="Center" />
                </Button>
            </StackPanel>
        </Panel>

        <DockPanel IsVisible="{CompiledBinding !BatchResizeViewModel.IsRunning.Value}">

            <!--  Tabs  -->
            <TabControl
                DockPanel.Dock="Top"
                HorizontalAlignment="Center"
                x:Name="MainTabControl">
                <TabItem
                    Classes="alt"
                    CornerRadius="6"
                    x:Name="SelectFilesTabItem">
                    <TabItem.Header>
                        <StackPanel VerticalAlignment="Center" Width="112">
                            <PathIcon
                                Data="{StaticResource FolderGeometry}"
                                Foreground="{DynamicResource MainTextColor}"
                                Height="18"
                                HorizontalAlignment="Center"
                                Width="18" />
                            <TextBlock
                                Classes="txt"
                                Margin="0,5,0,0"
                                Text="{CompiledBinding Translation.SelectFiles}"
                                TextAlignment="Center" />
                        </StackPanel>
                    </TabItem.Header>
                </TabItem>
                <TabItem
                    Classes="alt"
                    CornerRadius="6"
                    x:Name="ResizeSettingsTabItem">
                    <TabItem.Header>
                        <StackPanel VerticalAlignment="Center" Width="112">
                            <Image
                                Height="18"
                                HorizontalAlignment="Center"
                                Source="{StaticResource UpscaleImage}"
                                Width="18" />
                            <TextBlock
                                Classes="txt"
                                Margin="0,5,0,0"
                                Text="{CompiledBinding Translation.ResizeSettings}"
                                TextAlignment="Center" />
                        </StackPanel>
                    </TabItem.Header>
                </TabItem>
                <TabItem
                    Classes="alt"
                    CornerRadius="6"
                    x:Name="ThumbnailTabItem">
                    <TabItem.Header>
                        <StackPanel VerticalAlignment="Center" Width="112">
                            <Image
                                Height="18"
                                HorizontalAlignment="Center"
                                Source="{StaticResource BatchResizeImage}"
                                Width="18" />
                            <TextBlock
                                Classes="txt"
                                Margin="0,5,0,0"
                                Text="{CompiledBinding Translation.Thumbnail}"
                                TextAlignment="Center" />
                        </StackPanel>
                    </TabItem.Header>
                </TabItem>
            </TabControl>

            <!--  Add folder of files buttons  -->
            <StackPanel
                DockPanel.Dock="Top"
                HorizontalAlignment="Center"
                IsVisible="{Binding Path=IsSelected, ElementName=SelectFilesTabItem}"
                Margin="0,15"
                Orientation="Horizontal"
                Spacing="10">
                <customControls:TextIconButton
                    Background="{DynamicResource SoftenColor}"
                    Classes="ButtonBorder altHover mainBtn"
                    Command="{CompiledBinding BatchResizeViewModel.SelectAndAddFileCommand}"
                    Foreground="{DynamicResource MainTextColor}"
                    Icon="{StaticResource AddFileImage}"
                    IconHeight="16"
                    IconMargin="5,0,10,0"
                    IconWidth="16"
                    Text="{CompiledBinding Translation.AddFiles}"
                    x:Name="AddFileButton" />
                <customControls:TextIconButton
                    Background="{DynamicResource SoftenColor}"
                    Classes="ButtonBorder altHover mainBtn"
                    Command="{CompiledBinding BatchResizeViewModel.SelectAndAddFolderCommand}"
                    Foreground="{DynamicResource MainTextColor}"
                    Icon="{StaticResource AddFolderImage}"
                    IconHeight="16"
                    IconMargin="5,0,10,0"
                    IconWidth="16"
                    Text="{CompiledBinding Translation.AddFolder}"
                    x:Name="AddFolderButton" />

            </StackPanel>

            <!--  add files log  -->
            <Border
                Background="{DynamicResource TertiaryBackgroundColor}"
                BorderBrush="{DynamicResource MainBorderColor}"
                BorderThickness="0,1,0,1"
                CornerRadius="4,4,0,0"
                DockPanel.Dock="Top"
                IsVisible="{Binding Path=IsSelected, ElementName=SelectFilesTabItem}"
                Margin="10,0"
                x:Name="FolderHeaderBorder">

                <!--  Files panel header  -->
                <DockPanel LastChildFill="True" VerticalAlignment="Top">
                    <Button
                        Classes="errorHover focus"
                        Command="{CompiledBinding BatchResizeViewModel.RemoveAllCommand}"
                        CornerRadius="0,4,0,0"
                        DockPanel.Dock="Right"
                        Padding="10,2,10,2"
                        x:Name="UnSelectAllButton">
                        <TextBlock Classes="txt" Text="{CompiledBinding Translation.RemoveAll.Value, Mode=OneWay}" />
                    </Button>

                    <!--  Filter  -->
                    <Panel DockPanel.Dock="Left">

                        <Image
                            Height="14"
                            HorizontalAlignment="Left"
                            Margin="15,0,0,0"
                            Source="{StaticResource SearchImage}"
                            Width="14" />

                        <TextBox
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            FontFamily="/Assets/Fonts/Roboto-Regular.ttf#Roboto"
                            Foreground="{DynamicResource MainTextColor}"
                            Padding="50,7,4,7"
                            Text="{CompiledBinding BatchResizeViewModel.FilterText.Value,
                                                   FallbackValue='',
                                                   Mode=TwoWay}"
                            VerticalAlignment="Center"
                            Watermark="{CompiledBinding Translation.Filter.Value,
                                                        Mode=OneWay}"
                            x:Name="FilterBox" />

                        <!--  File count  -->
                        <StackPanel
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right"
                            IsVisible="{Binding Path=!IsVisible, ElementName=ClearButton}"
                            Margin="0,0,10,0"
                            Opacity="0.5"
                            Orientation="Horizontal">
                            <TextBlock
                                Classes="txt"
                                Foreground="{DynamicResource MainTextColorFaded}"
                                Text="{CompiledBinding BatchResizeViewModel.SelectedFiles.Value.Count}" />
                            <TextBlock Classes="txt" Text=" " />
                            <TextBlock
                                Classes="txt"
                                Foreground="{DynamicResource MainTextColorFaded}"
                                Text="{CompiledBinding Translation.Files}" />
                        </StackPanel>

                        <!--  clear  -->
                        <customControls:IconButton
                            Classes="altHover"
                            Command="{CompiledBinding BatchResizeViewModel.ClearFilterCommand}"
                            Data="{StaticResource CloseGeometry}"
                            DockPanel.Dock="Right"
                            Foreground="{DynamicResource MainTextColorFaded}"
                            HorizontalAlignment="Right"
                            IconHeight="12"
                            IconWidth="12"
                            IsVisible="{CompiledBinding BatchResizeViewModel.FilterText.Value,
                                                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Padding="10,3,10,3"
                            x:Name="ClearButton" />


                    </Panel>
                </DockPanel>
            </Border>
            <!--  Add Files panel log  -->
            <Border
                Background="{DynamicResource TertiaryBackgroundColor}"
                BorderBrush="{DynamicResource MainBorderColor}"
                BorderThickness="0,0,0,1"
                CornerRadius="0,0,4,4"
                DockPanel.Dock="Top"
                DragDrop.AllowDrop="True"
                Effect="{StaticResource MenuShadowButtonBorder}"
                IsVisible="{Binding Path=IsSelected, ElementName=SelectFilesTabItem}"
                Margin="10,0,10,75"
                x:Name="FilePanelLogBorder">
                <Panel>
                    <customControls:AutoScrollViewer
                        IsVisible="{CompiledBinding !BatchResizeViewModel.IsFiltering.Value}">
                        <ItemsControl ItemsSource="{CompiledBinding BatchResizeViewModel.SelectedFiles.Value}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <customControls:IconButton
                                            Background="Transparent"
                                            Classes="errorHover"
                                            Command="{Binding #MainTabControl.((viewModels:MainViewModel)DataContext).BatchResizeViewModel.RemoveFileFromListCommand}"
                                            CommandParameter="{Binding}"
                                            Data="{StaticResource CloseGeometry}"
                                            DockPanel.Dock="Left"
                                            IconHeight="12"
                                            IconWidth="12"
                                            Padding="16,12" />
                                        <Button
                                            Background="Transparent"
                                            Classes="altHover"
                                            DockPanel.Dock="Right">
                                            <TextBlock
                                                Classes="txt"
                                                Margin="10,0"
                                                Text="{Binding Name}" />
                                        </Button>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </customControls:AutoScrollViewer>
                    <customControls:AutoScrollViewer
                        IsVisible="{CompiledBinding BatchResizeViewModel.IsFiltering.Value}">
                        <ItemsControl ItemsSource="{CompiledBinding BatchResizeViewModel.FilteredFiles.Value}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <customControls:IconButton
                                            Background="Transparent"
                                            Classes="errorHover"
                                            Command="{Binding #MainTabControl.((viewModels:MainViewModel)DataContext).BatchResizeViewModel.RemoveFileFromListCommand}"
                                            CommandParameter="{Binding}"
                                            Data="{StaticResource CloseGeometry}"
                                            DockPanel.Dock="Left"
                                            IconHeight="12"
                                            IconWidth="12"
                                            Padding="16,12" />
                                        <Button
                                            Background="Transparent"
                                            Classes="altHover"
                                            DockPanel.Dock="Right">
                                            <TextBlock
                                                Classes="txt"
                                                Margin="10,0"
                                                Text="{Binding Name}" />
                                        </Button>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </customControls:AutoScrollViewer>
                </Panel>
            </Border>

            <!--  Output folder  -->
            <DockPanel
                DockPanel.Dock="Top"
                Height="36"
                IsVisible="{Binding Path=IsSelected, ElementName=SelectFilesTabItem}"
                LastChildFill="True"
                Margin="0,-85,0,0">
                <TextBlock
                    Classes="txt"
                    DockPanel.Dock="Left"
                    Margin="15,0,5,0"
                    Text="{CompiledBinding Translation.OutputFolder.Value,
                                           Mode=OneWay}"
                    VerticalAlignment="Center" />

                <customControls:IconButton
                    Background="Transparent"
                    Classes="altHover"
                    ClickMode="Release"
                    Command="{CompiledBinding BatchResizeViewModel.PickOutputFolderCommand}"
                    CornerRadius="4"
                    Data="{StaticResource AltFolderGeometry}"
                    DockPanel.Dock="Right"
                    Foreground="{DynamicResource MainTextColor}"
                    IconHeight="20"
                    IconWidth="20"
                    IsRepeatEnabled="False"
                    Margin="5,0,10,0"
                    Width="30"
                    x:Name="OutputFolderButton" />
                <customControls:FuncTextBox
                    Classes="hover TStyle"
                    DockPanel.Dock="Left"
                    MinWidth="252"
                    Text="{CompiledBinding BatchResizeViewModel.OutputFolder.Value,
                                           Mode=TwoWay}"
                    x:Name="OutputFolderTextBox" />
            </DockPanel>


            <!--  Resize settings  -->
            <customControls:AutoScrollViewer
                DockPanel.Dock="Top"
                IsVisible="{Binding Path=IsSelected, ElementName=ResizeSettingsTabItem}"
                Margin="10,15"
                x:Name="ResizeSettingsContainer">
                <StackPanel HorizontalAlignment="Center" Spacing="15">

                    <!--  Compression  -->
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock
                            Classes="txt"
                            Foreground="{DynamicResource MainTextColor}"
                            Margin="5,0,0,0"
                            Text="{CompiledBinding Translation.Compression.Value,
                                                   Mode=OneWay}"
                            Width="130" />
                        <ComboBox
                            Background="{DynamicResource SecondaryBackgroundColor}"
                            BorderBrush="{DynamicResource MainBorderColor}"
                            BorderThickness="1"
                            CornerRadius="2"
                            FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                            Foreground="{DynamicResource MainTextColor}"
                            Height="30"
                            ItemsSource="{CompiledBinding BatchResizeViewModel.CompressionModes.Value,
                                                          Mode=TwoWay}"
                            Margin="10,0,0,0"
                            Padding="5,7,0,7"
                            SelectedIndex="{CompiledBinding Window.BatchResizeWindowConfig.WindowProperties.CompressionIndex}"
                            Width="252"
                            x:Name="CompressionComboBox" />
                    </StackPanel>

                    <!--  Quality  -->
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock
                            Classes="txt"
                            IsEnabled="{Binding Path=IsChecked, ElementName=IsQualityEnabledBox}"
                            Margin="5,0,0,0"
                            Text="{CompiledBinding Translation.Quality.Value,
                                                   Mode=OneWay}"
                            Width="130" />
                        <CheckBox
                            Classes="altHover"
                            IsChecked="{CompiledBinding Window.BatchResizeWindowConfig.WindowProperties.IsQualityEnabled}"
                            IsCheckedChanged="IsQualityEnabledBox_OnIsCheckedChanged"
                            Margin="10,0,6,0"
                            x:Name="IsQualityEnabledBox" />
                        <customControls:CustomSlider
                            Height="10"
                            IsEnabled="{Binding Path=IsChecked, ElementName=IsQualityEnabledBox}"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,10,2"
                            Maximum="100"
                            Minimum="1"
                            TickFrequency="1"
                            Value="75"
                            Width="170"
                            x:Name="QualitySlider" />
                        <TextBlock
                            Classes="txt"
                            IsEnabled="{Binding Path=IsChecked, ElementName=IsQualityEnabledBox}"
                            Margin="10,0,0,3"
                            Text="{Binding Path=Value, ElementName=QualitySlider}" />
                    </StackPanel>

                    <!--  Convert to  -->
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock
                            Classes="txt"
                            Margin="5,0,0,0"
                            Text="{CompiledBinding Translation.ConvertTo.Value,
                                                   Mode=OneWay}"
                            Width="130" />
                        <ComboBox
                            Background="{DynamicResource SecondaryBackgroundColor}"
                            BorderBrush="{DynamicResource MainBorderColor}"
                            BorderThickness="1"
                            CornerRadius="2"
                            FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                            Foreground="{DynamicResource MainTextColor}"
                            ItemsSource="{CompiledBinding BatchResizeViewModel.ConversionTargets.Value,
                                                          Mode=TwoWay}"
                            Margin="11,0,0,0"
                            Padding="5,7,0,7"
                            SelectedIndex="{CompiledBinding Window.BatchResizeWindowConfig.WindowProperties.ConvertToIndex}"
                            Width="252"
                            x:Name="ConversionComboBox" />
                    </StackPanel>

                    <!--  Resize  -->
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock
                            Classes="txt"
                            Margin="5,0,0,0"
                            Text="{CompiledBinding Translation.Resize.Value,
                                                   Mode=OneWay}"
                            Width="130"
                            x:Name="ResizeTextBlock" />
                        <ComboBox
                            Background="{DynamicResource SecondaryBackgroundColor}"
                            BorderBrush="{DynamicResource MainBorderColor}"
                            BorderThickness="1"
                            CornerRadius="2"
                            FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                            Foreground="{DynamicResource MainTextColor}"
                            Height="30"
                            ItemsSource="{CompiledBinding BatchResizeViewModel.ResizeModes.Value,
                                                          Mode=TwoWay}"
                            Margin="10,0,0,0"
                            Padding="5,7,0,7"
                            SelectedIndex="{CompiledBinding Window.BatchResizeWindowConfig.WindowProperties.ResizeIndex}"
                            SelectedItem="NoResizeBox"
                            SelectionChanged="ResizeComboBox_OnSelectionChanged"
                            Width="252"
                            x:Name="ResizeComboBox" />
                    </StackPanel>

                    <!--  Percentage  -->
                    <StackPanel
                        HorizontalAlignment="Center"
                        IsVisible="{CompiledBinding BatchResizeViewModel.IsPercentageResizing.Value}"
                        Margin="10,0,0,0"
                        Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock
                                Classes="txt"
                                FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                                Margin="5,0,0,0"
                                Text="{CompiledBinding Translation.Percentage.Value,
                                                       Mode=OneWay}" />
                            <customControls:FuncTextBox
                                Classes="hover TStyle"
                                Text="{CompiledBinding BatchResizeViewModel.PercentageValue.Value,
                                                       Mode=TwoWay}"
                                Width="130"
                                x:Name="PercentageValueBox" />
                        </StackPanel>

                        <Image
                            Height="12"
                            Margin="15,0"
                            Source="{StaticResource PercentageIcon}"
                            Width="12" />
                    </StackPanel>

                    <!--  Width and height adjustment  -->
                    <StackPanel
                        HorizontalAlignment="Center"
                        IsVisible="{CompiledBinding BatchResizeViewModel.IsWidthAndHeightResizing.Value}"
                        Margin="10,0,0,0"
                        Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock
                                Classes="txt"
                                FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                                Margin="5,0,0,0"
                                Text="{CompiledBinding Translation.Width.Value,
                                                       Mode=OneWay}" />
                            <customControls:NumTextBox
                                Background="{DynamicResource SecondaryBackgroundColor}"
                                Classes="hover TStyle"
                                CornerRadius="4"
                                Foreground="{DynamicResource MainTextColor}"
                                Height="35"
                                Margin="0"
                                MinWidth="100"
                                Text="{CompiledBinding BatchResizeViewModel.WidthValue.Value,
                                                       Mode=TwoWay}"
                                Width="110" />
                        </StackPanel>

                        <Button
                            Background="Transparent"
                            Classes="altHover"
                            Command="{CompiledBinding BatchResizeViewModel.ToggleAspectRatioCommand}"
                            Foreground="{DynamicResource MainTextColor}"
                            Height="35"
                            Margin="15,0"
                            Width="38">
                            <Panel>
                                <Image
                                    Height="21"
                                    IsVisible="{CompiledBinding !BatchResizeViewModel.IsKeepingAspectRatio}"
                                    Source="{StaticResource UnlinkChainImage}"
                                    Width="21"
                                    x:Name="UnlinkChainImage" />
                                <Image
                                    Height="21"
                                    IsVisible="{CompiledBinding BatchResizeViewModel.IsKeepingAspectRatio}"
                                    Source="{StaticResource LinkChainImage}"
                                    Width="21"
                                    x:Name="LinkChainImage" />
                            </Panel>
                        </Button>


                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="10">
                            <TextBlock
                                Classes="txt"
                                FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                                Margin="5,0,0,0"
                                Text="{CompiledBinding Translation.Height.Value,
                                                       Mode=OneWay}" />
                            <customControls:NumTextBox
                                Background="{DynamicResource SecondaryBackgroundColor}"
                                Classes="hover TStyle"
                                CornerRadius="4"
                                Foreground="{DynamicResource MainTextColor}"
                                Height="35"
                                Margin="0"
                                MinWidth="100"
                                Text="{CompiledBinding BatchResizeViewModel.HeightValue.Value,
                                                       Mode=TwoWay}"
                                Width="110" />
                        </StackPanel>
                    </StackPanel>


                    <!--  Width  -->
                    <StackPanel
                        HorizontalAlignment="Center"
                        IsVisible="{CompiledBinding BatchResizeViewModel.IsWidthResizing.Value}"
                        Margin="10,0,0,0"
                        Orientation="Horizontal"
                        Spacing="10">
                        <TextBlock
                            Classes="txt"
                            FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                            Margin="5,0,0,0"
                            Text="{CompiledBinding Translation.Width.Value,
                                                   Mode=OneWay}" />
                        <customControls:NumTextBox
                            Background="{DynamicResource SecondaryBackgroundColor}"
                            Classes="hover TStyle"
                            CornerRadius="4"
                            Foreground="{DynamicResource MainTextColor}"
                            Height="35"
                            Margin="0"
                            MinWidth="60"
                            Text="{CompiledBinding BatchResizeViewModel.SingleWidthValue.Value,
                                                   Mode=TwoWay}"
                            Width="175" />
                    </StackPanel>

                    <!--  Height  -->
                    <StackPanel
                        HorizontalAlignment="Center"
                        IsVisible="{CompiledBinding BatchResizeViewModel.IsHeightResizing.Value}"
                        Margin="10,0,0,0"
                        Orientation="Horizontal"
                        Spacing="10">
                        <TextBlock
                            Classes="txt"
                            FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                            Margin="5,0,0,0"
                            Text="{CompiledBinding Translation.Height.Value,
                                                   Mode=OneWay}" />
                        <customControls:NumTextBox
                            Background="{DynamicResource SecondaryBackgroundColor}"
                            Classes="hover TStyle"
                            CornerRadius="4"
                            Foreground="{DynamicResource MainTextColor}"
                            Height="35"
                            Margin="0"
                            MinWidth="60"
                            Text="{CompiledBinding BatchResizeViewModel.SingleHeightValue.Value,
                                                   Mode=TwoWay}"
                            Width="175" />
                    </StackPanel>

                </StackPanel>
            </customControls:AutoScrollViewer>

            <!--  Generate thumbnails  -->
            <customControls:AutoScrollViewer
                DockPanel.Dock="Top"
                IsVisible="{Binding Path=IsSelected, ElementName=ThumbnailTabItem}"
                Margin="0,0,0,20"
                x:Name="ThumbnailTabContainer">
                <StackPanel Margin="15,5">

                    <StackPanel
                        HorizontalAlignment="Center"
                        Margin="0,10"
                        Orientation="Horizontal">
                        <TextBlock
                            Classes="txt"
                            Margin="5,0,0,0"
                            Text="{CompiledBinding Translation.GenerateThumbnails.Value,
                                                   Mode=OneWay}"
                            Width="130"
                            x:Name="GenerateThumbnailsTextBlock" />
                        <ComboBox
                            Background="{DynamicResource SecondaryBackgroundColor}"
                            BorderBrush="{DynamicResource MainBorderColor}"
                            BorderThickness="1"
                            CornerRadius="2"
                            FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                            Foreground="{DynamicResource MainTextColor}"
                            Height="30"
                            ItemsSource="{CompiledBinding BatchResizeViewModel.ThumbnailAmounts.Value,
