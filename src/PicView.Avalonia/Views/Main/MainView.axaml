<UserControl
    x:Class="PicView.Avalonia.Views.Main.MainView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:buttons="clr-namespace:PicView.Avalonia.Views.UC.Buttons"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:uc="clr-namespace:PicView.Avalonia.Views.UC"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    x:DataType="viewModels:MainWindowViewModel"
    Background="Transparent"
    DragDrop.AllowDrop="True"
    Focusable="True">
    <UserControl.Resources>
        <SolidColorBrush x:Key="Brush0" Color="{DynamicResource MainTextColor}" />

        <ContextMenu x:Key="MainContextMenu">

            <!--  Open  -->
            <MenuItem
                MinWidth="180"
                Command="{CompiledBinding OpenCommand}"
                Header="{CompiledBinding Translation.Open.Value,
                                         Mode=OneWay}">
                <MenuItem.Icon>
                    <Image Classes="OpenImage" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Save  -->
            <MenuItem
                Command="{CompiledBinding SaveCommand}"
                Header="{CompiledBinding Translation.Save.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Path Classes="SavePath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Save as  -->
            <MenuItem
                Command="{CompiledBinding SaveAsCommand}"
                Header="{CompiledBinding Translation.SaveAs.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull}}">
                <MenuItem.Icon>
                    <Path Classes="SavePath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Print  -->
            <MenuItem
                x:Name="PrintMenuItem"
                Command="{CompiledBinding PrintCommand}"
                Header="{CompiledBinding Translation.Print.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="PrintPath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Open with  -->
            <MenuItem
                x:Name="OpenWithMenuItem"
                Command="{CompiledBinding OpenWithCommand}"
                Header="{CompiledBinding Translation.OpenWith.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource OpenExternalImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Locate on disk  -->
            <MenuItem
                Command="{CompiledBinding OpenInExplorerCommand}"
                Header="{CompiledBinding Translation.ShowInFolder.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Path Classes="ShowInFolderPath" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Sort files by  -->
            <MenuItem Header="{CompiledBinding Translation.SortFilesBy.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="SortFilesPath" />
                </MenuItem.Icon>

                <!--  Sort files by name  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesByNameCommand}"
                    GroupName="SortType"
                    Header="{CompiledBinding Translation.FileName.Value,
                                             Mode=OneWay}"
                    IsChecked="{Binding WindowTabs.IsSortedByName.Value}"
                    ToggleType="Radio" />

                <!--  Sort files by size  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesBySizeCommand}"
                    GroupName="SortType"
                    Header="{CompiledBinding Translation.FileSize.Value,
                                             Mode=OneWay}"
                    IsChecked="{Binding WindowTabs.IsSortedByFileSize.Value}"
                    ToggleType="Radio" />

                <!--  Sort files by extension  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesByExtensionCommand}"
                    GroupName="SortType"
                    Header="{CompiledBinding Translation.FileExtension.Value,
                                             Mode=OneWay}"
                    IsChecked="{Binding WindowTabs.IsSortedByExtension.Value}"
                    ToggleType="Radio" />

                <!--  Sort files by creation time  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesByCreationTimeCommand}"
                    GroupName="SortType"
                    Header="{CompiledBinding Translation.Created.Value,
                                             Mode=OneWay}"
                    IsChecked="{Binding WindowTabs.IsSortedByCreationTime.Value}"
                    ToggleType="Radio" />

                <!--  Sort files by last access time  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesByLastAccessTimeCommand}"
                    GroupName="SortType"
                    Header="{CompiledBinding Translation.LastAccessTime.Value,
                                             Mode=OneWay}"
                    IsChecked="{Binding WindowTabs.IsSortedByLastAccessTime.Value}"
                    ToggleType="Radio" />

                <!--  Sort files by last write time  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesByLastAccessTimeCommand}"
                    GroupName="SortType"
                    Header="{CompiledBinding Translation.Modified.Value,
                                             Mode=OneWay}"
                    IsChecked="{Binding WindowTabs.IsSortedByLastAccessTime.Value}"
                    ToggleType="Radio" />

                <!--  Sort files randomly  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesRandomlyCommand}"
                    GroupName="SortType"
                    Header="{CompiledBinding Translation.Random.Value,
                                             Mode=OneWay}"
                    IsChecked="{Binding WindowTabs.IsSortedByRandomization.Value}"
                    ToggleType="Radio" />

                <Separator />

                <!--  Sort files ascending  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesAscendingCommand}"
                    GroupName="SortDirection"
                    Header="{CompiledBinding Translation.Ascending.Value,
                                             Mode=OneWay}"
                    IsChecked="{CompiledBinding WindowTabs.IsAscending.Value}"
                    ToggleType="Radio" />

                <!--  Sort files descending  -->
                <MenuItem
                    Command="{CompiledBinding SortFilesDescendingCommand}"
                    GroupName="SortDirection"
                    Header="{CompiledBinding Translation.Descending.Value,
                                             Mode=OneWay}"
                    IsChecked="{CompiledBinding !WindowTabs.IsAscending.Value}"
                    ToggleType="Radio" />
            </MenuItem>

            <Separator />

            <!--  Settings  -->
            <MenuItem Header="{CompiledBinding Translation.Settings.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path
                        Width="12"
                        Height="12"
                        Data="{StaticResource WrenchGeometry}"
                        Fill="{StaticResource Brush0}"
                        Stretch="Fill" />
                </MenuItem.Icon>

                <!--  Toggle Subdirectories  -->
                <MenuItem
                    Command="{CompiledBinding ToggleSubdirectoriesCommand}"
                    Header="{CompiledBinding Translation.SearchSubdirectory.Value,
                                             Mode=OneWay}"
                    ToggleType="CheckBox" />

                <Separator />

                <!--  Toggle looping  -->
                <MenuItem
                    Command="{CompiledBinding ToggleLoopingCommand}"
                    Header="{CompiledBinding Translation.IsLooping.Value,
                                             Mode=OneWay}"
                    IsChecked="{Binding GlobalSettings.IsLooping.Value, Mode=TwoWay}"
                    ToggleType="CheckBox" />

                <Separator />

                <!--  Toggle scrolling  -->
                <MenuItem
                    Command="{CompiledBinding ToggleScrollCommand}"
                    Header="{CompiledBinding Translation.IsScrolling.Value,
                                             Mode=OneWay}"
                    IsChecked="{Binding IsScrollingEnabled.Value, Mode=TwoWay}"
                    ToggleType="CheckBox" />

                <!--  Zoom to fit  -->
                <MenuItem
                    Command="{CompiledBinding ZoomToFitCommand}"
                    Header="{CompiledBinding Translation.ZoomToFit.Value,
                                             Mode=OneWay}"
                    IsChecked="{Binding IsZoomedToFit.Value, Mode=TwoWay}"
                    ToggleType="CheckBox" />

                <!--  Toggle side-by-side  -->
                <MenuItem
                    Command="{CompiledBinding SideBySideCommand}"
                    Header="{CompiledBinding Translation.SideBySide.Value,
                                             Mode=OneWay}"
                    IsChecked="{Binding IsSideBySide.Value, Mode=TwoWay}"
                    ToggleType="CheckBox" />

                <Separator />

                <!--  Toggle topmost  -->
                <MenuItem
                    Command="{CompiledBinding SetTopMostCommand}"
                    Header="{CompiledBinding Translation.StayTopMost.Value,
                                             Mode=OneWay}"
                    IsChecked="{Binding IsTopMost.Value, Mode=TwoWay}"
                    ToggleType="CheckBox" />

                <!--  Toggle auto fit  -->
                <MenuItem
                    Command="{CompiledBinding AutoFitWindowCommand}"
                    Header="{CompiledBinding Translation.AutoFitWindow.Value,
                                             Mode=OneWay}"
                    IsChecked="{Binding IsAutoFit.Value, Mode=TwoWay}"
                    ToggleType="CheckBox" />

                <Separator />

                <!--  Toggle ctrl zoom  -->
                <MenuItem Command="{CompiledBinding ChangeCtrlZoomCommand}" Header="{CompiledBinding Translation.IsCtrlToZoom.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{CompiledBinding ChangeCtrlZoomImage.Value}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Toggle UI  -->
                <MenuItem
                    Command="{CompiledBinding ToggleInterfaceCommand}"
                    Header="{CompiledBinding Translation.IsShowingUI.Value,
                                             Mode=OneWay}"
                    IsVisible="{CompiledBinding IsUIShown.Value,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource EyeOffImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    Command="{CompiledBinding ToggleInterfaceCommand}"
                    Header="{CompiledBinding Translation.IsShowingUI.Value,
                                             Mode=OneWay}"
                    IsVisible="{CompiledBinding !IsUIShown.Value,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource EyeImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Change background  -->
                <MenuItem
                    Command="{CompiledBinding ChangeBackgroundCommand}"
                    Header="{CompiledBinding Translation.ChangeBackground.Value,
                                             Mode=OneWay}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource PaletteImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Toggle bottom gallery  -->
                <MenuItem Header="{CompiledBinding Translation.IsShowingDockedGallery.Value, Mode=OneWay}" IsChecked="{CompiledBinding WindowTabs.ActiveTab.Value.Gallery.IsDockedGalleryVisible.Value}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource GalleryImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Toggle bottom bar  -->
                <MenuItem
                    Command="{Binding ToggleBottomToolbarCommand}"
                    Header="{CompiledBinding Translation.ShowBottomToolbar.Value,
                                             Mode=OneWay}"
                    IsChecked="{CompiledBinding IsBottomToolbarShown.Value}"
                    IsVisible="{CompiledBinding !IsBottomToolbarShown.Value}"
                    ToggleType="CheckBox">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource Panel-Bottom}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Show Settings window  -->
                <MenuItem Command="{CompiledBinding SettingsWindowCommand}" Header="{CompiledBinding Translation.ShowAllSettingsWindow.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image Classes="CogImage" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <Separator />

            <!--  Navigation  -->
            <MenuItem Header="{CompiledBinding Translation.Navigation.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Image
                        Width="14"
                        Height="14"
                        Source="{StaticResource SignPostImage}" />
                </MenuItem.Icon>

                <!--  Next  -->
                <MenuItem
                    Command="{CompiledBinding NextCommand}"
                    Header="{CompiledBinding Translation.NextImage.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateForwards.Value,
                                                FallbackValue=False}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource NextImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Prev  -->
                <MenuItem
                    Command="{CompiledBinding PrevCommand}"
                    Header="{CompiledBinding Translation.PrevImage.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateBackwards.Value,
                                                FallbackValue=False}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource PrevImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Next 10  -->
                <MenuItem
                    Command="{CompiledBinding Next10Command}"
                    Header="{CompiledBinding Translation.AdvanceBy10Images.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateForwards.Value}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource NextImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Next 100  -->
                <MenuItem
                    Command="{CompiledBinding Next100Command}"
                    Header="{CompiledBinding Translation.AdvanceBy100Images.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateForwards.Value}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource NextImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Prev 10  -->
                <MenuItem
                    Command="{CompiledBinding Prev10Command}"
                    Header="{CompiledBinding Translation.GoBackBy10Images.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateBackwards.Value}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource PrevImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Prev 100  -->
                <MenuItem
                    Command="{CompiledBinding Prev100Command}"
                    Header="{CompiledBinding Translation.GoBackBy100Images.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateBackwards.Value}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource PrevImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  First Image  -->
                <MenuItem
                    Command="{CompiledBinding FirstCommand}"
                    Header="{CompiledBinding Translation.FirstImage.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateBackwards.Value}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource FirstImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Last Image  -->
                <MenuItem
                    Command="{CompiledBinding LastCommand}"
                    Header="{CompiledBinding Translation.LastImage.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.CanNavigateForwards.Value}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource LastImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Next folder  -->
                <MenuItem
                    Command="{CompiledBinding NextFolderCommand}"
                    Header="{CompiledBinding Translation.NextFolder.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="14"
                            Height="14"
                            Source="{StaticResource NextFolderImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Prev folder  -->
                <MenuItem
                    Command="{CompiledBinding PrevFolderCommand}"
                    Header="{CompiledBinding Translation.PrevFolder.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="14"
                            Height="14"
                            Source="{StaticResource PrevFolderImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Next archive  -->
                <MenuItem
                    Command="{CompiledBinding NextArchiveCommand}"
                    Header="{CompiledBinding Translation.NextArchive.Value,
                                             Mode=OneWay}"
                    IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <MenuItem.Icon>
                        <Image
                            Width="14"
                            Height="14"
                            Source="{StaticResource ArchiveFile}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Prev archive  -->
                <MenuItem
                    Command="{CompiledBinding PrevArchiveCommand}"
                    Header="{CompiledBinding Translation.PrevArchive.Value,
                                             Mode=OneWay}"
                    IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <MenuItem.Icon>
                        <Image
                            Width="14"
                            Height="14"
                            Source="{StaticResource ArchiveFile}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <Separator />

            <!--  Set as wallpaper  -->
            <MenuItem
                Command="{CompiledBinding SetAsWallpaperFittedCommand}"
                CommandParameter="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                   FallbackValue=''}"
                Header="{CompiledBinding Translation.SetAsWallpaper.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Path
                        Width="13"
                        Height="10.40"
                        Data="{StaticResource PanoramaGeometry}"
                        Fill="{StaticResource Brush0}"
                        Stretch="Fill" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Image  -->
            <MenuItem Header="{CompiledBinding Translation.Image.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource Image}" />
                </MenuItem.Icon>

                <!--  Exif window  -->
                <MenuItem Command="{CompiledBinding ImageInfoWindowCommand}" Header="{CompiledBinding Translation.ImageInfo.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource CameraImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  File properties  -->
                <MenuItem
                    Command="{CompiledBinding ShowFilePropertiesCommand}"
                    Header="{CompiledBinding Translation.FileProperties.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource FileUserImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Image effects  -->
                <MenuItem
                    Command="{Binding EffectsWindowCommand}"
                    Header="{CompiledBinding Translation.Effects.Value,
                                             Mode=OneWay}"
                    ToolTip.Tip="{CompiledBinding Translation.EffectsTooltip.Value,
                                                  Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource SparklesImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Resize  Image  -->
                <MenuItem Command="{Binding ResizeWindowCommand}" Header="{CompiledBinding Translation.ResizeImage.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource UpscaleImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Batch Resize  Images  -->
                <MenuItem Command="{Binding BatchResizeWindowCommand}" Header="{CompiledBinding Translation.BatchResize.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource UpscaleImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Optimize image  -->
                <MenuItem
                    x:Name="OptimizeMenuItem"
                    Command="{Binding OptimizeImageCommand}"
                    Header="{CompiledBinding Translation.OptimizeImage.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.ShouldOptimizeImageBeEnabled.Value,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource PortalImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Crop  -->
                <MenuItem
                    x:Name="CropMenuItem"
                    Command="{Binding CropCommand}"
                    Header="{Binding Translation.Crop.Value, Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.ShouldCropBeEnabled.Value,
                                                Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image Classes="CropImage" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Flip  -->
                <MenuItem
                    Command="{Binding FlipCommand}"
                    Header="{CompiledBinding Translation.IsFlipped.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image Classes="FlipImage">
                            <Image.RenderTransform>
                                <ScaleTransform ScaleX="{Binding WindowTabs.ActiveTab.Value.ScaleX.Value}" />
                            </Image.RenderTransform>
                        </Image>
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Rotate left  -->
                <MenuItem
                    Command="{Binding RotateLeftCommand}"
                    Header="{CompiledBinding Translation.RotateLeft.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Path Classes="RotateLeftPath" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Rotate right  -->
                <MenuItem
                    Command="{Binding RotateRightCommand}"
                    Header="{CompiledBinding Translation.RotateRight.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False,
                                                Mode=OneWay}"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Path Classes="RotateRightPath" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <Separator />

            <!--  Delete file  -->
            <MenuItem
                x:Name="DeleteFileMenuItem"
                Command="{CompiledBinding DeleteFileCommand}"
                Header="{CompiledBinding Translation.DeleteFile.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="RecyclePath" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Paste  -->
            <MenuItem Command="{CompiledBinding PasteCommand}" Header="{CompiledBinding Translation.Paste.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="PastePath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Copy  -->
            <MenuItem Header="{Binding Translation.Copy.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path
                        Width="12"
                        Height="12"
                        Data="{StaticResource CopyGeometry}"
                        Fill="{StaticResource Brush0}"
                        Stretch="Fill" />
                </MenuItem.Icon>

                <!--  Copy image  -->
                <MenuItem
                    Command="{Binding CopyImageCommand}"
                    Header="{Binding Translation.CopyImage.Value, Mode=OneWay}"
                    IsEnabled="{Binding WindowTabs.ActiveTab.Value.Image.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path Classes="CopyPath" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Copy file path  -->
                <MenuItem
                    Command="{Binding CopyFilePathCommand}"
                    Header="{Binding Translation.FileCopyPath.Value, Mode=OneWay}"
                    IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path Classes="CopyPath" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Copy base64  -->
                <MenuItem Command="{Binding CopyBase64Command}" IsEnabled="{Binding WindowTabs.ActiveTab.Value.Image.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False, Mode=OneWay}">
                    <MenuItem.Header>
                        <TextBlock>
                            <Run Text="{Binding Translation.Copy.Value, Mode=OneWay}" />
                            <Run Text=" base64" />
                        </TextBlock>
                    </MenuItem.Header>
                    <MenuItem.Icon>
                        <Path Classes="CopyPath" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Duplicate file  -->
                <MenuItem
                    Command="{Binding DuplicateFileCommand}"
                    Header="{Binding Translation.DuplicateFile.Value, Mode=OneWay}"
                    IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path Classes="DuplicatePath" />
                    </MenuItem.Icon>
                </MenuItem>

            </MenuItem>

            <!--  Copy file  -->
            <MenuItem
                Command="{Binding CopyFileCommand}"
                Header="{Binding Translation.CopyFile.Value, Mode=OneWay}"
                IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="CopyPath" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Fullscreen  -->
            <MenuItem
                Command="{CompiledBinding ToggleFullscreenCommand}"
                Header="{CompiledBinding Translation.Fullscreen.Value,
                                         Mode=OneWay}"
                IsVisible="{CompiledBinding !IsFullscreen.Value,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="FullscreenPath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Maximize  -->
            <MenuItem
                x:Name="MaximizeMenuItem"
                Command="{CompiledBinding MaximizeCommand}"
                Header="{CompiledBinding Translation.Maximize.Value,
                                         Mode=OneWay}"
                IsVisible="{CompiledBinding ShouldMaximizeBeShown.Value,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Image Classes="MaximizeImage" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Restore  -->
            <MenuItem
                Command="{CompiledBinding RestoreCommand}"
                Header="{CompiledBinding Translation.RestoreDown.Value,
                                         Mode=OneWay}"
                IsVisible="{CompiledBinding ShouldRestoreBeShown.Value,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="RestorePath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Close  -->
            <MenuItem Command="{CompiledBinding ExitCommand}" Header="{CompiledBinding Translation.Close.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path
                        Width="12"
                        Height="12"
                        Data="{StaticResource CloseGeometry}"
                        Fill="{StaticResource Brush0}"
                        Stretch="Fill" />
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </UserControl.Resources>

    <Panel x:Name="MainPanel" ContextMenu="{StaticResource MainContextMenu}">
        <customControls:DraggableTabControl
            x:Name="MainTabControl"
            Background="{DynamicResource SecondaryBackgroundColor}"
            BorderBrush="{DynamicResource TertiaryBorderColor}"
            BorderThickness="0,0,0,1"
            DataContext="{CompiledBinding WindowTabs}"
            ItemsSource="{CompiledBinding Tabs.Value,
                                          Mode=TwoWay}"
            SelectedItem="{Binding ActiveTab.Value, Mode=TwoWay}">

            <customControls:DraggableTabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="Theme" Value="{StaticResource DraggableTabItem}" />
                </Style>
            </customControls:DraggableTabControl.Styles>

            <customControls:DraggableTabControl.ItemTemplate>
                <DataTemplate>
                    <DockPanel Background="Transparent" LastChildFill="True">
                        <customControls:IconButton
                            Height="{Binding TabHeight}"
                            Padding="9,0"
                            Background="Transparent"
                            Classes="altHover"
                            Command="{CompiledBinding CloseTab}"
                            Data="{StaticResource CloseGeometry}"
                            DockPanel.Dock="Right"
                            Foreground="{DynamicResource MainTextColor}"
                            IconHeight="12"
                            IconWidth="12" />
                        <TextBlock
                            Margin="7,0,0,0"
                            Classes="txt"
                            Text="{CompiledBinding TabTitle.Value,
                                                   Mode=OneWay}"
                            TextWrapping="NoWrap" />
                        <ToolTip.Tip>
                            <DockPanel Width="140" Height="235">
                                <TextBlock
                                    MaxWidth="135"
                                    HorizontalAlignment="Center"
                                    Classes="txt bold"
                                    DockPanel.Dock="Top"
                                    FontSize="12"
                                    Text="{Binding TabTitle.Value, Mode=OneWay}" />
                                <customControls:ThumbImage
                                    HorizontalAlignment="Center"
                                    DockPanel.Dock="Bottom"
                                    Source="{CompiledBinding Image.Value,
                                                             TargetNullValue={StaticResource LogoImage}}" />
                            </DockPanel>
                        </ToolTip.Tip>
                    </DockPanel>
                </DataTemplate>
            </customControls:DraggableTabControl.ItemTemplate>

            <customControls:DraggableTabControl.ContentTemplate>
                <DataTemplate DataType="viewModels:TabViewModel">
                    <ContentControl ClipToBounds="True" Content="{Binding CurrentView.Value, Mode=OneWay}" />
                </DataTemplate>
            </customControls:DraggableTabControl.ContentTemplate>

        </customControls:DraggableTabControl>

        <uc:SpinWaiter
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsVisible="{Binding IsLoadingIndicatorShown.Value, Mode=OneWay}"
            ZIndex="9" />

        <StackPanel
            x:Name="AltButtonsPanel"
            Height="150"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Background="Transparent"
            IsVisible="{Binding !WindowTabs.ActiveTab.Value.Gallery.IsGalleryExpanded.Value}"
            Opacity="0"
            Orientation="Horizontal"
            ZIndex="9">
            <buttons:AltMinimize x:Name="AltMinimize" IsVisible="{Binding !IsUIShown.Value}" />
            <buttons:AltRestore x:Name="AltRestore" IsVisible="{Binding !IsUIShown.Value}" />
            <buttons:AltClose x:Name="AltClose" IsVisible="{Binding !IsUIShown.Value}" />
        </StackPanel>

        <uc:ToolTipMessage
            x:Name="ToolTipMessage"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Opacity="0"
            ZIndex="9" />
    </Panel>
</UserControl>