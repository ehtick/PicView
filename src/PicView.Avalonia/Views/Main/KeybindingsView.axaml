                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="True"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding AltKey,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  Tab management  -->
                    <TextBlock
                        Margin="10,10,10,15"
                        Classes="txt bold"
                        Text="Tab management (Replace with translation)"
                        TextAlignment="Center" />
                    <ItemsControl ItemsSource="{CompiledBinding Keybindings.TabKeys.Value}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="15,0,10,10" Orientation="Horizontal">
                                    <TextBlock
                                        Width="170"
                                        Classes="txt"
                                        FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                                        Text="{CompiledBinding FriendlyMethodName}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="False"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding Key,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="True"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding AltKey,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  Tool Windows  -->
                    <TextBlock
                        Margin="10,10,10,15"
                        Classes="txt bold"
                        Text="{CompiledBinding Translation.ToolWindows.Value,
                                               Mode=OneWay}"
                        TextAlignment="Center" />
                    <ItemsControl ItemsSource="{CompiledBinding Keybindings.ToolWindowsKeys.Value}">
                        <ItemsControl.ItemTemplate>
