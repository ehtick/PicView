<UserControl
    x:Class="PicView.Avalonia.Views.Main.KeybindingsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    x:DataType="viewModels:CoreViewModel">

    <!--  Filter  -->
    <DockPanel>

        <Panel Margin="7,0" DockPanel.Dock="Top">
            <Image
                Width="14"
                Height="14"
                Margin="15,0,0,0"
                HorizontalAlignment="Left"
                Source="{StaticResource SearchImage}" />

            <TextBox
                x:Name="FilterBox"
                Padding="50,7,4,7"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderBrush="{DynamicResource MainBorderColor}"
                BorderThickness="1"
                CornerRadius="4"
                FontFamily="/Assets/Fonts/Roboto-Regular.ttf#Roboto"
                Foreground="{DynamicResource MainTextColor}"
                Text="{CompiledBinding Keybindings.FilterText.Value,
                                       FallbackValue='',
                                       Mode=TwoWay}"
                Watermark="{CompiledBinding Translation.Filter.Value,
                                            Mode=OneWay}" />

            <!--  clear  -->
            <customControls:IconButton
                x:Name="ClearButton"
                Padding="10,3,10,3"
                HorizontalAlignment="Right"
                Classes="altHover"
                Command="{CompiledBinding Keybindings.ClearFilteringCommand}"
                Data="{StaticResource CloseGeometry}"
                Foreground="{DynamicResource MainTextColorFaded}"
                IconHeight="12"
                IconWidth="12"
                IsVisible="{CompiledBinding Keybindings.FilterText.Value,
                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </Panel>

        <customControls:AutoScrollViewer>

            <StackPanel>

                <!--  Search  -->
                <ItemsControl IsVisible="{CompiledBinding Keybindings.IsFiltering.Value}" ItemsSource="{CompiledBinding Keybindings.FilteredKeys.Value}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="15,10,10,10" Orientation="Horizontal">
                                <TextBlock
                                    Width="170"
                                    Classes="txt"
                                    FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                                    Text="{CompiledBinding FriendlyMethodName}" />
                                <customControls:KeybindTextBox
                                    Width="140"
                                    Alt="False"
                                    Classes="hover TStyle"
                                    IsReadOnly="{CompiledBinding IsReadOnly,
                                                                 Mode=OneTime}"
                                    MethodName="{CompiledBinding MethodName}"
                                    Text="{CompiledBinding Key,
                                                           Mode=OneTime}"
                                    ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                  Mode=OneWay}" />
                                <customControls:KeybindTextBox
                                    Width="140"
                                    Alt="True"
                                    Classes="hover TStyle"
                                    IsReadOnly="{CompiledBinding IsReadOnly,
                                                                 Mode=OneTime}"
                                    MethodName="{CompiledBinding MethodName}"
                                    Text="{CompiledBinding AltKey,
                                                           Mode=OneTime}"
                                    ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                  Mode=OneWay}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!--  Description  -->
                <StackPanel
                    x:Name="MainPanel"
                    Margin="5,0,2,25"
                    IsVisible="{CompiledBinding !Keybindings.IsFiltering.Value}">
                    <TextBlock
                        x:Name="ApplicationShortcutsTextBlock"
                        Margin="10,20,10,15"
                        Classes="txt"
                        FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                        FontSize="16"
                        Text="{CompiledBinding Translation.ApplicationShortcuts.Value,
                                               Mode=OneWay}"
                        TextAlignment="Center" />
                    <TextBlock
                        x:Name="ChangeKeybindingTextBlock"
                        Classes="txt"
                        FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                        Text="{CompiledBinding Translation.ChangeKeybindingText.Value,
                                               Mode=OneWay}"
                        TextAlignment="Center" />
                    <Button
                        x:Name="DefaultButton"
                        Margin="0,15,0,25"
                        HorizontalAlignment="Center"
                        Classes="BorderStyle altHover mainBtn"
                        Command="{CompiledBinding Keybindings.ResetKeybindingsCommand}">
                        <TextBlock Classes="txt" Text="{CompiledBinding Translation.ResetButtonText.Value, Mode=OneWay}" />
                    </Button>

                    <!--  Navigation  -->
                    <TextBlock
                        Margin="10,10,10,15"
                        Classes="txt bold"
                        Text="{CompiledBinding Translation.Navigation.Value,
                                               Mode=OneWay}"
                        TextAlignment="Center" />
                    <ItemsControl ItemsSource="{CompiledBinding Keybindings.NavigationKeys.Value}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="15,0,10,10" Orientation="Horizontal">
                                    <TextBlock
                                        Width="170"
                                        Classes="txt"
                                        FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                                        Text="{CompiledBinding FriendlyMethodName}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="False"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding Key,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="True"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding AltKey,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  Scroll and rotate  -->
                    <TextBlock
                        Margin="10,10,10,15"
                        Classes="txt bold"
                        Text="{CompiledBinding Translation.ScrollAndRotate.Value,
                                               Mode=OneWay}"
                        TextAlignment="Center" />
                    <ItemsControl ItemsSource="{CompiledBinding Keybindings.ScrollAndRotateKeys.Value}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="15,0,10,10" Orientation="Horizontal">
                                    <TextBlock
                                        Width="170"
                                        Classes="txt"
                                        FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                                        Text="{CompiledBinding FriendlyMethodName}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="False"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding Key,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="True"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding AltKey,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  Zoom  -->
                    <TextBlock
                        Margin="10,10,10,15"
                        Classes="txt bold"
                        Text="{CompiledBinding Translation.Zoom.Value,
                                               Mode=OneWay}"
                        TextAlignment="Center" />
                    <ItemsControl ItemsSource="{CompiledBinding Keybindings.ZoomKeys.Value}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="15,0,10,10" Orientation="Horizontal">
                                    <TextBlock
                                        Width="170"
                                        Classes="txt"
                                        FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                                        Text="{CompiledBinding FriendlyMethodName}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="False"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding Key,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="True"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding AltKey,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  Image control  -->
                    <TextBlock
                        Margin="10,10,10,15"
                        Classes="txt bold"
                        Text="{CompiledBinding Translation.ImageControl.Value,
                                               Mode=OneWay}"
                        TextAlignment="Center" />
                    <ItemsControl ItemsSource="{CompiledBinding Keybindings.ImageControlKeys.Value}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="15,0,10,10" Orientation="Horizontal">
                                    <TextBlock
                                        Width="170"
                                        Classes="txt"
                                        FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                                        Text="{CompiledBinding FriendlyMethodName}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="False"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding Key,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="True"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding AltKey,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  Interface configuration  -->
                    <TextBlock
                        Margin="10,10,10,15"
                        Classes="txt bold"
                        Text="{CompiledBinding Translation.InterfaceConfiguration.Value,
                                               Mode=OneWay}"
                        TextAlignment="Center" />
                    <ItemsControl ItemsSource="{CompiledBinding Keybindings.InterfaceConfigurationKeys.Value}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="15,0,10,10" Orientation="Horizontal">
                                    <TextBlock
                                        Width="170"
                                        Classes="txt"
                                        FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                                        Text="{CompiledBinding FriendlyMethodName}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="False"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding Key,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="True"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding AltKey,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  File management  -->
                    <TextBlock
                        Margin="10,10,10,15"
                        Classes="txt bold"
                        Text="{CompiledBinding Translation.FileManagement.Value,
                                               Mode=OneWay}"
                        TextAlignment="Center" />
                    <ItemsControl ItemsSource="{CompiledBinding Keybindings.FileManagementKeys.Value}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="15,0,10,10" Orientation="Horizontal">
                                    <TextBlock
                                        Width="170"
                                        Classes="txt"
                                        FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                                        Text="{CompiledBinding FriendlyMethodName}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="False"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding Key,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="True"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding AltKey,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  Sort files by  -->
                    <TextBlock
                        Margin="10,10,10,15"
                        Classes="txt bold"
                        Text="{CompiledBinding Translation.SortFilesBy.Value,
                                               Mode=OneWay}"
                        TextAlignment="Center" />
                    <ItemsControl ItemsSource="{CompiledBinding Keybindings.SortFilesKeys.Value}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="15,0,10,10" Orientation="Horizontal">
                                    <TextBlock
                                        Width="170"
                                        Classes="txt"
                                        FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                                        Text="{CompiledBinding FriendlyMethodName}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="False"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding Key,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="True"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding AltKey,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>


                    <!--  Copy  -->
                    <TextBlock
                        Margin="10,10,10,15"
                        Classes="txt bold"
                        Text="{CompiledBinding Translation.Copy.Value,
                                               Mode=OneWay}"
                        TextAlignment="Center" />
                    <ItemsControl ItemsSource="{CompiledBinding Keybindings.CopyKeys.Value}">
                        <ItemsControl.ItemTemplate>
