                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding Key,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                    <customControls:KeybindTextBox
                                        Width="140"
                                        Alt="True"
                                        Classes="hover TStyle"
                                        IsReadOnly="{CompiledBinding IsReadOnly,
                                                                     Mode=OneTime}"
                                        MethodName="{CompiledBinding MethodName}"
                                        Text="{CompiledBinding AltKey,
                                                               Mode=OneTime}"
                                        ToolTip.Tip="{CompiledBinding #MainPanel.((viewModels:CoreViewModel)DataContext).Translation.ChangeKeybindingTooltip.Value,
                                                                      Mode=OneWay}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  Window management  -->
                    <TextBlock
                        Margin="10,10,10,15"
                        Classes="txt"
                        FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                        FontSize="14"
                        Text="{CompiledBinding Translation.WindowManagement.Value,
                                               Mode=OneWay}"
                        TextAlignment="Center" />
                    <ItemsControl ItemsSource="{CompiledBinding Keybindings.WindowManagementKeys.Value}">
