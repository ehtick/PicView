                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Exif version  -->
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Margin="10" Orientation="Horizontal">
                                    <TextBlock
                                        Classes="txt"
                                        Margin="0,8,2,0"
                                        Text="{CompiledBinding Translation.ExifVersion.Value,
                                                               Mode=OneWay}"
                                        Width="{CompiledBinding InfoWindow.TextWidth}" />
                                    <customControls:FuncTextBox
                                        Classes=" TStyle x"
                                        Text="{CompiledBinding Exif.ExifVersion.Value,
                                                               Mode=TwoWay}"
                                        Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                        x:Name="ExifVersionBox" />
                                    <customControls:CopyButton
                                        Classes="altHover BorderStyle"
                                        CopyText="{CompiledBinding Exif.ExifVersion.Value,
                                                                   Mode=TwoWay}"
                                        IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                        ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                      Mode=OneWay}">
                                        <Path Classes="CopyPath" />
                                    </customControls:CopyButton>
                                </StackPanel>
                            </StackPanel>

                        </WrapPanel>
                    </StackPanel>
                </StackPanel>
            </Panel>
        </customControls:AutoScrollViewer>
    </Panel>
</UserControl>