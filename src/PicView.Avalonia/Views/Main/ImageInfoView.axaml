<UserControl
    x:Class="PicView.Avalonia.Views.Main.ImageInfoView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:coreVm="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:uc="clr-namespace:PicView.Avalonia.Views.UC"
    x:DataType="coreVm:MainWindowViewModel"
    Background="Transparent"
    Foreground="{StaticResource SecondaryTextColor}">
    <UserControl.Styles>
        <Styles>
            <Style Selector="TextBox.x, ComboBox.x">
                <Setter Property="Foreground" Value="{DynamicResource MainTextColor}" />
                <Setter Property="MaxHeight" Value="80" />
            </Style>
            <Style Selector="TextBox.x">
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
        </Styles>
    </UserControl.Styles>
    <UserControl.ContextMenu>
        <ContextMenu x:Name="MainContextMenu">

            <!--  Save  -->
            <MenuItem
                Command="{CompiledBinding SaveCommand}"
                Header="{CompiledBinding Translation.Save.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Path Classes="SavePath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Save as  -->
            <MenuItem
                Command="{CompiledBinding SaveAsCommand}"
                Header="{CompiledBinding Translation.SaveAs.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Path Classes="SavePath" />
                </MenuItem.Icon>
            </MenuItem>


            <!--  Print  -->
            <MenuItem
                x:Name="PrintMenuItem"
                Command="{CompiledBinding PrintCommand}"
                Header="{CompiledBinding Translation.Print.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Path Classes="PrintPath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Open with  -->
            <MenuItem
                x:Name="OpenWithMenuItem"
                Command="{CompiledBinding OpenWithCommand}"
                Header="{CompiledBinding Translation.OpenWith.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Image Classes="OpenWithImage" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Locate on disk  -->
            <MenuItem
                Command="{CompiledBinding OpenInExplorerCommand}"
                Header="{CompiledBinding Translation.ShowInFolder.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Path Classes="ShowInFolderPath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Remove image data  -->
            <MenuItem
                x:Name="RemoveImageDataMenuItem"
                Header="{CompiledBinding Translation.RemoveImageData.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource OffImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Set as wallpaper  -->
            <MenuItem
                x:Name="WallpaperMenuItem"
                Header="{CompiledBinding Translation.SetAsWallpaper.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}"
                IsVisible="{CompiledBinding GlobalSettings.ShowSetAsWallpaper.Value}">
                <MenuItem.Icon>
                    <Path
                        Width="13"
                        Height="10.40"
                        Data="{StaticResource PanoramaGeometry}"
                        Fill="{DynamicResource MainTextColor}"
                        Stretch="Fill" />
                </MenuItem.Icon>

                <!--  Set as wallpaper filled  -->
                <MenuItem
                    Command="{CompiledBinding SetAsWallpaperFilledCommand}"
                    Header="{CompiledBinding Translation.Fill.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False}"
                    IsVisible="{CompiledBinding GlobalSettings.ShowSetAsWallpaper.Value}">
                    <MenuItem.Icon>
                        <Path
                            Width="13"
                            Height="10.40"
                            Data="{StaticResource PanoramaGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Stretch="Fill" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Set as wallpaper fit  -->
                <MenuItem
                    Command="{CompiledBinding SetAsWallpaperFittedCommand}"
                    Header="{CompiledBinding Translation.Fit.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False}"
                    IsVisible="{CompiledBinding GlobalSettings.ShowSetAsWallpaper.Value}">
                    <MenuItem.Icon>
                        <Path
                            Width="13"
                            Height="10.40"
                            Data="{StaticResource PanoramaGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Stretch="Fill" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Set as wallpaper stretched  -->
                <MenuItem
                    Command="{CompiledBinding SetAsWallpaperStretchedCommand}"
                    Header="{CompiledBinding Translation.Stretch.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False}"
                    IsVisible="{CompiledBinding GlobalSettings.ShowSetAsWallpaper.Value}">
                    <MenuItem.Icon>
                        <Path
                            Width="13"
                            Height="10.40"
                            Data="{StaticResource PanoramaGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Stretch="Fill" />
                    </MenuItem.Icon>
                </MenuItem>


                <!--  Set as wallpaper centered  -->
                <MenuItem
                    Command="{CompiledBinding SetAsWallpaperCenteredCommand}"
                    Header="{CompiledBinding Translation.Center.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False}"
                    IsVisible="{CompiledBinding GlobalSettings.ShowSetAsWallpaper.Value}">
                    <MenuItem.Icon>
                        <Path
                            Width="13"
                            Height="10.40"
                            Data="{StaticResource PanoramaGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Stretch="Fill" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Set as wallpaper tiled  -->
                <MenuItem
                    Command="{CompiledBinding SetAsWallpaperTiledCommand}"
                    Header="{CompiledBinding Translation.Tile.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False}"
                    IsVisible="{CompiledBinding GlobalSettings.ShowSetAsWallpaper.Value}">
                    <MenuItem.Icon>
                        <Path
                            Width="13"
                            Height="10.40"
                            Data="{StaticResource PanoramaGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Stretch="Fill" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!--  File properties  -->
            <MenuItem
                Command="{CompiledBinding ShowFilePropertiesCommand}"
                Header="{CompiledBinding Translation.FileProperties.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource FileUserImage}"
                        Stretch="Fill" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Optimize image  -->
            <MenuItem
                Command="{CompiledBinding OptimizeImageCommand}"
                Header="{CompiledBinding Translation.OptimizeImage.Value,
                                         Mode=OneWay}"
                IsEnabled="True">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource PortalImage}" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Convert image  -->
            <MenuItem
                Command="{CompiledBinding ConvertWindowCommand}"
                Header="{CompiledBinding Translation.ConvertTo.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Image
                        Width="12"
                        Height="12"
                        Source="{StaticResource FileImage}"
                        Stretch="Fill" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Delete file  -->
            <MenuItem
                Command="{CompiledBinding DeleteFileCommand}"
                Header="{CompiledBinding Translation.DeleteFile.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull},
                                            FallbackValue=False}">
                <MenuItem.Icon>
                    <Path Classes="RecyclePath" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Copy  -->
            <MenuItem Command="{CompiledBinding CopyFileCommand}" Header="{CompiledBinding Translation.Copy.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="CopyPath Xl" />
                </MenuItem.Icon>

                <!--  Copy file  -->
                <MenuItem
                    Command="{CompiledBinding CopyFileCommand}"
                    Header="{CompiledBinding Translation.CopyFile.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False}">
                    <MenuItem.Icon>
                        <Path Classes="CopyPath Xl" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Copy image  -->
                <MenuItem
                    Command="{CompiledBinding CopyImageCommand}"
                    Header="{CompiledBinding Translation.CopyImage.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False}">
                    <MenuItem.Icon>
                        <Path Classes="CopyPath Xl" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Copy file path  -->
                <MenuItem
                    Command="{CompiledBinding CopyFilePathCommand}"
                    Header="{Binding Translation.FileCopyPath, Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False}">
                    <MenuItem.Icon>
                        <Path Classes="CopyPath Xl" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Copy base64  -->
                <MenuItem Command="{CompiledBinding CopyBase64Command}" IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}">
                    <MenuItem.Header>
                        <TextBlock>
                            <Run Text="{CompiledBinding Translation.Copy, Mode=OneWay}" />
                            <Run Text=" base64" />
                        </TextBlock>
                    </MenuItem.Header>
                    <MenuItem.Icon>
                        <Path Classes="CopyPath Xl" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Duplicate file  -->
                <MenuItem
                    Command="{CompiledBinding DuplicateFileCommand}"
                    Header="{CompiledBinding Translation.DuplicateFile,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull},
                                                FallbackValue=False}">
                    <MenuItem.Icon>
                        <Path Classes="DuplicatePath" />
                    </MenuItem.Icon>
                </MenuItem>

            </MenuItem>

            <Separator />

            <!--  Close  -->
            <MenuItem x:Name="CloseItem" Header="{CompiledBinding Translation.Close.Value, Mode=OneWay}">
                <MenuItem.Icon>
                    <Path Classes="ClosePath" />
                </MenuItem.Icon>
            </MenuItem>

        </ContextMenu>
    </UserControl.ContextMenu>

    <Panel>
        <uc:SpinWaiter
            x:Name="SpinWaiter"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsVisible="False" />
        <customControls:AutoScrollViewer
            x:Name="ScrollViewer"
            Background="Transparent"
            Focusable="True"
            VerticalScrollBarVisibility="Visible">

            <Panel x:Name="ParentPanel" Margin="5">

                <StackPanel x:Name="MainContainer">

                    <WrapPanel ItemsAlignment="Center">

                        <!--  File name  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                Width="{CompiledBinding InfoWindow.TextWidth,
                                                        FallbackValue=0}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.FileName.Value,
                                                       Mode=OneWay}" />
                            <customControls:FuncTextBox
                                x:Name="FileNameTextBox"
                                Width="{CompiledBinding InfoWindow.TextBoxXlWidth.Value,
                                                        FallbackValue=0}"
                                Classes="hover TStyle x"
                                Text="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value.Name}" />
                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value,
                                                            FallbackValue=True}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                        <!--  Folder path  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                Width="{CompiledBinding InfoWindow.TextWidth,
                                                        FallbackValue=0}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.Folder.Value,
                                                       Mode=OneWay}" />
                            <customControls:FuncTextBox
                                x:Name="DirectoryNameTextBox"
                                Width="{CompiledBinding InfoWindow.TextBoxXlWidth.Value,
                                                        FallbackValue=0}"
                                Classes="hover TStyle x"
                                Text="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value.DirectoryName,
                                                       FallbackValue=''}" />
                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value.DirectoryName,
                                                           FallbackValue=''}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value,
                                                            FallbackValue=False}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                        <!--  Full path  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                Width="{CompiledBinding InfoWindow.TextWidth,
                                                        FallbackValue='0'}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.FullPath.Value,
                                                       Mode=OneWay}" />
                            <customControls:FuncTextBox
                                x:Name="FullPathTextBox"
                                Width="{CompiledBinding InfoWindow.TextBoxXlWidth.Value}"
                                Classes="hover TStyle x"
                                Text="{CompiledBinding WindowTabs.ActiveTab.Value.Model.FileInfo.FullName,
                                                       FallbackValue=''}" />
                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{CompiledBinding WindowTabs.ActiveTab.Value.Model.FileInfo.FullName,
                                                           FallbackValue=''}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                        <!--  Width  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                Width="{CompiledBinding InfoWindow.TextWidth}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.Width.Value,
                                                       Mode=OneWay}" />
                            <customControls:NumTextBox
                                x:Name="PixelWidthTextBox"
                                Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                Classes="hover TStyle x"
                                Text="{CompiledBinding WindowTabs.ActiveTab.Value.Model.PixelWidth,
                                                       Mode=OneWay}"
                                ToolTip.Tip="{CompiledBinding Translation.SizeTooltip.Value,
                                                              Mode=OneWay}" />
                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{CompiledBinding WindowTabs.ActiveTab.Value.Model.PixelWidth,
                                                           Mode=OneWay}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                        <!--  Height  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                Width="{CompiledBinding InfoWindow.TextWidth}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.Height.Value,
                                                       Mode=OneWay}" />
                            <customControls:NumTextBox
                                x:Name="PixelHeightTextBox"
                                Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                Classes="hover TStyle x"
                                Text="{CompiledBinding WindowTabs.ActiveTab.Value.Model.PixelHeight,
                                                       Mode=OneWay}"
                                ToolTip.Tip="{CompiledBinding Translation.SizeTooltip.Value,
                                                              Mode=OneWay}" />
                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{CompiledBinding WindowTabs.ActiveTab.Value.Model.PixelHeight,
                                                           Mode=OneWay}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                        <!--  Size Mp  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                Width="{CompiledBinding InfoWindow.TextWidth,
                                                        FallbackValue=''}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.SizeMp.Value,
                                                       Mode=OneWay}" />
                            <customControls:FuncTextBox
                                x:Name="SizeMpTextBox"
                                Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                Background="{DynamicResource DisabledBackgroundColor}"
                                Classes=" TStyle x"
                                IsReadOnly="True"
                                Text="{CompiledBinding Exif.SizeMp.Value,
                                                       Mode=OneWay,
                                                       FallbackValue=''}" />
                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{CompiledBinding Exif.SizeMp.Value,
                                                           Mode=OneWay}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                        <!--  Resolution  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                x:Name="ResolutionTextBlock"
                                Width="{CompiledBinding InfoWindow.TextWidth}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.Resolution.Value,
                                                       Mode=OneWay}" />
                            <customControls:FuncTextBox
                                Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                Background="{DynamicResource DisabledBackgroundColor}"
                                Classes=" TStyle x"
                                IsReadOnly="True"
                                Text="{CompiledBinding Exif.Resolution.Value,
                                                       Mode=OneWay}" />
                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{CompiledBinding Exif.Resolution.Value,
                                                           Mode=OneWay}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                        <!--  Print Size Centimeters  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                Width="{CompiledBinding InfoWindow.TextWidth}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.PrintSizeCm.Value,
                                                       Mode=OneWay}" />
                            <customControls:FuncTextBox
                                x:Name="PrintSizeCmTextBox"
                                Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                Background="{DynamicResource DisabledBackgroundColor}"
                                Classes=" TStyle x"
                                IsReadOnly="True"
                                Text="{CompiledBinding Exif.PrintSizeCm.Value,
                                                       Mode=OneWay}" />
                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{CompiledBinding Exif.PrintSizeCm.Value,
                                                           Mode=OneWay}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                        <!--  Print Size Inches  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                Width="{CompiledBinding InfoWindow.TextWidth}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.PrintSizeIn.Value,
                                                       Mode=OneWay}" />
                            <customControls:FuncTextBox
                                x:Name="PrintSizeInchTextBox"
                                Width="{CompiledBinding InfoWindow.TextBoxWidth.Value,
                                                        FallbackValue=0}"
                                Background="{DynamicResource DisabledBackgroundColor}"
                                Classes=" TStyle x"
                                IsReadOnly="True"
                                Text="{CompiledBinding Exif.PrintSizeInch.Value,
                                                       Mode=OneWay,
                                                       FallbackValue=''}" />
                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{CompiledBinding Exif.PrintSizeInch.Value,
                                                           Mode=OneWay,
                                                           FallbackValue=''}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value,
                                                            FallbackValue=False}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                        <!--  Aspect Ratio  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                Width="{CompiledBinding InfoWindow.TextWidth,
                                                        FallbackValue=0}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.ReadAbleAspectRatio.Value,
                                                       Mode=OneWay}" />
                            <customControls:FuncTextBox
                                x:Name="AspectRatioTextBox"
                                Width="{CompiledBinding InfoWindow.TextBoxWidth.Value,
                                                        FallbackValue=0}"
                                Background="{DynamicResource DisabledBackgroundColor}"
                                Classes=" TStyle x"
                                IsReadOnly="True"
                                Text="{CompiledBinding Exif.AspectRatio.Value,
                                                       Mode=OneWay,
                                                       FallbackValue=''}" />
                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{CompiledBinding Exif.AspectRatio.Value,
                                                           Mode=OneWay,
                                                           FallbackValue=''}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value,
                                                            FallbackValue=False}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                        <!--  Bit Depth  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                Width="{CompiledBinding InfoWindow.TextWidth,
                                                        FallbackValue=0}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.BitDepth.Value,
                                                       Mode=OneWay}" />
                            <customControls:FuncTextBox
                                Width="{CompiledBinding InfoWindow.TextBoxWidth.Value,
                                                        FallbackValue=0}"
                                Background="{DynamicResource DisabledBackgroundColor}"
                                Classes="TStyle x"
                                IsReadOnly="True"
                                Text="{CompiledBinding Exif.BitDepth.Value,
                                                       Mode=OneWay,
                                                       FallbackValue=''}" />
                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{CompiledBinding Exif.BitDepth.Value,
                                                           Mode=OneWay,
                                                           FallbackValue=''}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value,
                                                            FallbackValue=False}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                        <!--  Orientation  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                Width="{CompiledBinding InfoWindow.TextWidth,
                                                        FallbackValue=0}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.Orientation.Value,
                                                       Mode=OneWay}" />
                            <ComboBox
                                x:Name="OrientationBox"
                                Width="{CompiledBinding InfoWindow.TextBoxWidth.Value,
                                                        FallbackValue=0}"
                                MinWidth="180"
                                Margin="5,0,0,0"
                                Background="{DynamicResource DisabledBackgroundColor}"
                                Classes="CStyle x"
                                ItemsSource="{CompiledBinding Exif.Orientations.Value,
                                                              Mode=OneWay,
                                                              FallbackValue=''}"
                                SelectedIndex="{CompiledBinding Exif.Orientation.Value,
                                                                Mode=OneWay,
                                                                FallbackValue=0}" />
                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{CompiledBinding Exif.Orientation.Value,
                                                           Mode=OneWay,
                                                           FallbackValue=''}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value,
                                                            FallbackValue=False}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                        <!--  Image Format  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                Width="{CompiledBinding InfoWindow.TextWidth,
                                                        FallbackValue=''}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.ImageFormat.Value}" />
                            <customControls:FuncTextBox
                                Width="{CompiledBinding InfoWindow.TextBoxWidth.Value,
                                                        FallbackValue=''}"
                                Background="{DynamicResource DisabledBackgroundColor}"
                                Classes="TStyle x"
                                IsReadOnly="True"
                                Text="{CompiledBinding Exif.ImageFormat.Value,
                                                       Mode=OneWay}" />
                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{CompiledBinding Exif.ImageFormat.Value,
                                                           Mode=OneWay}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value,
                                                            FallbackValue=''}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                        <!--  File Size  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                Width="{CompiledBinding InfoWindow.TextWidth}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.FileSize.Value,
                                                       Mode=OneWay}" />
                            <customControls:FuncTextBox
                                x:Name="FileSizeBox"
                                Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                Background="{DynamicResource DisabledBackgroundColor}"
                                Classes="TStyle x"
                                IsReadOnly="True" />
                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{Binding Path=Text, ElementName=FileSizeBox}"
                                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                            Converter={x:Static ObjectConverters.IsNotNull}}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                        <!--  Created  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                Width="{CompiledBinding InfoWindow.TextWidth,
                                                        FallbackValue=0}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.Created.Value,
                                                       Mode=OneWay}" />
                            <customControls:DateTimePickerButtons
                                Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                Margin="5,0,0,0"
                                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                            Converter={x:Static ObjectConverters.IsNotNull}}"
                                SelectedDateTime="{CompiledBinding WindowTabs.ActiveTab.Value.Model.FileInfo.CreationTime,
                                                                   Mode=TwoWay,
                                                                   FallbackValue=''}" />

                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{CompiledBinding WindowTabs.ActiveTab.Value.Model.FileInfo.CreationTime,
                                                           FallbackValue=''}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                        <!--  Modified  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                Width="{CompiledBinding InfoWindow.TextWidth}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.Modified.Value,
                                                       Mode=OneWay}" />
                            <customControls:DateTimePickerButtons
                                Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                Margin="5,0,0,0"
                                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                            Converter={x:Static ObjectConverters.IsNotNull}}"
                                SelectedDateTime="{CompiledBinding WindowTabs.ActiveTab.Value.Model.FileInfo.LastWriteTime,
                                                                   Mode=TwoWay,
                                                                   FallbackValue=''}" />
                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{CompiledBinding WindowTabs.ActiveTab.Value.Model.FileInfo.LastWriteTime,
                                                           FallbackValue=''}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                        <!--  Last Accessed  -->
                        <StackPanel Margin="15,10" Orientation="Horizontal">
                            <TextBlock
                                Width="{CompiledBinding InfoWindow.TextWidth}"
                                Margin="0,8,0,0"
                                Classes="txt"
                                Text="{CompiledBinding Translation.LastAccessTime.Value,
                                                       Mode=OneWay}" />
                            <customControls:DateTimePickerButtons
                                Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                Margin="5,0,0,0"
                                IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                            Converter={x:Static ObjectConverters.IsNotNull}}"
                                SelectedDateTime="{CompiledBinding WindowTabs.ActiveTab.Value.Model.FileInfo.LastAccessTime,
                                                                   Mode=TwoWay,
                                                                   FallbackValue=''}" />

                            <customControls:CopyButton
                                Classes="altHover BorderStyle"
                                CopyText="{CompiledBinding WindowTabs.ActiveTab.Value.Model.FileInfo.LastAccessTime,
                                                           FallbackValue=''}"
                                IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                              Mode=OneWay}">
                                <Path Classes="CopyPath Xl" />
                            </customControls:CopyButton>
                        </StackPanel>

                    </WrapPanel>

                    <!--  Copyright, comment, etc.  -->
                    <StackPanel IsEnabled="{CompiledBinding Exif.IsExifAvailable.Value}">

                        <StackPanel
                            Height="20"
                            Margin="15,20"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                            <Rectangle
                                Width="{CompiledBinding InfoWindow.HalfLineWidth.Value,
                                                        FallbackValue=0}"
                                Height="1"
                                Margin="0,0,7,0"
                                Fill="{DynamicResource MainBorderColor}" />
                            <Path
                                Data="{StaticResource AtGeometry}"
                                Fill="{DynamicResource MainTextColor}"
                                Stretch="Uniform" />
                            <Rectangle
                                Width="{CompiledBinding InfoWindow.HalfLineWidth.Value,
                                                        FallbackValue=0}"
                                Height="1"
                                Margin="7,0,0,0"
                                Fill="{DynamicResource MainBorderColor}" />
                        </StackPanel>

                        <WrapPanel Margin="5,10,0,0" HorizontalAlignment="Center">

                            <!--  Date taken  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Width="{CompiledBinding InfoWindow.TextWidth,
                                                            FallbackValue=0}"
                                    Margin="0,8,2,0"
                                    Classes="txt"
                                    Text="{CompiledBinding Translation.DateTaken.Value,
                                                           Mode=OneWay}" />
                                <customControls:DateTimePickerButtons
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value,
                                                            FallbackValue=0}"
                                    Margin="5,0,0,0"
                                    Command="{CompiledBinding Exif.SetDateTakenCommand}"
                                    SelectedDateTime="{CompiledBinding Exif.DateTaken.Value,
                                                                       Mode=TwoWay,
                                                                       FallbackValue=''}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.DateTaken.Value,
                                                               Mode=OneWay,
                                                               FallbackValue=''}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value,
                                                                FallbackValue=False}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath Xl" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Authors  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Width="{CompiledBinding InfoWindow.TextWidth}"
                                    Margin="0,8,2,0"
                                    Classes="txt"
                                    Text="{CompiledBinding Translation.Authors.Value,
                                                           Mode=OneWay}" />
                                <customControls:FuncTextBox
                                    x:Name="AuthorsBox"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    Classes=" TStyle x"
                                    Command="{CompiledBinding Exif.SetAuthorsCommand}"
                                    CommandParameter="{Binding $self.Text}"
                                    Text="{CompiledBinding Exif.Authors.Value,
                                                           Mode=TwoWay}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Authors.Value,
                                                               Mode=TwoWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath Xl" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Copyright  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Width="{CompiledBinding InfoWindow.TextWidth}"
                                    Margin="0,8,2,0"
                                    Classes="txt"
                                    Text="{CompiledBinding Translation.Copyright.Value,
                                                           Mode=OneWay}" />
                                <customControls:FuncTextBox
                                    x:Name="CopyRightBox"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    Classes=" TStyle x"
                                    Command="{CompiledBinding Exif.SetCopyrightCommand}"
                                    CommandParameter="{Binding $self.Text}"
                                    Text="{CompiledBinding Exif.Copyright.Value,
                                                           Mode=TwoWay}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Copyright.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath Xl" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Software  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Width="{CompiledBinding InfoWindow.TextWidth}"
                                    Margin="0,8,2,0"
                                    Classes="txt"
                                    Text="{CompiledBinding Translation.Software.Value,
                                                           Mode=OneWay}" />
                                <customControls:FuncTextBox
                                    x:Name="SoftwareBox"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    Classes="TStyle x"
                                    Command="{CompiledBinding Exif.SetSoftwareCommand}"
                                    CommandParameter="{Binding $self.Text}"
                                    Text="{CompiledBinding Exif.Software.Value,
                                                           Mode=TwoWay}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Software.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath Xl" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Subject  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Width="{CompiledBinding InfoWindow.TextWidth}"
                                    Margin="0,8,2,0"
                                    Classes="txt"
                                    Text="{CompiledBinding Translation.Subject.Value,
                                                           Mode=OneWay}" />
                                <customControls:FuncTextBox
                                    x:Name="SubjectBox"
                                    Width="{CompiledBinding InfoWindow.TextBoxXxlWidth.Value}"
                                    Classes=" TStyle x"
                                    Command="{CompiledBinding Exif.SetSubjectCommand}"
                                    CommandParameter="{Binding $self.Text}"
                                    Text="{CompiledBinding Exif.Subject.Value,
                                                           Mode=TwoWay}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Subject.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath Xl" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Title  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Width="{CompiledBinding InfoWindow.TextWidth}"
                                    Margin="0,8,2,0"
                                    Classes="txt"
                                    Text="{CompiledBinding Translation.Title.Value,
                                                           Mode=OneWay}" />
                                <customControls:FuncTextBox
                                    x:Name="TitleBox"
                                    Width="{CompiledBinding InfoWindow.TextBoxXxlWidth.Value}"
                                    Classes=" TStyle x"
                                    Command="{CompiledBinding Exif.SetTitleCommand}"
                                    CommandParameter="{Binding $self.Text}"
                                    Text="{CompiledBinding Exif.Title.Value,
                                                           Mode=TwoWay}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Title.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath Xl" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Comment  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Width="{CompiledBinding InfoWindow.TextWidth}"
                                    Margin="0,8,2,0"
                                    Classes="txt"
                                    Text="Comment" />
                                <customControls:FuncTextBox
                                    x:Name="CommentBox"
                                    Width="{CompiledBinding InfoWindow.TextBoxXxlWidth.Value}"
                                    MaxHeight="600"
                                    Classes=" TStyle x"
                                    Command="{CompiledBinding Exif.SetCommentCommand}"
                                    CommandParameter="{Binding $self.Text}"
                                    Text="{CompiledBinding Exif.Comment.Value,
                                                           Mode=TwoWay}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Comment.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath Xl" />
                                </customControls:CopyButton>
                            </StackPanel>
                        </WrapPanel>

                    </StackPanel>

                    <!--  Gps  -->
                    <StackPanel IsEnabled="{CompiledBinding Exif.IsExifAvailable.Value}">
                        <StackPanel
                            Height="20"
                            Margin="15,20"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                            <Rectangle
                                Width="{CompiledBinding InfoWindow.HalfLineWidth.Value}"
                                Height="1"
                                Margin="0,0,7,0"
                                Fill="{DynamicResource MainBorderColor}" />
                            <Path
                                Data="{StaticResource GpsGeometry}"
                                Fill="{DynamicResource MainTextColor}"
                                Stretch="Uniform" />
                            <Rectangle
                                Width="{CompiledBinding InfoWindow.HalfLineWidth.Value}"
                                Height="1"
                                Margin="7,0,0,0"
                                Fill="{DynamicResource MainBorderColor}" />
                        </StackPanel>

                        <WrapPanel Margin="5,10,0,0" HorizontalAlignment="Center">

                            <!--  Latitude  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Width="{CompiledBinding InfoWindow.TextWidth}"
                                    Margin="0,8,2,0"
                                    Classes="txt"
                                    Text="{CompiledBinding Translation.Latitude.Value,
                                                           Mode=OneWay}" />
                                <customControls:FuncTextBox
                                    x:Name="LatitudeBox"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes=" TStyle x"
                                    Command="{CompiledBinding Exif.SetLatitudeCommand}"
                                    CommandParameter="{Binding $self.Text}"
                                    IsReadOnly="True"
                                    Text="{CompiledBinding Exif.Latitude.Value,
                                                           Mode=TwoWay}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Latitude.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath Xl" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Longitude  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Width="{CompiledBinding InfoWindow.TextWidth}"
                                    Margin="0,8,2,0"
                                    Classes="txt"
                                    Text="{CompiledBinding Translation.Longitude.Value,
                                                           Mode=OneWay}" />
                                <customControls:FuncTextBox
                                    x:Name="LongitudeBox"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes=" TStyle x"
                                    Command="{CompiledBinding Exif.SetLongitudeCommand}"
                                    CommandParameter="{Binding $self.Text}"
                                    IsReadOnly="True"
                                    Text="{CompiledBinding Exif.Longitude.Value,
                                                           Mode=TwoWay}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Longitude.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath Xl" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Altitude  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Width="{CompiledBinding InfoWindow.TextWidth}"
                                    Margin="0,8,2,0"
                                    Classes="txt"
                                    Text="{CompiledBinding Translation.Altitude,
                                                           Mode=OneWay}" />
                                <customControls:FuncTextBox
                                    x:Name="AltitudeBox"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes=" TStyle x"
                                    Command="{CompiledBinding Exif.SetAltitudeCommand}"
                                    CommandParameter="{Binding $self.Text}"
                                    IsReadOnly="True"
                                    Text="{CompiledBinding Exif.Altitude.Value,
                                                           Mode=TwoWay}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Altitude.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath Xl" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Map link buttons  -->
                            <StackPanel Margin="0,5" Orientation="Horizontal">
                                <Button
                                    x:Name="GoogleLinkButton"
                                    Margin="117,0,15,0"
                                    Classes="altHover BorderStyle"
                                    Command="{CompiledBinding Exif.OpenGoogleLinkCommand,
                                                              Mode=OneWay}">
                                    <Path
                                        Width="20"
                                        Height="20"
                                        Data="{StaticResource GoogleGeometry}"
                                        Fill="{DynamicResource MainTextColor}"
                                        Stretch="Fill" />
                                </Button>
                                <Button
                                    x:Name="BingLinkButton"
                                    Classes="altHover BorderStyle"
                                    Command="{CompiledBinding Exif.OpenBingLinkCommand,
                                                              Mode=OneWay}">
                                    <Path
                                        Width="20"
                                        Height="20"
                                        Data="{StaticResource BingGeometry}"
                                        Fill="{DynamicResource MainTextColor}"
                                        Stretch="Fill" />
                                </Button>

                            </StackPanel>
                        </WrapPanel>

                    </StackPanel>

                    <!--  Color  -->
                    <StackPanel IsEnabled="{CompiledBinding Exif.IsExifAvailable.Value}">
                        <StackPanel
                            Height="20"
                            Margin="15,20"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                            <Rectangle
                                Width="{CompiledBinding InfoWindow.HalfLineWidth.Value}"
                                Height="1"
                                Margin="0,0,7,0"
                                Fill="{DynamicResource MainBorderColor}" />
                            <Image Source="{StaticResource PaletteImage}" />
                            <Rectangle
                                Width="{CompiledBinding InfoWindow.HalfLineWidth.Value}"
                                Height="1"
                                Margin="7,0,0,0"
                                Fill="{DynamicResource MainBorderColor}" />
                        </StackPanel>

                        <WrapPanel Margin="5,10,0,0" HorizontalAlignment="Center">

                            <!--  Color representation  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Width="{CompiledBinding InfoWindow.TextWidth}"
                                    Margin="0,8,2,0"
                                    Classes="txt"
                                    Text="{CompiledBinding Translation.ColorRepresentation.Value,
                                                           Mode=OneWay}" />
                                <ComboBox
                                    x:Name="ColorRepresentationBox"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    MinWidth="180"
                                    Margin="5,0,0,0"
                                    Padding="5,7,1,7"
                                    Classes="CStyle x"
                                    CornerRadius="2"
                                    ItemsSource="{CompiledBinding Exif.ColorRepresentations.Value}"
                                    SelectedIndex="{CompiledBinding Exif.ColorRepresentation.Value,
                                                                    Mode=TwoWay}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.ColorRepresentation.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath Xl" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Resolution unit  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Width="{CompiledBinding InfoWindow.TextWidth}"
                                    Margin="0,8,2,0"
                                    Classes="txt"
                                    Text="{CompiledBinding Translation.ResolutionUnit.Value,
                                                           Mode=OneWay}" />
                                <ComboBox
                                    x:Name="ResolutionUnitBox"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    MinWidth="180"
                                    Margin="5,0,0,0"
                                    Padding="5,7,1,7"
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes="CStyle x"
                                    CornerRadius="2"
                                    ItemsSource="{CompiledBinding Exif.ResolutionUnits.Value}"
                                    SelectedIndex="{CompiledBinding Exif.ResolutionUnit.Value,
                                                                    Mode=OneWay}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{Binding #ResolutionUnitBox.SelectedItem}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath Xl" />
                                </customControls:CopyButton>

                            </StackPanel>

                            <!--  Compression  -->
