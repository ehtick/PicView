<UserControl
    Background="Transparent"
    Foreground="{StaticResource SecondaryTextColor}"
    mc:Ignorable="d"
    x:Class="PicView.Avalonia.Views.Main.ImageInfoView"
    x:DataType="vm:MainViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:PicView.Avalonia.Views.UC"
    xmlns:vm="clr-namespace:PicView.Avalonia.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>
    <UserControl.Styles>
        <Styles>
            <Style Selector="TextBox.x, ComboBox.x">
                <Setter Property="Foreground" Value="{DynamicResource MainTextColor}" />
                <Setter Property="MaxHeight" Value="80" />
            </Style>
            <Style Selector="TextBox.x">
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
        </Styles>
    </UserControl.Styles>
    <UserControl.ContextMenu>
        <ContextMenu x:Name="MainContextMenu">

            <!--  Save  -->
            <MenuItem
                Command="{CompiledBinding Tools.SaveFileCommand}"
                Header="{CompiledBinding Translation.Save.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding PicViewer.ImageSource.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull}}">
                <MenuItem.Icon>
                    <Path Classes="SavePath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Save as  -->
            <MenuItem
                Command="{CompiledBinding Tools.SaveFileAsCommand}"
                Header="{CompiledBinding Translation.SaveAs.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding PicViewer.ImageSource.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull}}">
                <MenuItem.Icon>
                    <Path Classes="SavePath" />
                </MenuItem.Icon>
            </MenuItem>


            <!--  Print  -->
            <MenuItem
                Command="{CompiledBinding Tools.PrintCommand}"
                CommandParameter="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                   FallbackValue=''}"
                Header="{CompiledBinding Translation.Print.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding PicViewer.ImageSource.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull}}"
                x:Name="PrintMenuItem">
                <MenuItem.Icon>
                    <Path Classes="PrintPath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Open with  -->
            <MenuItem
                Command="{CompiledBinding Tools.OpenWithCommand}"
                CommandParameter="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                   FallbackValue=''}"
                Header="{CompiledBinding Translation.OpenWith.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding PicViewer.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull}}"
                x:Name="OpenWithMenuItem">
                <MenuItem.Icon>
                    <Image Classes="OpenWithImage" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Locate on disk  -->
            <MenuItem
                Command="{CompiledBinding Tools.LocateOnDiskCommand}"
                CommandParameter="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                   FallbackValue=''}"
                Header="{CompiledBinding Translation.ShowInFolder.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding PicViewer.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull}}">
                <MenuItem.Icon>
                    <Path Classes="ShowInFolderPath" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Remove image data  -->
            <MenuItem
                Header="{CompiledBinding Translation.RemoveImageData.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding PicViewer.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull}}"
                x:Name="RemoveImageDataMenuItem">
                <MenuItem.Icon>
                    <Image
                        Height="12"
                        Source="{StaticResource OffImage}"
                        Width="12" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Set as wallpaper  -->
            <MenuItem
                Header="{CompiledBinding Translation.SetAsWallpaper.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding PicViewer.ImageSource.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull}}"
                x:Name="WallpaperMenuItem">
                <MenuItem.Icon>
                    <Path
                        Data="{StaticResource PanoramaGeometry}"
                        Fill="{DynamicResource MainTextColor}"
                        Height="10.40"
                        Stretch="Fill"
                        Width="13" />
                </MenuItem.Icon>

                <!--  Set as wallpaper filled  -->
                <MenuItem
                    Command="{CompiledBinding Tools.SetAsWallpaperFilledCommand}"
                    CommandParameter="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                       FallbackValue=''}"
                    Header="{CompiledBinding Translation.Fill.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding PicViewer.ImageSource.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull}}">
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource PanoramaGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="10.40"
                            Stretch="Fill"
                            Width="13" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Set as wallpaper fit  -->
                <MenuItem
                    Command="{CompiledBinding Tools.SetAsWallpaperFittedCommand}"
                    CommandParameter="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                       FallbackValue=''}"
                    Header="{CompiledBinding Translation.Fit.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding PicViewer.ImageSource.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull}}">
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource PanoramaGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="10.40"
                            Stretch="Fill"
                            Width="13" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Set as wallpaper stretched  -->
                <MenuItem
                    Command="{CompiledBinding Tools.SetAsWallpaperStretchedCommand}"
                    CommandParameter="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                       FallbackValue=''}"
                    Header="{CompiledBinding Translation.Stretch.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding PicViewer.ImageSource.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull}}">
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource PanoramaGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="10.40"
                            Stretch="Fill"
                            Width="13" />
                    </MenuItem.Icon>
                </MenuItem>


                <!--  Set as wallpaper centered  -->
                <MenuItem
                    Command="{CompiledBinding Tools.SetAsWallpaperCenteredCommand}"
                    CommandParameter="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                       FallbackValue=''}"
                    Header="{CompiledBinding Translation.Center.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding PicViewer.ImageSource.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull}}">
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource PanoramaGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="10.40"
                            Stretch="Fill"
                            Width="13" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Set as wallpaper tiled  -->
                <MenuItem
                    Command="{CompiledBinding Tools.SetAsWallpaperTiledCommand}"
                    CommandParameter="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                       FallbackValue=''}"
                    Header="{CompiledBinding Translation.Tile.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding PicViewer.ImageSource.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull}}">
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource PanoramaGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="10.40"
                            Stretch="Fill"
                            Width="13" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!--  File properties  -->
            <MenuItem
                Command="{CompiledBinding Tools.FilePropertiesCommand}"
                CommandParameter="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                   FallbackValue=''}"
                Header="{CompiledBinding Translation.FileProperties.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding PicViewer.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull}}">
                <MenuItem.Icon>
                    <Image
                        Height="12"
                        Source="{StaticResource FileUserImage}"
                        Stretch="Fill"
                        Width="12" />
                </MenuItem.Icon>
            </MenuItem>

            <!--  Optimize image  -->
            <MenuItem
                Command="{CompiledBinding Tools.OptimizeImageCommand}"
                Header="{CompiledBinding Translation.OptimizeImage.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding PicViewer.ShouldOptimizeImageBeEnabled.Value,
                                            Mode=OneWay}">
                <MenuItem.Icon>
                    <Image
                        Height="12"
                        Source="{StaticResource PortalImage}"
                        Width="12" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Delete file  -->
            <MenuItem
                Command="{CompiledBinding Tools.RecycleFileCommand}"
                CommandParameter="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                   FallbackValue=''}"
                Header="{CompiledBinding Translation.DeleteFile.Value,
                                         Mode=OneWay}"
                IsEnabled="{CompiledBinding PicViewer.FileInfo.Value,
                                            Converter={x:Static ObjectConverters.IsNotNull}}">
                <MenuItem.Icon>
                    <Path
                        Data="{StaticResource RecycleGeometry}"
                        Fill="{DynamicResource MainTextColor}"
                        Height="12"
                        Stretch="Fill"
                        Width="12" />
                </MenuItem.Icon>
            </MenuItem>

            <Separator />

            <!--  Copy  -->
            <MenuItem
                Command="{CompiledBinding Tools.CopyFileCommand}"
                CommandParameter="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                   FallbackValue=''}"
                Header="{CompiledBinding Translation.Copy.Value,
                                         Mode=OneWay}">
                <MenuItem.Icon>
                    <Path
                        Data="{StaticResource CopyGeometry}"
                        Fill="{DynamicResource MainTextColor}"
                        Height="12"
                        Stretch="Fill"
                        Width="12" />
                </MenuItem.Icon>

                <!--  Copy file  -->
                <MenuItem
                    Command="{CompiledBinding Tools.CopyFileCommand}"
                    CommandParameter="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                       FallbackValue=''}"
                    Header="{CompiledBinding Translation.CopyFile.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding PicViewer.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull}}">
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource CopyGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="12"
                            Stretch="Fill"
                            Width="12" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Copy image  -->
                <MenuItem
                    Command="{CompiledBinding Tools.CopyImageCommand}"
                    Header="{CompiledBinding Translation.CopyImage.Value,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding PicViewer.ImageSource.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull}}">
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource CopyImageGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="12"
                            Stretch="Fill"
                            Width="12" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Copy file path  -->
                <MenuItem
                    Command="{CompiledBinding Tools.CopyFilePathCommand}"
                    CommandParameter="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                       FallbackValue=''}"
                    Header="{Binding Translation.FileCopyPath, Mode=OneWay}"
                    IsEnabled="{CompiledBinding PicViewer.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull}}">
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource CopyGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="12"
                            Stretch="Fill"
                            Width="12" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Copy base64  -->
                <MenuItem
                    Command="{CompiledBinding Tools.CopyBase64Command}"
                    CommandParameter="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                       FallbackValue=''}"
                    IsEnabled="{CompiledBinding PicViewer.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull}}">
                    <MenuItem.Header>
                        <TextBlock>
                            <Run Text="{CompiledBinding Translation.Copy, Mode=OneWay}" />
                            <Run Text=" base64" />
                        </TextBlock>
                    </MenuItem.Header>
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource CopyGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="12"
                            Stretch="Fill"
                            Width="12" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <!--  Duplicate file  -->
                <MenuItem
                    Command="{CompiledBinding Tools.DuplicateFileCommand}"
                    CommandParameter="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                       FallbackValue=''}"
                    Header="{CompiledBinding Translation.DuplicateFile,
                                             Mode=OneWay}"
                    IsEnabled="{CompiledBinding PicViewer.FileInfo.Value,
                                                Converter={x:Static ObjectConverters.IsNotNull}}">
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource DuplicateGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="12"
                            Stretch="Fill"
                            Width="12" />
                    </MenuItem.Icon>
                </MenuItem>

            </MenuItem>

            <Separator />

            <!--  Close  -->
            <MenuItem Header="{CompiledBinding Translation.Close.Value, Mode=OneWay}" x:Name="CloseItem">
                <MenuItem.Icon>
                    <Path
                        Data="{StaticResource CloseGeometry}"
                        Fill="{DynamicResource MainTextColor}"
                        Height="12"
                        Stretch="Fill"
                        Width="12" />
                </MenuItem.Icon>
            </MenuItem>

        </ContextMenu>
    </UserControl.ContextMenu>

    <Panel>
        <uc:SpinWaiter
            HorizontalAlignment="Center"
            IsVisible="False"
            VerticalAlignment="Center"
            x:Name="SpinWaiter" />
        <customControls:AutoScrollViewer
            Background="Transparent"
            Focusable="True"
            VerticalScrollBarVisibility="Visible"
            x:Name="ScrollViewer">

            <Panel Margin="5" x:Name="ParentPanel">

                <StackPanel x:Name="MainContainer">

                    <StackPanel Orientation="Horizontal">

                        <WrapPanel HorizontalAlignment="Center" MaxWidth="{Binding Path=Bounds.Width, ElementName=ParentPanel}">

                            <!--  File name  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.FileName.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth,
                                                            FallbackValue=0}" />
                                <customControls:FuncTextBox
                                    Classes="hover TStyle x"
                                    Text="{Binding PicViewer.FileInfo.Value.Name, FallbackValue=''}"
                                    Width="{CompiledBinding InfoWindow.TextBoxXlWidth.Value,
                                                            FallbackValue=0}"
                                    x:Name="FileNameTextBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding PicViewer.FileInfo.Value.Name,
                                                               FallbackValue=''}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value,
                                                                FallbackValue=False}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Folder path  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.Folder.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth,
                                                            FallbackValue=0}" />
                                <customControls:FuncTextBox
                                    Classes="hover TStyle x"
                                    Text="{CompiledBinding PicViewer.FileInfo.Value.DirectoryName,
                                                           FallbackValue=''}"
                                    Width="{CompiledBinding InfoWindow.TextBoxXlWidth.Value,
                                                            FallbackValue=0}"
                                    x:Name="DirectoryNameTextBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding PicViewer.FileInfo.Value.DirectoryName,
                                                               FallbackValue=''}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value,
                                                                FallbackValue=False}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Full path  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.FullPath.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth,
                                                            FallbackValue='0'}" />
                                <customControls:FuncTextBox
                                    Classes="hover TStyle x"
                                    Text="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                           FallbackValue=''}"
                                    Width="{CompiledBinding InfoWindow.TextBoxXlWidth.Value}"
                                    x:Name="FullPathTextBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding PicViewer.FileInfo.Value.FullName,
                                                               FallbackValue=''}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Width  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.Width.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:NumTextBox
                                    Classes="hover TStyle x"
                                    Text="{CompiledBinding PicViewer.PixelWidth.Value,
                                                           Mode=OneWay}"
                                    ToolTip.Tip="{CompiledBinding Translation.SizeTooltip.Value,
                                                                  Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="PixelWidthTextBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding PicViewer.PixelWidth.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Height  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.Height.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:NumTextBox
                                    Classes="hover TStyle x"
                                    Text="{CompiledBinding PicViewer.PixelHeight.Value,
                                                           Mode=OneWay}"
                                    ToolTip.Tip="{CompiledBinding Translation.SizeTooltip.Value,
                                                                  Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="PixelHeightTextBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding PicViewer.PixelHeight.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Size Mp  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.SizeMp.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth,
                                                            FallbackValue=''}" />
                                <customControls:FuncTextBox
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes=" TStyle x"
                                    IsReadOnly="True"
                                    Text="{CompiledBinding Exif.SizeMp.Value,
                                                           Mode=OneWay,
                                                           FallbackValue=''}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="SizeMpTextBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.SizeMp.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Resolution  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.Resolution.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}"
                                    x:Name="ResolutionTextBlock" />
                                <customControls:FuncTextBox
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes=" TStyle x"
                                    IsReadOnly="True"
                                    Text="{CompiledBinding Exif.Resolution.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Resolution.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Print Size Centimeters  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.PrintSizeCm.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:FuncTextBox
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes=" TStyle x"
                                    IsReadOnly="True"
                                    Text="{CompiledBinding Exif.PrintSizeCm.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="PrintSizeCmTextBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.PrintSizeCm.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Print Size Inches  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.PrintSizeIn.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:FuncTextBox
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes=" TStyle x"
                                    IsReadOnly="True"
                                    Text="{CompiledBinding Exif.PrintSizeInch.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="PrintSizeInchTextBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.PrintSizeInch.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Aspect Ratio  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.ReadAbleAspectRatio.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:FuncTextBox
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes=" TStyle x"
                                    IsReadOnly="True"
                                    Text="{CompiledBinding Exif.AspectRatio.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="AspectRatioTextBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.AspectRatio.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Bit Depth  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.BitDepth.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:FuncTextBox
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes="TStyle x"
                                    IsReadOnly="True"
                                    Text="{CompiledBinding Exif.BitDepth.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.BitDepth.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Orientation  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.Orientation.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <ComboBox
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes="CStyle x"
                                    ItemsSource="{CompiledBinding Exif.Orientations.Value,
                                                                  Mode=OneWay}"
                                    Margin="5,0,0,0"
                                    MinWidth="180"
                                    SelectedIndex="{CompiledBinding Exif.Orientation.Value,
                                                                    Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="OrientationBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Orientation.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Image Format  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.ImageFormat.Value}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:FuncTextBox
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes="TStyle x"
                                    IsReadOnly="True"
                                    Text="{CompiledBinding PicViewer.Format.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding PicViewer.Format.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  File Size  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.FileSize.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:FuncTextBox
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes="TStyle x"
                                    IsReadOnly="True"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="FileSizeBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{Binding Path=Text, ElementName=FileSizeBox}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Created  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.Created.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:DateTimePickerButtons
                                    Margin="5,0,0,0"
                                    SelectedDateTime="{CompiledBinding PicViewer.FileInfo.Value.CreationTime,
                                                                       Mode=TwoWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}" />

                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding PicViewer.FileInfo.Value.CreationTime,
                                                               FallbackValue=''}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Modified  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.Modified.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:DateTimePickerButtons
                                    Margin="5,0,0,0"
                                    SelectedDateTime="{CompiledBinding PicViewer.FileInfo.Value.LastWriteTime,
                                                                       Mode=TwoWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding PicViewer.FileInfo.Value.LastWriteTime,
                                                               FallbackValue=''}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Last Accessed  -->
                            <StackPanel Margin="15,10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,0,0"
                                    Text="{CompiledBinding Translation.LastAccessTime.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:DateTimePickerButtons
                                    Margin="5,0,0,0"
                                    SelectedDateTime="{CompiledBinding PicViewer.FileInfo.Value.LastAccessTime,
                                                                       Mode=TwoWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}" />

                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding PicViewer.FileInfo.Value.LastAccessTime,
                                                               FallbackValue=''}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                        </WrapPanel>

                        <!--  Convert To  -->
                        <StackPanel
                            HorizontalAlignment="Right"
                            IsVisible="{CompiledBinding InfoWindow.IsConvertBoxEnabled.Value}"
                            Margin="45,15,10,0"
                            Width="140"
                            x:Name="ConvertToPanel">
                            <TextBlock
                                Classes="txt"
                                FontSize="16"
                                Margin="0,25,0,10"
                                Text="{CompiledBinding Translation.ConvertTo.Value,
                                                       Mode=OneWay}"
                                TextAlignment="Center" />
                            <ComboBox
                                BorderBrush="{DynamicResource MainBorderColor}"
                                BorderThickness="1"
                                CornerRadius="2"
                                FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                                Foreground="{DynamicResource MainTextColor}"
                                Padding="5,7,0,7"
                                SelectedIndex="0"
                                Width="140"
                                x:Name="ConversionComboBox">
                                <ComboBoxItem Content="{CompiledBinding Translation.NoConversion.Value, Mode=OneWay}" x:Name="NoConversion" />
                                <ComboBoxItem Content=".png" x:Name="PngItem" />
                                <ComboBoxItem Content=".jpg" x:Name="JpgItem" />
                                <ComboBoxItem Content=".webp" x:Name="WebpItem" />
                                <ComboBoxItem Content=".avif" x:Name="AvifItem" />
                                <ComboBoxItem Content=".heic" x:Name="HeicItem" />
                                <ComboBoxItem Content=".jxl" x:Name="JxlItem" />
                            </ComboBox>

                            <!--  Save, save as  -->
                            <SplitButton
                                Background="{DynamicResource AccentColor}"
                                Classes="BorderStyle accentHover mainBtn"
                                CornerRadius="2"
                                Foreground="{StaticResource SecondaryTextColor}"
                                Margin="0,40,0,0"
                                Width="140"
                                x:Name="SaveButton">
                                <TextBlock
                                    Classes="txt"
                                    Foreground="{StaticResource SecondaryTextColor}"
                                    Text="{CompiledBinding Translation.Save.Value,
                                                           Mode=OneWay}"
                                    TextAlignment="Center" />
                                <SplitButton.Flyout>
                                    <MenuFlyout FlyoutPresenterClasses="noCornerRadius" Placement="Bottom">
                                        <MenuItem
                                            Background="Transparent"
                                            Header="{CompiledBinding Translation.SaveAs.Value,
                                                                     Mode=OneWay}"
                                            Width="140"
                                            x:Name="SaveAsButton" />
                                    </MenuFlyout>
                                </SplitButton.Flyout>
                            </SplitButton>

                            <!--  Reset  -->
                            <Button
                                Classes="BorderStyle altHover mainBtn"
                                CornerRadius="2"
                                Margin="0,20,0,0"
                                Width="140"
                                x:Name="ResetButton">
                                <TextBlock
                                    Classes="txt"
                                    Text="{CompiledBinding Translation.Reset.Value,
                                                           Mode=OneWay}"
                                    TextAlignment="Center" />
                            </Button>
                        </StackPanel>

                    </StackPanel>

                    <!--  Copyright, comment, etc.  -->
                    <StackPanel IsEnabled="{CompiledBinding Exif.IsExifAvailable.Value}">

                        <StackPanel
                            Height="20"
                            HorizontalAlignment="Center"
                            Margin="15,20"
                            Orientation="Horizontal">
                            <Rectangle
                                Fill="{DynamicResource MainBorderColor}"
                                Height="1"
                                Margin="0,0,7,0"
                                Width="{CompiledBinding InfoWindow.HalfLineWidth.Value}" />
                            <Path
                                Data="{StaticResource AtGeometry}"
                                Fill="{DynamicResource MainTextColor}"
                                Stretch="Uniform" />
                            <Rectangle
                                Fill="{DynamicResource MainBorderColor}"
                                Height="1"
                                Margin="7,0,0,0"
                                Width="{CompiledBinding InfoWindow.HalfLineWidth.Value}" />
                        </StackPanel>

                        <WrapPanel HorizontalAlignment="Center" Margin="5,10,0,0">

                            <!--  Date taken  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,2,0"
                                    Text="{CompiledBinding Translation.DateTaken.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:DateTimePickerButtons
                                    Command="{CompiledBinding Exif.SetDateTakenCommand}"
                                    CommandParameter="{CompiledBinding PicViewer.FileInfo.Value}"
                                    Margin="5,0,0,0"
                                    SelectedDateTime="{CompiledBinding Exif.DateTaken.Value,
                                                                       Mode=TwoWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.DateTaken.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Authors  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,2,0"
                                    Text="{CompiledBinding Translation.Authors.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:FuncTextBox
                                    Classes=" TStyle x"
                                    Text="{CompiledBinding Exif.Authors.Value,
                                                           Mode=TwoWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="AuthorsBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Authors.Value,
                                                               Mode=TwoWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Copyright  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,2,0"
                                    Text="{CompiledBinding Translation.Copyright.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:FuncTextBox
                                    Classes=" TStyle x"
                                    Text="{CompiledBinding Exif.Copyright.Value,
                                                           Mode=TwoWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="CopyRightBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Copyright.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Software  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,2,0"
                                    Text="{CompiledBinding Translation.Software.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:FuncTextBox
                                    Classes="TStyle x"
                                    Text="{CompiledBinding Exif.Software.Value,
                                                           Mode=TwoWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="SoftwareBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Software.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Subject  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,2,0"
                                    Text="{CompiledBinding Translation.Subject.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:FuncTextBox
                                    Classes=" TStyle x"
                                    Text="{CompiledBinding Exif.Subject.Value,
                                                           Mode=TwoWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxXxlWidth.Value}"
                                    x:Name="SubjectBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Subject.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Title  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,2,0"
                                    Text="{CompiledBinding Translation.Title.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:FuncTextBox
                                    Classes=" TStyle x"
                                    Text="{CompiledBinding Exif.Title.Value,
                                                           Mode=TwoWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxXxlWidth.Value}"
                                    x:Name="TitleBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Title.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Comment  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,2,0"
                                    Text="Comment"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:FuncTextBox
                                    Classes=" TStyle x"
                                    MaxHeight="600"
                                    Text="{CompiledBinding Exif.Comment.Value,
                                                           Mode=TwoWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxXxlWidth.Value}"
                                    x:Name="CommentBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Comment.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>
                        </WrapPanel>

                    </StackPanel>

                    <!--  Gps  -->
                    <StackPanel IsEnabled="{CompiledBinding Exif.IsExifAvailable.Value}">
                        <StackPanel
                            Height="20"
                            HorizontalAlignment="Center"
                            Margin="15,20"
                            Orientation="Horizontal">
                            <Rectangle
                                Fill="{DynamicResource MainBorderColor}"
                                Height="1"
                                Margin="0,0,7,0"
                                Width="{CompiledBinding InfoWindow.HalfLineWidth.Value}" />
                            <Path
                                Data="{StaticResource GpsGeometry}"
                                Fill="{DynamicResource MainTextColor}"
                                Stretch="Uniform" />
                            <Rectangle
                                Fill="{DynamicResource MainBorderColor}"
                                Height="1"
                                Margin="7,0,0,0"
                                Width="{CompiledBinding InfoWindow.HalfLineWidth.Value}" />
                        </StackPanel>

                        <WrapPanel HorizontalAlignment="Center" Margin="5,10,0,0">

                            <!--  Latitude  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,2,0"
                                    Text="{CompiledBinding Translation.Latitude.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:FuncTextBox
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes=" TStyle x"
                                    IsReadOnly="True"
                                    Text="{CompiledBinding Exif.Latitude.Value,
                                                           Mode=TwoWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="LatitudeBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Latitude.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Longitude  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,2,0"
                                    Text="{CompiledBinding Translation.Longitude.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:FuncTextBox
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes=" TStyle x"
                                    IsReadOnly="True"
                                    Text="{CompiledBinding Exif.Longitude.Value,
                                                           Mode=TwoWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="LongitudeBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Longitude.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Altitude  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,2,0"
                                    Text="{CompiledBinding Translation.Altitude,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:FuncTextBox
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes=" TStyle x"
                                    IsReadOnly="True"
                                    Text="{CompiledBinding Exif.Altitude.Value,
                                                           Mode=TwoWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="AltitudeBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Altitude.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>

                            </StackPanel>

                            <StackPanel Margin="94,0,0,0" Orientation="Horizontal">
                                <Button
                                    Classes="altHover BorderStyle"
                                    Command="{CompiledBinding Exif.OpenGoogleLinkCommand,
                                                              Mode=OneWay}"
                                    Margin="30,0,15,0"
                                    x:Name="GoogleLinkButton">
                                    <Path
                                        Data="{StaticResource GoogleGeometry}"
                                        Fill="{DynamicResource MainTextColor}"
                                        Height="20"
                                        Stretch="Fill"
                                        Width="20" />
                                </Button>
                                <Button
                                    Classes="altHover BorderStyle"
                                    Command="{CompiledBinding Exif.OpenBingLinkCommand,
                                                              Mode=OneWay}"
                                    x:Name="BingLinkButton">
                                    <Path
                                        Data="{StaticResource BingGeometry}"
                                        Fill="{DynamicResource MainTextColor}"
                                        Height="20"
                                        Stretch="Fill"
                                        Width="20" />
                                </Button>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>

                    <!--  Color  -->
                    <StackPanel IsEnabled="{CompiledBinding Exif.IsExifAvailable.Value}">
                        <StackPanel
                            Height="20"
                            HorizontalAlignment="Center"
                            Margin="15,20"
                            Orientation="Horizontal">
                            <Rectangle
                                Fill="{DynamicResource MainBorderColor}"
                                Height="1"
                                Margin="0,0,7,0"
                                Width="{CompiledBinding InfoWindow.HalfLineWidth.Value}" />
                            <Image Source="{StaticResource PaletteImage}" />
                            <Rectangle
                                Fill="{DynamicResource MainBorderColor}"
                                Height="1"
                                Margin="7,0,0,0"
                                Width="{CompiledBinding InfoWindow.HalfLineWidth.Value}" />
                        </StackPanel>

                        <WrapPanel HorizontalAlignment="Center" Margin="5,10,0,0">

                            <!--  Color representation  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,2,0"
                                    Text="{CompiledBinding Translation.ColorRepresentation.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <ComboBox
                                    Classes="CStyle x"
                                    CornerRadius="2"
                                    ItemsSource="{CompiledBinding Exif.ColorRepresentations.Value}"
                                    Margin="5,0,0,0"
                                    MinWidth="180"
                                    Padding="5,7,1,7"
                                    SelectedIndex="{CompiledBinding Exif.ColorRepresentation.Value,
                                                                    Mode=TwoWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="ColorRepresentationBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.ColorRepresentation.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Resolution unit  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,2,0"
                                    Text="{CompiledBinding Translation.ResolutionUnit.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <ComboBox
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes="CStyle x"
                                    CornerRadius="2"
                                    ItemsSource="{CompiledBinding Exif.ResolutionUnits.Value}"
                                    Margin="5,0,0,0"
                                    MinWidth="180"
                                    Padding="5,7,1,7"
                                    SelectedIndex="{CompiledBinding Exif.ResolutionUnit.Value,
                                                                    Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="ResolutionUnitBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{Binding #ResolutionUnitBox.SelectedItem}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>

                            </StackPanel>

                            <!--  Compression  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,2,0"
                                    Text="{CompiledBinding Translation.Compression.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <ComboBox
                                    Classes="CStyle x"
                                    CornerRadius="2"
                                    ItemsSource="{CompiledBinding Exif.Compressions.Value}"
                                    Margin="5,0,0,0"
                                    MinWidth="180"
                                    Padding="5,7,1,7"
                                    SelectedIndex="{CompiledBinding Exif.Compression.Value,
                                                                    Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="CompressionBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.Compression.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>

                            <!--  Compressed bits pixel  -->
                            <StackPanel Margin="10" Orientation="Horizontal">
                                <TextBlock
                                    Classes="txt"
                                    Margin="0,8,2,0"
                                    Text="{CompiledBinding Translation.CompressedBitsPixel.Value,
                                                           Mode=OneWay}"
                                    Width="{CompiledBinding InfoWindow.TextWidth}" />
                                <customControls:FuncTextBox
                                    Background="{DynamicResource DisabledBackgroundColor}"
                                    Classes=" TStyle x"
                                    IsReadOnly="True"
                                    Text="{CompiledBinding Exif.CompressedBitsPixel.Value,
                                                           Mode=TwoWay}"
                                    Width="{CompiledBinding InfoWindow.TextBoxWidth.Value}"
                                    x:Name="CompressedBitsPerPixelBox" />
                                <customControls:CopyButton
                                    Classes="altHover BorderStyle"
                                    CopyText="{CompiledBinding Exif.CompressedBitsPixel.Value,
                                                               Mode=OneWay}"
                                    IsVisible="{CompiledBinding InfoWindow.IsCopyButtonEnabled.Value}"
                                    ToolTip.Tip="{CompiledBinding Translation.Copy.Value,
                                                                  Mode=OneWay}">
                                    <Path Classes="CopyPath" />
                                </customControls:CopyButton>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>

                    <!--  Camera info  -->
                    <StackPanel IsEnabled="{CompiledBinding Exif.IsExifAvailable.Value}">
                        <StackPanel
                            Height="20"
                            HorizontalAlignment="Center"
                            Margin="15,20"
                            Orientation="Horizontal">
                            <Rectangle
                                Fill="{DynamicResource MainBorderColor}"
                                Height="1"
                                Margin="0,0,7,0"
                                Width="{CompiledBinding InfoWindow.HalfLineWidth.Value}" />
                            <Path
                                Data="{StaticResource ImageInfoGeometry}"
                                Fill="{DynamicResource MainTextColor}"
                                Stretch="Uniform" />
                            <Rectangle
                                Fill="{DynamicResource MainBorderColor}"
                                Height="1"
                                Margin="7,0,0,0"
                                Width="{CompiledBinding InfoWindow.HalfLineWidth.Value}" />
                        </StackPanel>

                        <WrapPanel HorizontalAlignment="Center" Margin="5,10,0,0">

                            <!--  Camera maker  -->
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Margin="10" Orientation="Horizontal">
                                    <TextBlock
                                        Classes="txt"
                                        Margin="0,8,2,0"
                                        Text="{CompiledBinding Translation.CameraMaker.Value,
                                                               Mode=OneWay}"
                                        Width="{CompiledBinding InfoWindow.TextWidth}" />
