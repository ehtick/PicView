        <Button
            Background="{DynamicResource AccentColor}"
            Classes="BorderStyle accentHover mainBtn"
            HorizontalAlignment="Right"
            Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal">
                <Image
                    Height="18"
                    Margin="0,0,10,0"
                    Width="18">
                    <DrawingImage>
