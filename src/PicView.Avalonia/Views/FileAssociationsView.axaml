                        Margin="0,0,0,10">
                        <TextBlock
                            Classes="txt"
                            Margin="0"
                            Padding="0,1,5,0"
                            Text="High Dynamic Range (.hdr)" />
                    </ToggleButton>

                    <ToggleButton
