<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="PicView.Avalonia.Views.FileAssociationsView"
    x:DataType="viewModels:MainViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:PicView.Avalonia.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.DataContext>
        <viewModels:MainViewModel />
    </Design.DataContext>

    <StackPanel HorizontalAlignment="Center" Orientation="Vertical">

        <TextBlock
            Classes="txt"
            FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
            FontSize="14"
            Margin="0,20,0,0"
            Text="File associations" />

        <TextBlock
            Classes="txt"
            Foreground="{StaticResource SecondaryTextColor}"
            HorizontalAlignment="Left"
            Padding="0,5,10,5"
            Text="Select file types to associate. Unselected types will be unregistered." />

        <Panel Background="{DynamicResource SecondaryBackgroundColor}" Margin="0,20,0,0">
            <TextBlock
                Classes="txt"
                FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                FontSize="14"
                Foreground="{StaticResource SecondaryTextColor}"
                HorizontalAlignment="Left"
                Padding="10,5,0,5"
                Text="{CompiledBinding Translation.FileExtension,
                                       Mode=OneWay}" />

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Classes="altHover" Padding="10,2,10,2">

                    <TextBlock
                        Classes="txt"
                        Foreground="{StaticResource SecondaryTextColor}"
                        Text="{CompiledBinding Translation.SelectAll,
                                               Mode=OneWay}" />
                </Button>

                <Rectangle
                    Fill="{DynamicResource TertiaryBorderColor}"
                    Height="16"
                    Margin="5,0,5,0"
                    Width="2" />

                <Button Classes="altHover" Padding="10,2,10,2">
                    <TextBlock
                        Classes="txt"
                        Foreground="{StaticResource SecondaryTextColor}"
                        Text="Unselect All" />
                </Button>
            </StackPanel>
        </Panel>

        <Border BorderBrush="{DynamicResource MainBorderColor}" BorderThickness="1">
            <customControls:AutoScrollViewer Background="Transparent" Height="315">
                <StackPanel>

                    <ToggleButton
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="altHover"
                        Margin="0,0,0,10">
                        <TextBlock
                            Classes="txt"
                            Margin="0"
                            Padding="0,1,5,0"
                            Text="Joint Photographic Experts Group (.jpg, .jpeg, .jpe)" />
                    </ToggleButton>

                    <ToggleButton
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="altHover"
                        Margin="0,0,0,10">
                        <TextBlock
                            Classes="txt"
                            Margin="0"
                            Padding="0,1,5,0"
                            Text="JPEG File Interchange Format (.jfif)" />
                    </ToggleButton>

                    <ToggleButton
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="altHover"
                        Margin="0,0,0,10">
                        <TextBlock
                            Classes="txt"
                            Margin="0"
                            Padding="0,1,5,0"
                            Text="Portable Network Graphics (.png)" />
                    </ToggleButton>

                    <ToggleButton
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="altHover"
                        Margin="0,0,0,10">
                        <TextBlock
                            Classes="txt"
                            Margin="0"
                            Padding="0,1,5,0"
                            Text="Windows Bitmap (.bmp)" />
                    </ToggleButton>

                    <ToggleButton
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="altHover"
                        Margin="0,0,0,10">
                        <TextBlock
                            Classes="txt"
                            Margin="0"
                            Padding="0,1,5,0"
                            Text="Graphics Interchange Format (.gif)" />
                    </ToggleButton>

                    <ToggleButton
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="altHover"
                        Margin="0,0,0,10">
                        <TextBlock
                            Classes="txt"
                            Margin="0"
                            Padding="0,1,5,0"
                            Text="WebP (.webp)" />
                    </ToggleButton>

                    <ToggleButton
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="altHover"
                        Margin="0,0,0,10">
                        <TextBlock
                            Classes="txt"
                            Margin="0"
                            Padding="0,1,5,0"
                            Text="Wireless Bitmap (.wbmp)" />
                    </ToggleButton>

                    <ToggleButton
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="altHover"
                        Margin="0,0,0,10">
                        <TextBlock
                            Classes="txt"
                            Margin="0"
                            Padding="0,1,5,0"
                            Text="Advanced Video Interlace Format (.avif)" />
                    </ToggleButton>

                    <ToggleButton
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="altHover"
                        Margin="0,0,0,10">
                        <TextBlock
                            Classes="txt"
                            Margin="0"
                            Padding="0,1,5,0"
                            Text="Icon (.ico)" />
                    </ToggleButton>

                    <ToggleButton
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="altHover"
                        Margin="0,0,0,10">
                        <TextBlock
                            Classes="txt"
                            Margin="0"
                            Padding="0,1,5,0"
                            Text="Scalable Vector Graphics (.svg, svgz)" />
                    </ToggleButton>

