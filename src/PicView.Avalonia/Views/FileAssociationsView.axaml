                        Background="Transparent"
                        BorderThickness="0"
                        Classes="altHover"
                        Margin="0,0,0,10">
                        <TextBlock
                            Classes="txt"
                            Margin="0"
                            Padding="0,1,5,0"
                            Text="XCF (.xcf)" />
                    </ToggleButton>

                    <ToggleButton
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="altHover"
                        Margin="0,0,0,10">
                        <TextBlock
                            Classes="txt"
                            Margin="0"
                            Padding="0,1,5,0"
                            Text="Tagged Image File Format (.tif, .tiff)" />
                    </ToggleButton>

                    <ToggleButton
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="altHover"
                        Margin="0,0,0,10">
                        <TextBlock
                            Classes="txt"
                            Margin="0"
                            Padding="0,1,5,0"
                            Text="High-Enhanced Image File (.heic, .heif)" />
                    </ToggleButton>

                    <ToggleButton
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="altHover"
                        Margin="0,0,0,10">
                        <TextBlock
                            Classes="txt"
                            Margin="0"
                            Padding="0,1,5,0"
                            Text="JPEG XL (.jxl)" />
                    </ToggleButton>

                    <ToggleButton
                        Background="Transparent"
                        BorderThickness="0"
