<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="PicView.Avalonia.Views.Gallery.GalleryItem2"
    x:DataType="viewModels:GalleryItemViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border
        Background="Transparent"
        BorderThickness="2"
        Height="{CompiledBinding ItemHeight.Value,
                                 Mode=OneWay}"
        MinWidth="25"
        ToolTip.HorizontalOffset="0"
        ToolTip.Placement="TopEdgeAlignedLeft"
        ToolTip.VerticalOffset="0"
        Width="{CompiledBinding ItemWidth.Value,
                                Mode=OneWay}"
        x:Name="ImageBorder">
        <customControls:ThumbImage x:Name="GalleryImage" Source="{CompiledBinding Image.Value}" />
        <ToolTip.Tip>
            <StackPanel MaxWidth="600">
                <TextBlock
                    Classes="txt"
                    FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                    FontSize="14"
                    Foreground="{DynamicResource MainTextColor}"
                    Margin="2,0,2,6"
                    TextWrapping="NoWrap"
                    Text="{CompiledBinding FileName.Value}"
                    x:Name="FileName" />
                <TextBlock
                    Classes="txt"
                    Foreground="{DynamicResource MainTextColor}"
                    Margin="2,0,2,2"
                    TextWrapping="NoWrap"
                    Text="{CompiledBinding FileLocation.Value}"
                    x:Name="FileLocation" />
                <TextBlock
                    Classes="txt"
                    Foreground="{DynamicResource MainTextColor}"
                    Margin="2,0,2,2"
                    TextWrapping="NoWrap"
                    Text="{CompiledBinding FileSize.Value}"
                    x:Name="FileSize" />
                <TextBlock
                    Classes="txt"
                    Foreground="{DynamicResource MainTextColor}"
                    Margin="2,0,2,4"
                    TextWrapping="NoWrap"
                    Text="{CompiledBinding FileDate.Value}"
                    x:Name="FileDate" />
            </StackPanel>
        </ToolTip.Tip>
        <Border.ContextMenu>
            <ContextMenu x:Name="GalleryContextMenu">

                <!--  Print  -->
                <MenuItem
                    CommandParameter="{CompiledBinding Path=Text,
                                                       ElementName=FileLocation}"
                    Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Print.Value,
                                             Mode=OneWay}"
                    x:Name="PrintItem">
                    <MenuItem.Icon>
                        <Path Classes="PrintPath" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Open with  -->
                <MenuItem
                    CommandParameter="{CompiledBinding Path=Text,
                                                       ElementName=FileLocation}"
                    Foreground="{DynamicResource MainTextColor}"
                    Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.OpenWith.Value,
                                             Mode=OneWay}"
                    x:Name="OpenWith">
                    <MenuItem.Icon>
                        <Image Height="12" Width="12">
                            <Image.Source>
                                <DrawingImage>
                                    <DrawingGroup>
                                        <GeometryDrawing Geometry="F1 M12 6L6 6Q5.90175 6 5.80397 6.00963Q5.70618 6.01926 5.60982 6.03843Q5.51345 6.0576 5.41943 6.08612Q5.32541 6.11464 5.23463 6.15224Q5.14386 6.18984 5.05721 6.23616Q4.97055 6.28247 4.88886 6.33706Q4.80716 6.39165 4.73121 6.45398Q4.65526 6.51631 4.58579 6.58579Q4.51631 6.65526 4.45398 6.73121Q4.39165 6.80717 4.33706 6.88886Q4.28247 6.97056 4.23616 7.05721Q4.18984 7.14386 4.15224 7.23463Q4.11464 7.32541 4.08612 7.41943Q4.0576 7.51345 4.03843 7.60982Q4.01926 7.70619 4.00963 7.80397Q4 7.90175 4 8L4 18Q4 18.0983 4.00963 18.196Q4.01926 18.2938 4.03843 18.3902Q4.0576 18.4865 4.08612 18.5806Q4.11464 18.6746 4.15224 18.7654Q4.18984 18.8561 4.23616 18.9428Q4.28247 19.0294 4.33706 19.1111Q4.39165 19.1928 4.45398 19.2688Q4.51631 19.3447 4.58579 19.4142Q4.65526 19.4837 4.73121 19.546Q4.80716 19.6083 4.88886 19.6629Q4.97055 19.7175 5.05721 19.7638Q5.14386 19.8102 5.23463 19.8478Q5.32541 19.8854 5.41943 19.9139Q5.51345 19.9424 5.60982 19.9616Q5.70618 19.9807 5.80397 19.9904Q5.90175 20 6 20L16 20Q16.0983 20 16.196 19.9904Q16.2938 19.9807 16.3902 19.9616Q16.4865 19.9424 16.5806 19.9139Q16.6746 19.8854 16.7654 19.8478Q16.8561 19.8102 16.9428 19.7638Q17.0294 19.7175 17.1111 19.6629Q17.1928 19.6084 17.2688 19.546Q17.3447 19.4837 17.4142 19.4142Q17.4837 19.3447 17.546 19.2688Q17.6084 19.1928 17.6629 19.1111Q17.7175 19.0294 17.7638 18.9428Q17.8102 18.8561 17.8478 18.7654Q17.8854 18.6746 17.9139 18.5806Q17.9424 18.4865 17.9616 18.3902Q17.9807 18.2938 17.9904 18.196Q18 18.0983 18 18L18 12">
                                            <GeometryDrawing.Pen>
                                                <Pen
                                                    Brush="{DynamicResource MainTextColor}"
                                                    LineCap="Round"
                                                    LineJoin="Round"
                                                    MiterLimit="4"
                                                    Thickness="2" />
                                            </GeometryDrawing.Pen>
                                        </GeometryDrawing>
                                        <GeometryDrawing Geometry="F1 M11 13L20 4">
                                            <GeometryDrawing.Pen>
                                                <Pen
                                                    Brush="{DynamicResource MainTextColor}"
                                                    LineCap="Round"
                                                    LineJoin="Round"
                                                    MiterLimit="4"
                                                    Thickness="2" />
                                            </GeometryDrawing.Pen>
                                        </GeometryDrawing>
                                        <GeometryDrawing Geometry="F1 M15 4L20 4L20 9">
                                            <GeometryDrawing.Pen>
                                                <Pen
                                                    Brush="{DynamicResource MainTextColor}"
                                                    LineCap="Round"
                                                    LineJoin="Round"
                                                    MiterLimit="4"
                                                    Thickness="2" />
                                            </GeometryDrawing.Pen>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingImage>
                            </Image.Source>
                        </Image>
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Locate on disk  -->
                <MenuItem Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.ShowInFolder.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path Classes="ShowInFolderPath" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />

                <!--  Set as wallpaper  -->
                <MenuItem x:Name="WallpaperMenuItem">
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource PanoramaGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="10.40"
                            Stretch="Fill"
                            Width="13" />
                    </MenuItem.Icon>

                    <!--  Set as wallpaper filled  -->
                    <MenuItem Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Fill.Value, Mode=OneWay}">
                        <MenuItem.Icon>
                            <Path
                                Data="{StaticResource PanoramaGeometry}"
                                Fill="{DynamicResource MainTextColor}"
                                Height="10.40"
                                Stretch="Fill"
                                Width="13" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Set as wallpaper fit  -->
                    <MenuItem Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Fit.Value, Mode=OneWay}">
                        <MenuItem.Icon>
                            <Path
                                Data="{StaticResource PanoramaGeometry}"
                                Fill="{DynamicResource MainTextColor}"
                                Height="10.40"
                                Stretch="Fill"
                                Width="13" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Set as wallpaper stretched  -->
                    <MenuItem Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Stretch.Value, Mode=OneWay}">
                        <MenuItem.Icon>
                            <Path
                                Data="{StaticResource PanoramaGeometry}"
                                Fill="{DynamicResource MainTextColor}"
                                Height="10.40"
                                Stretch="Fill"
                                Width="13" />
                        </MenuItem.Icon>
                    </MenuItem>


                    <!--  Set as wallpaper centered  -->
                    <MenuItem Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Center.Value, Mode=OneWay}">
                        <MenuItem.Icon>
                            <Path
                                Data="{StaticResource PanoramaGeometry}"
                                Fill="{DynamicResource MainTextColor}"
                                Height="10.40"
                                Stretch="Fill"
                                Width="13" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Set as wallpaper tiled  -->
                    <MenuItem Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Tile.Value, Mode=OneWay}">
                        <MenuItem.Icon>
                            <Path
                                Data="{StaticResource PanoramaGeometry}"
                                Fill="{DynamicResource MainTextColor}"
                                Height="10.40"
                                Stretch="Fill"
                                Width="13" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <MenuItem
                    CommandParameter="{CompiledBinding Path=Text,
                                                       ElementName=FileLocation}"
                    Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.CopyFile.Value,
                                             Mode=OneWay}"
                    x:Name="CopyFileMenuItem">
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource CopyGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="12"
                            Stretch="Fill"
                            Width="12" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.CopyImage.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource CopyGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="12"
                            Stretch="Fill"
                            Width="12" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem>
                    <MenuItem.Header>
                        <TextBlock>
                            <Run Text="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Copy.Value, Mode=OneWay}" />
                            <Run Text=" base64" />
                        </TextBlock>
                    </MenuItem.Header>
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource CopyGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="12"
                            Stretch="Fill"
                            Width="12" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.DuplicateFile.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource CopyGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="12"
                            Stretch="Fill"
                            Width="12" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.DeleteFile.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource RecycleGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="12"
                            Stretch="Fill"
                            Width="12" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Stretch.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Height="12"
                            Source="{StaticResource Image}"
                            Width="12" />
                    </MenuItem.Icon>
                    <MenuItem
                        CommandParameter="Uniform"
                        Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Uniform.Value,
                                                 Mode=OneWay}"
                        ToggleType="Radio" />
                    <MenuItem
                        CommandParameter="UniformToFill"
                        Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.UniformToFill.Value,
                                                 Mode=OneWay}"
                        ToggleType="Radio" />
                    <MenuItem
                        CommandParameter="Fill"
                        Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Fill.Value,
                                                 Mode=OneWay}"
                        ToggleType="Radio" />
                    <MenuItem Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.None.Value, Mode=OneWay}" ToggleType="Radio" />
                    <MenuItem
                        CommandParameter="Square"
                        Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Square.Value,
                                                 Mode=OneWay}"
                        ToggleType="Radio" />
                    <MenuItem
                        CommandParameter="FillSquare"
                        Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.FillSquare.Value,
                                                 Mode=OneWay}"
                        ToggleType="Radio" />
                </MenuItem>
                <MenuItem Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.ExpandedGalleryItemSize.Value, Mode=OneWay}" StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image
                            Height="12"
                            Source="{StaticResource Image}"
                            Width="12" />
                    </MenuItem.Icon>
                    <FlyoutBase.AttachedFlyout>
                        <Flyout>
                            <Border
                                Background="{DynamicResource MainButtonBackgroundColor}"
                                BorderBrush="{DynamicResource MainBorderColor}"
                                BorderThickness="2"
                                CornerRadius="4"
                                Padding="10,3">
                                <!-- <gallery:GalleryItemSizeSlider x:Name="GalleryItemSizeSlider" /> -->
                            </Border>
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </MenuItem>
                <Separator />
                <MenuItem Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.HideBottomGallery.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource CloseGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="12"
                            Stretch="Fill"
                            Width="12" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.CloseGallery.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path
                            Data="{StaticResource CloseGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Height="12"
                            Stretch="Fill"
                            Width="12" />
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </Border.ContextMenu>
    </Border>
</UserControl>
