<UserControl
    x:Class="PicView.Avalonia.Views.Config.GallerySettingsView2"
    x:DataType="viewModels:CoreViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:config="clr-namespace:PicView.Core.Config;assembly=PicView.Core"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:ui="clr-namespace:PicView.Avalonia.UI"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel HorizontalAlignment="Center">

        <TextBlock
            Classes="txt bold"
            Margin="0,20,0,20"
            Text="{CompiledBinding Translation.GallerySettings.Value,
                                   Mode=OneWay}" />

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.GalleryDockSearchTags.Value}">
            <StackPanel>
                <customControls:TextIconButton
                    Background="Transparent"
                    BorderThickness="0"
                    Classes="altHover"
                    Command="{CompiledBinding GallerySettings.SetDockPositionCommand}"
                    CommandParameter="{x:Static config:GalleryDockPosition.Bottom}"
                    Foreground="{DynamicResource MainTextColor}"
                    Icon="{StaticResource GalleryImage}"
                    IconHeight="16"
                    IconMargin="0,0,7,0"
                    IconWidth="16"
                    IsEnabled="{CompiledBinding !GallerySettings.IsBottomDocked.Value}"
                    Margin="0,0,0,10"
                    Padding="9,8,8,8"
                    Text="{CompiledBinding Translation.ShowDockedGalleryAtBottom.Value,
                                           Mode=OneWay}"
                    TextMargin="5,0,5,0"
                    TextMaxWidth="240"
                    Width="300"
                    x:Name="ShowBottomDockedGalleryButton" />

                <customControls:TextIconButton
                    Background="Transparent"
                    BorderThickness="0"
                    Classes="altHover"
                    Command="{CompiledBinding GallerySettings.SetDockPositionCommand}"
                    CommandParameter="{x:Static config:GalleryDockPosition.Top}"
                    Foreground="{DynamicResource MainTextColor}"
                    Icon="{StaticResource GalleryImage}"
                    IconHeight="16"
                    IconMargin="0,0,7,0"
                    IconWidth="16"
                    IsEnabled="{CompiledBinding !GallerySettings.IsTopDocked.Value}"
                    Margin="0,0,0,10"
                    Padding="9,8,8,8"
                    Text="{CompiledBinding Translation.ShowDockedGalleryAtTop.Value,
                                           Mode=OneWay}"
                    TextMargin="5,0,5,0"
                    TextMaxWidth="240"
                    Width="300"
                    x:Name="ShowTopDockedGalleryButton" />

                <customControls:TextIconButton
                    Background="Transparent"
                    BorderThickness="0"
                    Classes="altHover"
                    Command="{CompiledBinding GallerySettings.SetDockPositionCommand}"
                    CommandParameter="{x:Static config:GalleryDockPosition.Right}"
                    Foreground="{DynamicResource MainTextColor}"
                    Icon="{StaticResource GalleryImage}"
                    IconHeight="16"
                    IconMargin="0,0,7,0"
                    IconWidth="16"
                    IsEnabled="{CompiledBinding !GallerySettings.IsRightDocked.Value}"
                    Margin="0,0,0,10"
                    Padding="9,8,8,8"
                    Text="{CompiledBinding Translation.ShowDockedGalleryToTheRight.Value,
                                           Mode=OneWay}"
                    TextMargin="5,0,5,0"
                    TextMaxWidth="240"
                    Width="300"
                    x:Name="ShowRightDockedGalleryButton" />

                <customControls:TextIconButton
                    Background="Transparent"
                    BorderThickness="0"
                    Classes="altHover"
                    Command="{CompiledBinding GallerySettings.SetDockPositionCommand}"
                    CommandParameter="{x:Static config:GalleryDockPosition.Left}"
                    Foreground="{DynamicResource MainTextColor}"
                    Icon="{StaticResource GalleryImage}"
                    IconHeight="16"
                    IconMargin="0,0,7,0"
                    IconWidth="16"
                    IsEnabled="{CompiledBinding !GallerySettings.IsLeftDocked.Value}"
                    Margin="0,0,0,10"
                    Padding="9,8,8,8"
                    Text="{CompiledBinding Translation.ShowDockedGalleryToTheLeft.Value,
                                           Mode=OneWay}"
                    TextMargin="5,0,5,0"
                    TextMaxWidth="240"
                    Width="300"
                    x:Name="ShowLeftDockedGalleryButton" />
            </StackPanel>
        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.GalleryVisibilitySearchTags.Value}">
            <StackPanel>
                <customControls:TextIconButton
                    Background="Transparent"
                    BorderThickness="0"
                    Classes="altHover"
                    Command="{CompiledBinding GallerySettings.CloseGalleryCommand}"
                    Data="{StaticResource CloseGeometry}"
                    Foreground="{DynamicResource MainTextColor}"
                    IconHeight="12"
                    IconMargin="0,0,7,0"
                    IconWidth="12"
                    IsEnabled="{CompiledBinding GallerySettings.IsGalleryDocked.Value}"
                    Margin="0,0,0,10"
                    Padding="9,8,8,8"
                    Text="{CompiledBinding Translation.HideDockedGallery.Value,
                                           Mode=OneWay}"
                    TextMargin="5,0,5,0"
                    TextMaxWidth="240"
                    Width="300"
                    x:Name="CloseDockedGalleryButton" />

                <ToggleButton
                    Background="Transparent"
                    BorderThickness="0"
                    Classes="altHover changeColor"
                    IsChecked="{CompiledBinding GallerySettings.IsDockedGalleryShownInHiddenUI.Value}"
                    Margin="0,0,0,10"
                    Width="300">
                    <TextBlock
                        Classes="txt"
                        Margin="0"
                        MaxWidth="240"
                        Padding="0,0,5,2"
                        Text="{CompiledBinding Translation.ShowDockedGalleryWhenUiIsHidden.Value,
                                               Mode=OneWay}" />
                </ToggleButton>
            </StackPanel>
        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.GallerySizeSearchTags.Value}">
            <StackPanel>
                <TextBlock
                    Classes="txt"
                    FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                    Margin="0,10,0,10"
                    MaxWidth="300"
                    Text="{CompiledBinding Translation.ExpandedGalleryItemSize.Value,
                                           Mode=OneWay}" />
                <customControls:CustomSlider
                    Height="30"
                    HorizontalAlignment="Center"
                    IsSnapToTickEnabled="True"
                    Margin="0,1,0,1"
                    Maximum="{CompiledBinding GallerySettings.ExpandedGalleryMaxItemSize.Value}"
                    Minimum="{CompiledBinding GallerySettings.ExpandedGalleryMinItemSize.Value}"
                    TickFrequency="1"
                    TickPlacement="BottomRight"
                    Value="{CompiledBinding GallerySettings.ExpandedGalleryItemSize.Value}"
                    Width="300"
                    x:Name="ExpandedGallerySlider" />

                <TextBlock
                    Classes="txt"
                    Margin="0,0,0,15"
                    Text="{CompiledBinding GallerySettings.ExpandedGalleryItemSize.Value,
                                           Mode=OneWay}" />

                <TextBlock
                    Classes="txt"
                    Margin="0,10,0,10"
                    MaxWidth="300"
                    Text="{CompiledBinding Translation.DockedGalleryItemSize.Value,
                                           Mode=OneWay}" />
                <customControls:CustomSlider
                    Height="30"
                    HorizontalAlignment="Center"
                    IsSnapToTickEnabled="True"
                    Margin="0,1,0,1"
                    Maximum="{CompiledBinding GallerySettings.DockedGalleryMaxItemSize.Value}"
                    Minimum="{CompiledBinding GallerySettings.DockedGalleryMinItemSize.Value}"
                    TickFrequency="1"
                    TickPlacement="BottomRight"
                    Value="{CompiledBinding GallerySettings.DockedGalleryItemSize.Value}"
                    Width="300"
                    x:Name="DockedGallerySlider" />

                <TextBlock
                    Classes="txt"
                    Margin="0,0,0,15"
                    Text="{CompiledBinding GallerySettings.DockedGalleryItemSize.Value,
                                           Mode=OneWay}" />

                <TextBlock
                    Classes="txt"
                    Margin="0,10,0,10"
                    MaxWidth="300"
                    Text="{CompiledBinding Translation.ItemSpacing.Value,
                                           Mode=OneWay}" />
                <customControls:CustomSlider
                    Height="30"
                    HorizontalAlignment="Center"
                    IsSnapToTickEnabled="True"
                    Margin="0,1,0,1"
                    Maximum="70"
                    Minimum="0"
                    TickFrequency="1"
                    TickPlacement="BottomRight"
                    Value="{CompiledBinding GallerySettings.GalleryItemSpacing.Value}"
                    Width="300" />

                <TextBlock
                    Classes="txt"
                    Margin="0,0,0,15"
                    Text="{CompiledBinding GallerySettings.GalleryItemSpacing.Value,
                                           Mode=OneWay}" />

                <TextBlock
                    Classes="txt"
                    Margin="0,10,0,10"
                    MaxWidth="300"
                    Text="{CompiledBinding Translation.LineSpacing.Value,
                                           Mode=OneWay}" />
                <customControls:CustomSlider
                    Height="30"
                    HorizontalAlignment="Center"
                    IsSnapToTickEnabled="True"
                    Margin="0,1,0,1"
                    Maximum="70"
                    Minimum="0"
                    TickFrequency="1"
                    TickPlacement="BottomRight"
                    Value="{CompiledBinding GallerySettings.GalleryLineSpacing.Value}"
                    Width="300" />

                <TextBlock
                    Classes="txt"
                    Margin="0,0,0,15"
                    Text="{CompiledBinding GallerySettings.GalleryLineSpacing.Value,
                                           Mode=OneWay}" />
            </StackPanel>
        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.GalleryStretchSearchTags.Value}">
            <StackPanel>
                <TextBlock
                    Classes="txt"
                    FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                    Margin="0,10,0,15"
                    MaxWidth="300"
                    Text="{CompiledBinding Translation.GalleryThumbnailStretch.Value,
                                           Mode=OneWay}" />
                <ComboBox
                    Background="{DynamicResource SecondaryBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1"
                    FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                    Foreground="{DynamicResource MainTextColor}"
                    Margin="0,5,0,15"
                    Padding="5,7,0,7"
                    SelectedIndex="{CompiledBinding GallerySettings.FullGalleryStretchIndex.Value}"
                    Width="300"
                    x:Name="FullGalleryComboBox">
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.Uniform.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="FullGalleryUniformItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.UniformToFill.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="FullGalleryUniformToFillItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.Fill.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="FullGalleryFillItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.None.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="FullGalleryNoneItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.Square.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="FullGallerySquareItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.FillSquare.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="FullGalleryFillSquareItem" />
                </ComboBox>

                <TextBlock
                    Classes="txt"
                    FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                    Margin="0,3,0,15"
                    MaxWidth="300"
                    Text="{CompiledBinding Translation.DockedGalleryThumbnailStretch.Value,
                                           Mode=OneWay}" />
                <ComboBox
                    Background="{DynamicResource SecondaryBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1"
                    FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                    Foreground="{DynamicResource MainTextColor}"
                    Margin="0,5,0,15"
                    Padding="5,7,0,7"
                    SelectedIndex="{CompiledBinding GallerySettings.DockedGalleryStretchIndex.Value}"
                    Width="300"
                    x:Name="DockedGalleryComboBox">
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.Uniform.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="DockedGalleryUniformItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.UniformToFill.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="DockedGalleryUniformToFillItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.Fill.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="DockedGalleryFillItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.None.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="DockedGalleryNoneItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.Square.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="DockedGallerySquareItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.FillSquare.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="DockedGalleryFillSquareItem" />
                </ComboBox>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>