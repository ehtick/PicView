<UserControl
    x:Class="PicView.Avalonia.Views.Config.GallerySettingsView2"
    x:DataType="viewModels:CoreViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:ui="clr-namespace:PicView.Avalonia.UI"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel HorizontalAlignment="Center">

        <TextBlock
            Classes="txt bold"
            Margin="0,20,0,20"
            Text="{CompiledBinding Translation.GallerySettings.Value,
                                   Mode=OneWay}" />

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.GalleryVisibilitySearchTags.Value}">
            <StackPanel>
                <ToggleButton
                    Background="Transparent"
                    BorderThickness="0"
                    Classes="altHover changeColor"
                    IsChecked="{CompiledBinding SettingsViewModel.IsGalleryDocked.Value}"
                    Margin="0,0,0,10"
                    Width="300"
                    x:Name="ToggleDockedGalleryButton">
                    <TextBlock
                        Classes="txt"
                        Margin="0"
                        MaxWidth="240"
                        Padding="0,1,5,0"
                        Text="{CompiledBinding Translation.IsShowingDockedGallery.Value,
                                               Mode=OneWay}" />
                </ToggleButton>

                <ToggleButton
                    Background="Transparent"
                    BorderThickness="0"
                    Classes="altHover changeColor"
                    IsChecked="{CompiledBinding SettingsViewModel.IsDockedGalleryShownInHiddenUI.Value}"
                    Margin="0,0,0,10"
                    Width="300">
                    <TextBlock
                        Classes="txt"
                        Margin="0"
                        MaxWidth="240"
                        Padding="0,1,5,0"
                        Text="{CompiledBinding Translation.ShowDockedGalleryWhenUiIsHidden.Value,
                                               Mode=OneWay}" />
                </ToggleButton>
            </StackPanel>
        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.GalleryDockSearchTags.Value}">
            <StackPanel>
                <TextBlock
                    Classes="txt"
                    FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                    Margin="0,10,0,15"
                    MaxWidth="300"
                    Text="{CompiledBinding Translation.Orientation.Value,
                                           Mode=OneWay}" />
                <ComboBox
                    Background="{DynamicResource SecondaryBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1"
                    FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                    Foreground="{DynamicResource MainTextColor}"
                    Margin="0,5,0,15"
                    Padding="5,7,0,7"
                    SelectedIndex="{CompiledBinding SettingsViewModel.DockPositionIndex.Value,
                                                    Mode=TwoWay}"
                    Width="300">
                    <ComboBoxItem Content="{CompiledBinding Translation.Bottom.Value, Mode=OneWay}" />
                    <ComboBoxItem Content="{CompiledBinding Translation.Top.Value, Mode=OneWay}" />
                    <ComboBoxItem Content="{CompiledBinding Translation.Left.Value, Mode=OneWay}" />
                    <ComboBoxItem Content="{CompiledBinding Translation.Right.Value, Mode=OneWay}" />
                </ComboBox>
            </StackPanel>
        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.GallerySizeSearchTags.Value}">
            <StackPanel>
                <TextBlock
                    Classes="txt"
                    FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                    Margin="0,10,0,10"
                    MaxWidth="300"
                    Text="{CompiledBinding Translation.ExpandedGalleryItemSize.Value,
                                           Mode=OneWay}" />
                <customControls:CustomSlider
                    Height="30"
                    HorizontalAlignment="Center"
                    IsSnapToTickEnabled="True"
                    Margin="0,1,0,1"
                    Maximum="{CompiledBinding SettingsViewModel.ExpandedGalleryMaxItemSize.Value}"
                    Minimum="{CompiledBinding SettingsViewModel.ExpandedGalleryMinItemSize.Value}"
                    TickFrequency="1"
                    TickPlacement="BottomRight"
                    Value="{CompiledBinding SettingsViewModel.ExpandedGalleryItemSize.Value}"
                    Width="300"
                    x:Name="ExpandedGallerySlider" />

                <TextBlock
                    Classes="txt"
                    Margin="0,0,0,15"
                    Text="{CompiledBinding SettingsViewModel.ExpandedGalleryItemSize.Value,
                                           Mode=OneWay}" />

                <TextBlock
                    Classes="txt"
                    Margin="0,10,0,10"
                    MaxWidth="300"
                    Text="{CompiledBinding Translation.DockedGalleryItemSize.Value,
                                           Mode=OneWay}" />
                <customControls:CustomSlider
                    Height="30"
                    HorizontalAlignment="Center"
                    IsSnapToTickEnabled="True"
                    Margin="0,1,0,1"
                    Maximum="{CompiledBinding SettingsViewModel.DockedGalleryMaxItemSize.Value}"
                    Minimum="{CompiledBinding SettingsViewModel.DockedGalleryMinItemSize.Value}"
                    TickFrequency="1"
                    TickPlacement="BottomRight"
                    Value="{CompiledBinding SettingsViewModel.DockedGalleryItemSize.Value}"
                    Width="300"
                    x:Name="DockedGallerySlider" />

                <TextBlock
                    Classes="txt"
                    Margin="0,0,0,15"
                    Text="{CompiledBinding SettingsViewModel.DockedGalleryItemSize.Value,
                                           Mode=OneWay}" />

                <TextBlock
                    Classes="txt"
                    Margin="0,10,0,10"
                    MaxWidth="300"
                    Text="{CompiledBinding Translation.ItemSpacing.Value,
                                           Mode=OneWay}" />
                <customControls:CustomSlider
                    Height="30"
                    HorizontalAlignment="Center"
                    IsSnapToTickEnabled="True"
                    Margin="0,1,0,1"
                    Maximum="70"
                    Minimum="0"
                    TickFrequency="1"
                    TickPlacement="BottomRight"
                    Value="{CompiledBinding SettingsViewModel.GalleryItemSpacing.Value}"
                    Width="300" />

                <TextBlock
                    Classes="txt"
                    Margin="0,0,0,15"
                    Text="{CompiledBinding SettingsViewModel.GalleryItemSpacing.Value,
                                           Mode=OneWay}" />

                <TextBlock
                    Classes="txt"
                    Margin="0,10,0,10"
                    MaxWidth="300"
                    Text="{CompiledBinding Translation.LineSpacing.Value,
                                           Mode=OneWay}" />
                <customControls:CustomSlider
                    Height="30"
                    HorizontalAlignment="Center"
                    IsSnapToTickEnabled="True"
                    Margin="0,1,0,1"
                    Maximum="70"
                    Minimum="0"
                    TickFrequency="1"
                    TickPlacement="BottomRight"
                    Value="{CompiledBinding SettingsViewModel.GalleryLineSpacing.Value}"
                    Width="300" />

                <TextBlock
                    Classes="txt"
                    Margin="0,0,0,15"
                    Text="{CompiledBinding SettingsViewModel.GalleryLineSpacing.Value,
                                           Mode=OneWay}" />
            </StackPanel>
        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.GalleryStretchSearchTags.Value}">
            <StackPanel>
                <TextBlock
                    Classes="txt"
                    FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                    Margin="0,10,0,15"
                    MaxWidth="300"
                    Text="{CompiledBinding Translation.GalleryThumbnailStretch.Value,
                                           Mode=OneWay}" />
                <ComboBox
                    Background="{DynamicResource SecondaryBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1"
                    FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                    Foreground="{DynamicResource MainTextColor}"
                    Margin="0,5,0,15"
                    Padding="5,7,0,7"
                    SelectedIndex="{CompiledBinding SettingsViewModel.FullGalleryStretchIndex.Value}"
                    Width="300"
                    x:Name="FullGalleryComboBox">
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.Uniform.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="FullGalleryUniformItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.UniformToFill.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="FullGalleryUniformToFillItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.Fill.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="FullGalleryFillItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.None.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="FullGalleryNoneItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.Square.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="FullGallerySquareItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.FillSquare.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="FullGalleryFillSquareItem" />
                </ComboBox>

                <TextBlock
                    Classes="txt"
                    FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                    Margin="0,3,0,15"
                    MaxWidth="300"
                    Text="{CompiledBinding Translation.DockedGalleryThumbnailStretch.Value,
                                           Mode=OneWay}" />
                <ComboBox
                    Background="{DynamicResource SecondaryBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1"
                    FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                    Foreground="{DynamicResource MainTextColor}"
                    Margin="0,5,0,15"
                    Padding="5,7,0,7"
                    SelectedIndex="{CompiledBinding SettingsViewModel.DockedGalleryStretchIndex.Value}"
                    Width="300"
                    x:Name="DockedGalleryComboBox">
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.Uniform.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="DockedGalleryUniformItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.UniformToFill.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="DockedGalleryUniformToFillItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.Fill.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="DockedGalleryFillItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.None.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="DockedGalleryNoneItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.Square.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="DockedGallerySquareItem" />
                    <ComboBoxItem
                        Content="{CompiledBinding Translation.FillSquare.Value,
                                                  Mode=OneWay}"
                        Foreground="{DynamicResource MainTextColor}"
                        x:Name="DockedGalleryFillSquareItem" />
                </ComboBox>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>