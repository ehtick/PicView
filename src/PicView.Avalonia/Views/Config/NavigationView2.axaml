<UserControl
    x:Class="PicView.Avalonia.Views.Config.NavigationView2"
    x:DataType="viewModels:CoreViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:converters="clr-namespace:PicView.Avalonia.Converters"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:ui="clr-namespace:PicView.Avalonia.UI"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel HorizontalAlignment="Center" Orientation="Vertical">
        <TextBlock
            Classes="txt"
            FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
            FontSize="14"
            Foreground="{StaticResource SecondaryTextColor}"
            Margin="0,20,0,20"
            Text="{CompiledBinding Translation.Navigation.Value,
                                   Mode=OneWay}"
            ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.NavigationSearchTags.Value}" />

        <ToggleButton
            Background="Transparent"
            BorderThickness="0"
            Classes="altHover changeColor"
            IsChecked="{CompiledBinding SettingsViewModel.IsIncludingSubdirectories.Value,
                                        Mode=TwoWay}"
            Margin="0,0,0,10"
            Width="300"
            ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.NavigationSearchTags.Value}">
            <TextBlock
                Classes="txt"
                Foreground="{StaticResource SecondaryTextColor}"
                Margin="0"
                MaxWidth="240"
                Padding="0,1,5,0"
                Text="{CompiledBinding Translation.SearchSubdirectory.Value,
                                       Mode=OneWay}" />
        </ToggleButton>

        <ToggleButton
            Background="Transparent"
            BorderThickness="0"
            Classes="altHover changeColor"
            IsChecked="{CompiledBinding SettingsViewModel.IsLooping.Value,
                                        Mode=TwoWay}"
            Margin="0,0,0,10"
            ToolTip.Tip="{CompiledBinding Translation.ToggleLooping.Value,
                                          Mode=OneWay}"
            Width="300"
            ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.NavigationSearchTags.Value}">
            <TextBlock
                Classes="txt"
                Foreground="{StaticResource SecondaryTextColor}"
                Margin="0"
                MaxWidth="240"
                Padding="0,1,5,0"
                Text="{CompiledBinding Translation.IsLooping.Value,
                                       Mode=OneWay}" />
        </ToggleButton>

        <ToggleButton
            Background="Transparent"
            BorderThickness="0"
            Classes="altHover changeColor"
            IsChecked="{CompiledBinding SettingsViewModel.IsShowingTaskbarProgress.Value,
                                        Mode=TwoWay}"
            Margin="0,0,0,10"
            Width="300"
            ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.NavigationSearchTags.Value}"
            x:Name="TaskBarToggleButton">
            <TextBlock
                Classes="txt"
                Foreground="{StaticResource SecondaryTextColor}"
                Margin="0"
                MaxWidth="240"
                Padding="0,1,5,0"
                Text="{CompiledBinding Translation.ToggleTaskbarProgress.Value,
                                       Mode=OneWay}" />
        </ToggleButton>

        <TextBlock
            Classes="txt"
            FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
            FontSize="14"
            Foreground="{StaticResource SecondaryTextColor}"
            Margin="0,10,0,10"
            MaxWidth="300"
            Text="{CompiledBinding Translation.AdjustNavSpeed.Value,
                                   Mode=OneWay}"
            ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.NavigationSearchTags.Value}" />
        <customControls:CustomSlider
            Height="30"
            HorizontalAlignment="Center"
            IsSnapToTickEnabled="True"
            Margin="0,1,0,1"
            Maximum="0.95"
            Minimum="0.05"
            TickFrequency="0.01"
            TickPlacement="BottomRight"
            Value="{CompiledBinding SettingsViewModel.NavSpeed.Value,
                                    Mode=TwoWay}"
            Width="300"
            ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.NavigationSearchTags.Value}" />

        <TextBlock
            Classes="txt"
            FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
            Foreground="{DynamicResource MainTextColorFaded}"
            Margin="0,0,0,15"
            ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.NavigationSearchTags.Value}">
            <Run Text="{CompiledBinding SettingsViewModel.GetNavSpeed.Value, Mode=OneWay}" />
            <Run Text="{CompiledBinding Translation.SecAbbreviation.Value, Mode=OneWay}" />
        </TextBlock>
    </StackPanel>
</UserControl>