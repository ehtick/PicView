<UserControl
    x:Class="PicView.Avalonia.Views.Config.MouseView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:ui="clr-namespace:PicView.Avalonia.UI"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    x:DataType="viewModels:CoreViewModel">

    <StackPanel HorizontalAlignment="Center">

        <StackPanel Classes="searchHeader">
            <Image
                Width="18"
                Height="18"
                Source="{StaticResource MouseWheelIcon}" />
            <TextBlock
                Margin="0,20,0,20"
                Classes="txt bold"
                Text="{CompiledBinding Translation.Mouse.Value,
                                       Mode=OneWay}" />
        </StackPanel>

        <Border ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.MouseDoubleClickSearchTags}" Classes="searchBorder">
            <StackPanel>
                <TextBlock
                    Margin="0,20,0,20"
                    Classes="txt bold"
                    Text="{CompiledBinding Translation.DoubleClick.Value,
                                           Mode=OneWay}" />

                <ComboBox
                    x:Name="DoubleClickBox"
                    Width="300"
                    Margin="0,6,0,15"
                    Padding="5,7,0,7"
                    Background="{DynamicResource SecondaryBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1"
                    FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                    Foreground="{DynamicResource MainTextColor}"
                    ItemsSource="{CompiledBinding SettingsViewModel.MouseDoubleClickBehaviors.Value}"
                    SelectedIndex="{CompiledBinding SettingsViewModel.MouseDoubleClickBehaviorIndex.Value}" />
            </StackPanel>
        </Border>

        <Border ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.MouseNavigationSearchTags}" Classes="searchBorder">
            <StackPanel>
                <TextBlock
                    Margin="0,20,0,20"
                    Classes="txt bold"
                    Text="{CompiledBinding Translation.MouseSideButtons.Value,
                                           Mode=OneWay}" />

                <ComboBox
                    x:Name="MouseSideButtonBox"
                    Width="300"
                    Margin="0,6,0,15"
                    Padding="5,7,0,7"
                    Background="{DynamicResource SecondaryBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1"
                    FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                    Foreground="{DynamicResource MainTextColor}"
                    ItemsSource="{Binding SettingsViewModel.MouseSideButtonBehaviors.Value}"
                    SelectedIndex="{CompiledBinding SettingsViewModel.MouseSideButtonBehaviorIndex.Value,
                                                    Mode=TwoWay}" />
            </StackPanel>
        </Border>

        <Border ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.MouseWheelBehaviorSearchTags}" Classes="searchBorder">
            <StackPanel>
                <TextBlock
                    Margin="0,20,0,20"
                    Classes="txt bold"
                    Text="{CompiledBinding Translation.MouseWheel.Value,
                                           Mode=OneWay}" />

                <ComboBox
                    x:Name="MouseWheelBox"
                    Width="300"
                    Margin="0,6,0,15"
                    Padding="5,7,0,7"
                    Background="{DynamicResource SecondaryBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1"
                    FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                    Foreground="{DynamicResource MainTextColor}"
                    SelectedIndex="{CompiledBinding SettingsViewModel.MouseWheelBehavior.Value,
                                                    Mode=TwoWay}">
                    <ComboBoxItem Content="{CompiledBinding Translation.CtrlToZoom.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
                    <ComboBoxItem Content="{CompiledBinding Translation.ScrollToZoom.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
                </ComboBox>
            </StackPanel>
        </Border>

        <Border ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.MouseScrollDirectionSearchTags}" Classes="searchBorder">
            <StackPanel>
                <TextBlock
                    MaxWidth="300"
                    Margin="0,10,0,10"
                    Classes="txt bold"
                    Text="{CompiledBinding Translation.ScrollDirection.Value,
                                           Mode=OneWay}" />
                <ComboBox
                    x:Name="ScrollDirectionBox"
                    Width="300"
                    Margin="0,6,0,15"
                    Padding="5,7,0,7"
                    Background="{DynamicResource SecondaryBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1"
                    FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                    Foreground="{DynamicResource MainTextColor}"
                    SelectedIndex="{CompiledBinding SettingsViewModel.ScrollDirectionIndex.Value,
                                                    Mode=TwoWay}">
                    <ComboBoxItem Content="{CompiledBinding Translation.Reverse.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
                    <ComboBoxItem Content="{CompiledBinding Translation.Forward.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
                </ComboBox>
            </StackPanel>
        </Border>

        <Border ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.MouseTouchpadSearchTags}" Classes="searchBorder">
            <StackPanel>
                <customControls:TextIconButton
                    x:Name="TouchPadButton"
                    Classes="altHover settingsTextIconButton"
                    Command="{CompiledBinding SettingsViewModel.ToggleUsingTouchpadCommand}"
                    Icon="{StaticResource TouchPadImage}"
                    IconHeight="18"
                    IconMargin="10,0,10,0"
                    IconWidth="18"
                    IsVisible="{CompiledBinding SettingsViewModel.IsUsingTouchpad.Value}"
                    Text="{CompiledBinding Translation.IsUsingTouchpad.Value,
                                           Mode=OneWay}"
                    TextMargin="0,1,5,0"
                    TextMaxWidth="240" />
                <customControls:TextIconButton
                    x:Name="MouseButton"
                    Classes="altHover settingsTextIconButton"
                    Command="{CompiledBinding SettingsViewModel.ToggleUsingTouchpadCommand}"
                    Icon="{StaticResource MouseWheelIcon}"
                    IconHeight="18"
                    IconMargin="10,0,10,0"
                    IconWidth="18"
                    IsVisible="{CompiledBinding !SettingsViewModel.IsUsingTouchpad.Value}"
                    Text="{CompiledBinding Translation.IsUsingTouchpad.Value,
                                           Mode=OneWay}"
                    TextMargin="0,1,5,0"
                    TextMaxWidth="240" />
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>