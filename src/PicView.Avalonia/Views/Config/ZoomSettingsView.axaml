<UserControl
    x:Class="PicView.Avalonia.Views.Config.ZoomSettingsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:ui="clr-namespace:PicView.Avalonia.UI"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    x:DataType="viewModels:CoreViewModel">

    <StackPanel HorizontalAlignment="Center" Orientation="Vertical">

        <StackPanel Classes="searchHeader">
            <Image
                Width="18"
                Height="18"
                Source="{StaticResource ZoomImage}" />
            <TextBlock
                Margin="0,20,0,20"
                Classes="txt bold"
                Text="{CompiledBinding Translation.Zoom.Value,
                                       Mode=OneWay}" />
        </StackPanel>

        <!--  Zoom to fit  -->
        <Border ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.ImageZoomToFitSearchTags}" Classes="searchBorder">
            <customControls:TextToggleButton
                x:Name="ZoomToFitToggleButton"
                Classes="altHover settingsToggleButton"
                Command="{Binding MainWindows.ActiveWindow.Value.ZoomToFitCommand}"
                IsChecked="{Binding MainWindows.ActiveWindow.Value.IsZoomedToFit.Value, Mode=TwoWay}"
                Text="{CompiledBinding Translation.ZoomToFit.Value,
                                       Mode=OneWay}"
                ToolTip.Tip="{CompiledBinding Translation.ZoomToFit.Value,
                                              Mode=OneWay}" />
        </Border>

        <Border ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.ZoomResetSearchTags}" Classes="searchBorder">
            <customControls:TextToggleButton
                x:Name="ResetZoomToggleButton"
                Classes="altHover settingsToggleButton"
                IsChecked="{CompiledBinding SettingsViewModel.IsResettingZoomOnImageChange.Value}"
                Text="{CompiledBinding Translation.ResetZoomOnChange.Value,
                                       Mode=OneWay}" />
        </Border>

        <Border ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.ZoomOutSearchTags}" Classes="searchBorder">
            <customControls:TextToggleButton
                x:Name="AllowZoomOutToggleButton"
                Classes="altHover settingsToggleButton"
                IsChecked="{CompiledBinding SettingsViewModel.IsAvoidingZoomingOut.Value}"
                Text="{CompiledBinding Translation.AllowZoomOut.Value,
                                       Mode=OneWay}" />
        </Border>

        <Border ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.ZoomAnimationSearchTags}" Classes="searchBorder">
            <customControls:TextToggleButton
                x:Name="UseAnimatedZoomToggleButton"
                Classes="altHover settingsToggleButton"
                IsChecked="{CompiledBinding SettingsViewModel.IsZoomAnimated.Value}"
                Text="{CompiledBinding Translation.UseAnimatedZoom.Value,
                                       Mode=OneWay}" />
        </Border>

        <Border ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.ZoomPopupSearchTags}" Classes="searchBorder">
            <customControls:TextToggleButton
                x:Name="ShowZoomPercentageToggleButton"
                Classes="altHover settingsToggleButton"
                IsChecked="{CompiledBinding SettingsViewModel.IsShowingZoomPercentagePopup.Value}"
                Text="{CompiledBinding Translation.ShowZoomPercentagePopup.Value,
                                       Mode=OneWay}" />
        </Border>

        <Border ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.ZoomPreviewerSearchTags}" Classes="searchBorder">
            <customControls:TextToggleButton
                x:Name="ShowZoomPreviewerToggleButton"
                Classes="altHover settingsToggleButton"
                IsChecked="{CompiledBinding SettingsViewModel.IsShowingZoomPreviewer.Value}"
                Text="{CompiledBinding Translation.ShowZoomPreviewer.Value,
                                       Mode=OneWay}" />
        </Border>

        <Border ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.ZoomSpeedSearchTags}" Classes="searchBorder">
            <StackPanel>
                <TextBlock
                    MaxWidth="300"
                    Margin="0,10,0,10"
                    Classes="txt bold"
                    Text="{CompiledBinding Translation.AdjustTimingForZoom.Value,
                                           Mode=OneWay}" />
                <customControls:CustomSlider
                    Width="300"
                    Height="30"
                    Margin="0,1,0,1"
                    HorizontalAlignment="Center"
                    IsSnapToTickEnabled="True"
                    Maximum="1.5"
                    Minimum=".1"
                    TickFrequency=".05"
                    TickPlacement="BottomRight"
                    Value="{CompiledBinding SettingsViewModel.ZoomSpeed.Value}" />

                <TextBlock
                    Margin="0,0,0,15"
                    Classes="txt"
                    FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                    Text="{CompiledBinding SettingsViewModel.GetZoomSpeed.Value,
                                           Mode=OneWay}" />
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>