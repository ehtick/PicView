<UserControl
    x:Class="PicView.Avalonia.Views.Config.ZoomSettingsView2"
    x:DataType="viewModels:CoreViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel HorizontalAlignment="Center" Orientation="Vertical">

        <TextBlock
            Classes="txt bold"
            Margin="0,20,0,20"
            Text="{CompiledBinding Translation.Zoom.Value,
                                   Mode=OneWay}" />

        <ToggleButton
            Background="Transparent"
            BorderThickness="0"
            Classes="altHover changeColor"
            IsChecked="{CompiledBinding SettingsViewModel.IsResettingZoomOnImageChange.Value}"
            Margin="0,0,0,10"
            Width="300">
            <TextBlock
                Classes="txt"
                Foreground="{StaticResource SecondaryTextColor}"
                Margin="0"
                MaxWidth="240"
                Padding="0,1,5,0"
                Text="{CompiledBinding Translation.ResetZoomOnChange.Value,
                                       Mode=OneWay}" />
        </ToggleButton>

        <ToggleButton
            Background="Transparent"
            BorderThickness="0"
            Classes="altHover changeColor"
            IsChecked="{CompiledBinding SettingsViewModel.IsAvoidingZoomingOut.Value}"
            Margin="0,0,0,10"
            Width="300">
            <TextBlock
                Classes="txt"
                Foreground="{StaticResource SecondaryTextColor}"
                Margin="0"
                MaxWidth="240"
                Padding="0,1,5,0"
                Text="{CompiledBinding Translation.AllowZoomOut.Value,
                                       Mode=OneWay}" />
        </ToggleButton>

        <ToggleButton
            Background="Transparent"
            BorderThickness="0"
            Classes="altHover changeColor"
            IsChecked="{CompiledBinding SettingsViewModel.IsZoomAnimated.Value}"
            Margin="0,0,0,10"
            Width="300">
            <TextBlock
                Classes="txt"
                Foreground="{StaticResource SecondaryTextColor}"
                Margin="0"
                MaxWidth="240"
                Padding="0,1,5,0"
                Text="{CompiledBinding Translation.UseAnimatedZoom.Value,
                                       Mode=OneWay}" />
        </ToggleButton>

        <ToggleButton
            Background="Transparent"
            BorderThickness="0"
            Classes="altHover changeColor"
            IsChecked="{CompiledBinding SettingsViewModel.IsShowingZoomPercentagePopup.Value}"
            Margin="0,0,0,10"
            Width="300">
            <TextBlock
                Classes="txt"
                Foreground="{StaticResource SecondaryTextColor}"
                Margin="0"
                MaxWidth="240"
                Padding="0,1,5,0"
                Text="{CompiledBinding Translation.ShowZoomPercentagePopup.Value,
                                       Mode=OneWay}" />
        </ToggleButton>

        <ComboBox
            Background="{DynamicResource SecondaryBackgroundColor}"
            BorderBrush="{DynamicResource MainBorderColor}"
            BorderThickness="1"
            FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
            Foreground="{DynamicResource MainTextColor}"
            Margin="0,6,0,15"
            Padding="5,7,0,7"
            SelectedIndex="{CompiledBinding SettingsViewModel.MouseWheelBehavior.Value, Mode=TwoWay}"
            Width="300"
            x:Name="MouseWheelBox">
            <ComboBoxItem Content="{CompiledBinding Translation.CtrlToZoom.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
            <ComboBoxItem Content="{CompiledBinding Translation.ScrollToZoom.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
        </ComboBox>

        <TextBlock
            Classes="txt"
            FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
            FontSize="12"
            Foreground="{StaticResource SecondaryTextColor}"
            Margin="0,10,0,10"
            MaxWidth="300"
            Text="{CompiledBinding Translation.AdjustTimingForZoom.Value,
                                   Mode=OneWay}" />
        <customControls:CustomSlider
            Height="30"
            HorizontalAlignment="Center"
            IsSnapToTickEnabled="True"
            Margin="0,1,0,1"
            Maximum="1.5"
            Minimum=".1"
            TickFrequency=".05"
            TickPlacement="BottomRight"
            Value="{CompiledBinding SettingsViewModel.ZoomSpeed.Value}"
            Width="300" />
        <TextBlock
            Classes="txt"
            FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
            Foreground="{StaticResource MainTextColorFaded}"
            Margin="0,0,0,15"
            Text="{CompiledBinding SettingsViewModel.GetZoomSpeed.Value,
                                   Mode=OneWay}" />

    </StackPanel>
</UserControl>
