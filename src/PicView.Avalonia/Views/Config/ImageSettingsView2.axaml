<UserControl
    x:Class="PicView.Avalonia.Views.Config.ImageSettingsView2"
    x:DataType="viewModels:CoreViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel HorizontalAlignment="Center" Orientation="Vertical">
        <TextBlock
            Classes="txt bold"
            Margin="0,20,0,20"
            Text="{CompiledBinding Translation.Image.Value,
                                   Mode=OneWay}" />

        <ToggleButton
            Background="Transparent"
            BorderThickness="0"
            Classes="altHover changeColor"
            IsChecked="{CompiledBinding GlobalSettings.IsStretched.Value}"
            Margin="0,0,0,10"
            ToolTip.Tip="{CompiledBinding Translation.Stretch.Value,
                                          Mode=OneWay}"
            Width="300">
            <TextBlock
                Classes="txt"
                Foreground="{StaticResource SecondaryTextColor}"
                Margin="0"
                MaxWidth="240"
                Padding="0,1,5,0"
                Text="{CompiledBinding Translation.Stretch.Value,
                                       Mode=OneWay}" />
        </ToggleButton>

        <ToggleButton
            Background="Transparent"
            BorderThickness="0"
            Classes="altHover changeColor"
            Command="{CompiledBinding MainWindows.ActiveWindow.Value.ToggleScrollCommand}"
            IsChecked="{CompiledBinding GlobalSettings.IsScrollingEnabled.Value}"
            Margin="0,0,0,10"
            Width="300">
            <TextBlock
                Classes="txt"
                Foreground="{StaticResource SecondaryTextColor}"
                Margin="0"
                MaxWidth="240"
                Padding="0,1,5,0"
                Text="{CompiledBinding Translation.IsScrolling.Value,
                                       Mode=OneWay}" />
        </ToggleButton>


        <ToggleButton
            Background="Transparent"
            BorderThickness="0"
            Classes="altHover changeColor"
            Command="{CompiledBinding MainWindows.ActiveWindow.Value.SideBySideCommand}"
            Margin="0,0,0,10"
            Width="300">
            <TextBlock
                Classes="txt"
                Foreground="{StaticResource SecondaryTextColor}"
                Margin="0"
                MaxWidth="240"
                Padding="0,1,5,0"
                Text="{CompiledBinding Translation.SideBySide.Value,
                                       Mode=OneWay}" />
        </ToggleButton>

        <TextBlock
            Classes="txt bold"
            Margin="0,20,0,20"
            Text="{CompiledBinding Translation.ImageAliasing.Value,
                                   Mode=OneWay}" />
        <ComboBox
            Background="{DynamicResource SecondaryBackgroundColor}"
            BorderBrush="{DynamicResource MainBorderColor}"
            BorderThickness="1"
            FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
            Foreground="{DynamicResource MainTextColor}"
            Margin="0,6,0,10"
            Padding="5,7,0,7"
            SelectedIndex="{CompiledBinding SettingsViewModel.ImageScalingIndex.Value, Mode=TwoWay}"
            Width="300"
            x:Name="ImageAliasingBox">
            <ComboBoxItem Content="{CompiledBinding Translation.HighQuality.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
            <ComboBoxItem Content="{CompiledBinding Translation.None.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
        </ComboBox>

    </StackPanel>
</UserControl>
