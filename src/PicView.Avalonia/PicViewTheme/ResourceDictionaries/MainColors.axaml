<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:ClassModifier="internal">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <Color x:Key="MainTextColor">#E2E0E0</Color>
            <Color x:Key="MainTextColorFaded">#d6d4d4</Color>
            <SolidColorBrush x:Key="MainTextColorFadedBrush" Color="{StaticResource MainTextColorFaded}" />

            <!--  Used for icons that should stay white in both themes  -->
            <Color x:Key="SecondaryTextColor">#fff</Color>

            <Color x:Key="MainBackgroundColor">#CC2b2b2b</Color>
            <Color x:Key="SecondaryBackgroundColor">#CC252525</Color>
            <Color x:Key="TertiaryBackgroundColor">#CC303030</Color>

            <Color x:Key="DisabledBackgroundColor">#4F4F4F</Color>
            <Color x:Key="DisabledTextColor">#d6d4d4</Color>

            <Color x:Key="BackgroundHoverColor">#FF4B4B4B</Color>

            <Color x:Key="AltBackgroundHoverColor">#22FFFFFF</Color>
            <Color x:Key="AltBackgroundColor">#A7222222</Color>

            <Color x:Key="MainButtonBackgroundColor">#CC252525</Color>
            <Color x:Key="SecondaryButtonBackgroundColor">#FF2e2e2e</Color>

            <Color x:Key="MainBorderColor">#FF3A3A3A</Color>
            <Color x:Key="SecondaryBorderColor">#777</Color>
            <Color x:Key="TertiaryBorderColor">#A4646464</Color>

            <Color x:Key="OuterBorderColor">#FF3A3A3A</Color>

            <Color x:Key="ButtonForegroundPointerOver">#FFF</Color>

            <Color x:Key="MenuBackgroundColor">#292929</Color>
            <Color x:Key="MenuButtonColor">#2F2F2F</Color>

            <Color x:Key="ContextMenuBackgroundColor">#EE2b2b2b</Color>
            <Color x:Key="ContextMenuTextColor">#EDEBEB</Color>

            <Color x:Key="WindowBackgroundColor">#C4252525</Color>
            <Color x:Key="WindowSecondaryBackgroundColor">#FF303030</Color>
            <Color x:Key="WindowBorderColor">#FF3A3A3A</Color>
            <Color x:Key="WindowButtonBackgroundColor">#FF2B2B2B</Color>

            <Color x:Key="DropDownBgColor">#303030</Color>

            <Color x:Key="DarkenBgColor">#14000000</Color>

            <Color x:Key="DarkenSelected">#FF252525</Color>

            <Color x:Key="SoftenColor">#491A1A1A</Color>
            <SolidColorBrush x:Key="SoftenColorBrush" Color="{DynamicResource SoftenColor}" />

            <ImageBrush
                x:Key="NoisyTexture"
                DestinationRect="0,0,200,200"
                Opacity=".6"
                Source="/PicViewTheme/Resources/noisy-texture-200x200-o4-d31-c-161616-t0.png"
                Stretch="Fill"
                TileMode="FlipXY" />

            <DropShadowDirectionEffect
                x:Key="TextShadow"
                BlurRadius="1"
                Direction="360"
                Color="#E6000000" />

            <Color x:Key="ErrorColor">#B51522</Color>
            <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
        </ResourceDictionary>


        <ResourceDictionary x:Key="Light">
            <Color x:Key="MainTextColor">#424242</Color>
            <Color x:Key="MainTextColorFaded">#DD9A98B7</Color>

            <Color x:Key="MainBackgroundColor">White</Color>
            <Color x:Key="SecondaryBackgroundColor">#F3FFFFFF</Color>
            <Color x:Key="TertiaryBackgroundColor">#E29E9E9E</Color>

            <Color x:Key="DisabledBackgroundColor">#B8CFCFCF</Color>
            <Color x:Key="DisabledTextColor">#ACA1A1A1</Color>

            <Color x:Key="BackgroundHoverColor">#A2EEEEEE</Color>

            <Color x:Key="AltBackgroundHoverColor">#1CF0F0F0</Color>
            <Color x:Key="AltBackgroundColor">#A7FFFFFF</Color>

            <Color x:Key="MainButtonBackgroundColor">#fff</Color>
            <Color x:Key="SecondaryButtonBackgroundColor">WhiteSmoke</Color>

            <Color x:Key="MainBorderColor">#DEDEDE</Color>
            <Color x:Key="SecondaryBorderColor">#95B5B5B5</Color>
            <Color x:Key="TertiaryBorderColor">#CFABABAB</Color>

            <Color x:Key="OuterBorderColor">#78B5B5B5</Color>

            <Color x:Key="ButtonForegroundPointerOver">#FFF</Color>

            <Color x:Key="MenuBackgroundColor">#ECF8F8F8</Color>
            <Color x:Key="MenuButtonColor">#fff</Color>

            <Color x:Key="ContextMenuBackgroundColor">#E3FFFFFF</Color>
            <Color x:Key="ContextMenuTextColor">#2B251E</Color>

            <Color x:Key="WindowBackgroundColor">#fff</Color>
            <Color x:Key="WindowSecondaryBackgroundColor">#fff</Color>
            <Color x:Key="WindowBorderColor">#39FFFFFF</Color>
            <Color x:Key="WindowButtonBackgroundColor">#fff</Color>

            <Color x:Key="SoftenColor">#fff</Color>

            <Color x:Key="DropDownBgColor">#F3F8F8F8</Color>

            <Color x:Key="NoisyTexture">#17FFFFFF</Color>


        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>