<ResourceDictionary
    x:ClassModifier="internal"
    xmlns="https://github.com/avaloniaui"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ControlTheme TargetType="customControls:AutoScrollViewer" x:Key="{x:Type customControls:AutoScrollViewer}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="*,Auto">
                    <ScrollContentPresenter
                        Background="{TemplateBinding Background}"
                        HorizontalSnapPointsAlignment="{TemplateBinding HorizontalSnapPointsAlignment}"
                        HorizontalSnapPointsType="{TemplateBinding HorizontalSnapPointsType}"
                        Name="PART_ContentPresenter"
                        Padding="{TemplateBinding Padding}"
                        ScrollViewer.IsScrollInertiaEnabled="{TemplateBinding IsScrollInertiaEnabled}"
                        VerticalSnapPointsAlignment="{TemplateBinding VerticalSnapPointsAlignment}"
                        VerticalSnapPointsType="{TemplateBinding VerticalSnapPointsType}">
                        <ScrollContentPresenter.GestureRecognizers>
                            <ScrollGestureRecognizer
                                CanHorizontallyScroll="{Binding CanHorizontallyScroll, ElementName=PART_ContentPresenter}"
                                CanVerticallyScroll="{Binding CanVerticallyScroll, ElementName=PART_ContentPresenter}"
                                IsScrollInertiaEnabled="{Binding (ScrollViewer.IsScrollInertiaEnabled), ElementName=PART_ContentPresenter}" />
                        </ScrollContentPresenter.GestureRecognizers>
                    </ScrollContentPresenter>
                    <ScrollBar
                        Grid.Column="0"
                        Grid.Row="1"
                        Name="PART_HorizontalScrollBar"
                        Orientation="Horizontal" />
                    <ScrollBar
                        Grid.Column="1"
                        Grid.Row="0"
                        Name="PART_VerticalScrollBar"
                        Orientation="Vertical" />
                    <Canvas Grid.Column="0" Grid.Row="0">
                        <customControls:AutoScrollSign
                            HorizontalAlignment="Center"
                            IsVisible="False"
                            Name="PART_AutoScrollSign"
                            VerticalAlignment="Center" />
                    </Canvas>
                </Grid>
            </ControlTemplate>
        </Setter>

    </ControlTheme>

    <ControlTheme TargetType="customControls:AutoScrollViewer" x:Key="Main">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="*,Auto">
                    <ScrollContentPresenter
                        Background="{TemplateBinding Background}"
                        HorizontalSnapPointsAlignment="{TemplateBinding HorizontalSnapPointsAlignment}"
                        HorizontalSnapPointsType="{TemplateBinding HorizontalSnapPointsType}"
                        Name="PART_ContentPresenter"
                        Padding="{TemplateBinding Padding}"
                        ScrollViewer.IsScrollInertiaEnabled="{TemplateBinding IsScrollInertiaEnabled}"
                        VerticalSnapPointsAlignment="{TemplateBinding VerticalSnapPointsAlignment}"
                        VerticalSnapPointsType="{TemplateBinding VerticalSnapPointsType}">
                        <ScrollContentPresenter.GestureRecognizers>
                            <ScrollGestureRecognizer
                                CanHorizontallyScroll="{Binding CanHorizontallyScroll, ElementName=PART_ContentPresenter}"
                                CanVerticallyScroll="{Binding CanVerticallyScroll, ElementName=PART_ContentPresenter}"
                                IsScrollInertiaEnabled="{Binding (ScrollViewer.IsScrollInertiaEnabled), ElementName=PART_ContentPresenter}" />
                        </ScrollContentPresenter.GestureRecognizers>
                    </ScrollContentPresenter>
                    <ScrollBar
                        Grid.Column="0"
                        Grid.Row="1"
                        Name="PART_HorizontalScrollBar"
                        Orientation="Horizontal"
                        Theme="{StaticResource MainScrollbar}" />
                    <ScrollBar
                        Grid.Column="1"
                        Grid.Row="0"
                        Name="PART_VerticalScrollBar"
                        Orientation="Vertical"
                        Theme="{StaticResource MainScrollbar}" />
                    <Canvas Grid.Column="0" Grid.Row="0">
                        <customControls:AutoScrollSign
                            HorizontalAlignment="Center"
                            IsVisible="False"
                            Name="PART_AutoScrollSign"
                            VerticalAlignment="Center" />
                    </Canvas>
                </Grid>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme TargetType="customControls:AutoScrollViewer" x:Key="Inline">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <ScrollContentPresenter
                        Background="Transparent"
                        HorizontalSnapPointsAlignment="{TemplateBinding HorizontalSnapPointsAlignment}"
                        HorizontalSnapPointsType="{TemplateBinding HorizontalSnapPointsType}"
                        Name="PART_ContentPresenter"
                        Padding="{TemplateBinding Padding}"
                        ScrollViewer.IsScrollInertiaEnabled="{TemplateBinding IsScrollInertiaEnabled}"
                        VerticalSnapPointsAlignment="{TemplateBinding VerticalSnapPointsAlignment}"
                        VerticalSnapPointsType="{TemplateBinding VerticalSnapPointsType}">
                        <ScrollContentPresenter.GestureRecognizers>
                            <ScrollGestureRecognizer
                                CanHorizontallyScroll="{Binding CanHorizontallyScroll, ElementName=PART_ContentPresenter}"
                                CanVerticallyScroll="{Binding CanVerticallyScroll, ElementName=PART_ContentPresenter}"
                                IsScrollInertiaEnabled="{Binding (ScrollViewer.IsScrollInertiaEnabled), ElementName=PART_ContentPresenter}" />
                        </ScrollContentPresenter.GestureRecognizers>
                    </ScrollContentPresenter>
                    <ScrollBar
                        Name="PART_HorizontalScrollBar"
                        Orientation="Horizontal"
                        Theme="{StaticResource Floating}" />
                    <ScrollBar
                        HorizontalAlignment="Right"
                        Name="PART_VerticalScrollBar"
                        Orientation="Vertical"
                        Theme="{StaticResource Floating}" />
                    <Canvas>
                        <customControls:AutoScrollSign
                            HorizontalAlignment="Center"
                            IsVisible="False"
                            Name="PART_AutoScrollSign"
                            VerticalAlignment="Center" />
                    </Canvas>
                </Panel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme TargetType="customControls:AutoScrollViewer" x:Key="InlineSlim">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <ScrollContentPresenter
                        Background="Transparent"
                        HorizontalSnapPointsAlignment="{TemplateBinding HorizontalSnapPointsAlignment}"
                        HorizontalSnapPointsType="{TemplateBinding HorizontalSnapPointsType}"
                        Name="PART_ContentPresenter"
                        Padding="{TemplateBinding Padding}"
                        ScrollViewer.IsScrollInertiaEnabled="{TemplateBinding IsScrollInertiaEnabled}"
                        VerticalSnapPointsAlignment="{TemplateBinding VerticalSnapPointsAlignment}"
                        VerticalSnapPointsType="{TemplateBinding VerticalSnapPointsType}">
                        <ScrollContentPresenter.GestureRecognizers>
                            <ScrollGestureRecognizer
                                CanHorizontallyScroll="{Binding CanHorizontallyScroll, ElementName=PART_ContentPresenter}"
                                CanVerticallyScroll="{Binding CanVerticallyScroll, ElementName=PART_ContentPresenter}"
                                IsScrollInertiaEnabled="{Binding (ScrollViewer.IsScrollInertiaEnabled), ElementName=PART_ContentPresenter}" />
                        </ScrollContentPresenter.GestureRecognizers>
                    </ScrollContentPresenter>
                    <ScrollBar
                        Name="PART_HorizontalScrollBar"
                        Opacity="0"
                        Orientation="Horizontal"
                        Theme="{StaticResource FloatingSlim}">
                        <ScrollBar.Transitions>
                            <Transitions>
                                <DoubleTransition
                                    Duration="0:0:0.45"
                                    Easing="CubicEaseOut"
                                    Property="Opacity" />
                            </Transitions>
                        </ScrollBar.Transitions>
                    </ScrollBar>
                    <ScrollBar
                        HorizontalAlignment="Right"
                        Name="PART_VerticalScrollBar"
                        Orientation="Vertical"
                        Theme="{StaticResource FloatingSlim}" />
                    <Canvas>
                        <customControls:AutoScrollSign
                            HorizontalAlignment="Center"
                            IsVisible="False"
                            Name="PART_AutoScrollSign"
                            VerticalAlignment="Center" />
                    </Canvas>
                </Panel>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover /template/ ScrollBar#PART_HorizontalScrollBar">
            <Setter Property="Opacity" Value="1" />
        </Style>

    </ControlTheme>

    <ControlTheme TargetType="customControls:AutoScrollViewer" x:Key="MenuScrollerOverlay">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <ScrollContentPresenter
                        Background="Transparent"
                        HorizontalSnapPointsAlignment="{TemplateBinding HorizontalSnapPointsAlignment}"
                        HorizontalSnapPointsType="{TemplateBinding HorizontalSnapPointsType}"
                        Name="PART_ContentPresenter"
                        Padding="{TemplateBinding Padding}"
                        ScrollViewer.IsScrollInertiaEnabled="{TemplateBinding IsScrollInertiaEnabled}"
                        VerticalSnapPointsAlignment="{TemplateBinding VerticalSnapPointsAlignment}"
                        VerticalSnapPointsType="{TemplateBinding VerticalSnapPointsType}">
                        <ScrollContentPresenter.GestureRecognizers>
                            <ScrollGestureRecognizer
                                CanHorizontallyScroll="{Binding CanHorizontallyScroll, ElementName=PART_ContentPresenter}"
                                CanVerticallyScroll="{Binding CanVerticallyScroll, ElementName=PART_ContentPresenter}"
                                IsScrollInertiaEnabled="{Binding (ScrollViewer.IsScrollInertiaEnabled), ElementName=PART_ContentPresenter}" />
                        </ScrollContentPresenter.GestureRecognizers>
                    </ScrollContentPresenter>

                    <customControls:IconButton
                        Command="{Binding PageUp, RelativeSource={RelativeSource TemplatedParent}}"
                        Cursor="Hand"
                        Data="{StaticResource FilledArrowUpGeometry}"
                        Foreground="{TemplateBinding Foreground}"
                        Height="30"
                        HorizontalContentAlignment="Center"
                        IconHeight="16"
                        IconWidth="16"
                        IsVisible="{Binding CanScrollUp, RelativeSource={RelativeSource TemplatedParent}}"
                        VerticalAlignment="Top"
                        VerticalContentAlignment="Center">
                        <customControls:IconButton.Background>
                            <LinearGradientBrush EndPoint="50%,100%" Opacity=".7" StartPoint="50%,0%">
                                <GradientStop Color="#EE161616" Offset="0" />
                                <GradientStop Color="#9B161616" Offset="1" />
                            </LinearGradientBrush>
                        </customControls:IconButton.Background>

                    </customControls:IconButton>

                    <customControls:IconButton
                        Command="{Binding PageDown, RelativeSource={RelativeSource TemplatedParent}}"
                        Cursor="Hand"
                        Data="{StaticResource FilledArrowDownGeometry}"
                        Foreground="{TemplateBinding Foreground}"
                        Height="30"
                        HorizontalContentAlignment="Center"
                        IconHeight="16"
                        IconWidth="16"
                        IsVisible="{Binding CanScrollDown, RelativeSource={RelativeSource TemplatedParent}}"
                        VerticalAlignment="Bottom"
                        VerticalContentAlignment="Center">
                        <customControls:IconButton.Background>
                            <LinearGradientBrush EndPoint="50%,100%" Opacity=".7" StartPoint="50%,0%">
                                <GradientStop Color="#EE161616" Offset="0" />
                                <GradientStop Color="#9B161616" Offset="1" />
                            </LinearGradientBrush>
                        </customControls:IconButton.Background>

                    </customControls:IconButton>

                    <ScrollBar
                        Name="PART_HorizontalScrollBar"
                        Orientation="Horizontal"
                        Theme="{StaticResource FloatingSlim}" />
                    <ScrollBar
                        HorizontalAlignment="Right"
                        Name="PART_VerticalScrollBar"
                        Orientation="Vertical"
                        Theme="{StaticResource FloatingSlim}"
                        Visibility="Hidden" />
                    <Canvas>
                        <customControls:AutoScrollSign
                            HorizontalAlignment="Center"
                            IsVisible="False"
                            Name="PART_AutoScrollSign"
                            VerticalAlignment="Center" />
                    </Canvas>
                </Panel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme TargetType="customControls:AutoScrollViewer" x:Key="OverlayScroller">
        <Setter Property="Background" Value="Transparent" />

        <!--  Auto hide  -->
        <Setter Property="AllowAutoHide" Value="True" />
        <Style Selector="^[AllowAutoHide=True]:not(:pointerover) /template/ ScrollBar">
            <Setter Property="Opacity" Value="0" />
        </Style>
        <Style Selector="^[AllowAutoHide=True]:scrolling /template/ ScrollBar">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <ScrollContentPresenter
                        Background="Transparent"
                        HorizontalSnapPointsAlignment="{TemplateBinding HorizontalSnapPointsAlignment}"
                        HorizontalSnapPointsType="{TemplateBinding HorizontalSnapPointsType}"
                        Name="PART_ContentPresenter"
                        Padding="{TemplateBinding Padding}"
                        ScrollViewer.IsScrollInertiaEnabled="{TemplateBinding IsScrollInertiaEnabled}"
                        VerticalSnapPointsAlignment="{TemplateBinding VerticalSnapPointsAlignment}"
                        VerticalSnapPointsType="{TemplateBinding VerticalSnapPointsType}">
                        <ScrollContentPresenter.GestureRecognizers>
                            <ScrollGestureRecognizer
                                CanHorizontallyScroll="{Binding CanHorizontallyScroll, ElementName=PART_ContentPresenter}"
                                CanVerticallyScroll="{Binding CanVerticallyScroll, ElementName=PART_ContentPresenter}"
                                IsScrollInertiaEnabled="{Binding (ScrollViewer.IsScrollInertiaEnabled), ElementName=PART_ContentPresenter}" />
                        </ScrollContentPresenter.GestureRecognizers>
                    </ScrollContentPresenter>

                    <Border
                        Background="{DynamicResource MenuBackgroundColor}"
                        IsVisible="{CompiledBinding CanScrollUp,
                                                    RelativeSource={RelativeSource TemplatedParent}}"
                        VerticalAlignment="Top">
                        <StackPanel>
                            <Button
                                Background="{DynamicResource MenuBackgroundColor}"
                                BorderBrush="{DynamicResource MainBorderColor}"
                                BorderThickness="0,0,0,1"
                                Classes="menuButtonHover"
                                Command="{CompiledBinding ScrollToHome,
                                                          RelativeSource={RelativeSource TemplatedParent}}"
                                Cursor="Hand"
                                Foreground="{TemplateBinding Foreground}"
                                Height="25"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center">
                                <Path
                                    Data="{StaticResource PlaySkipForwardGeometry}"
                                    Fill="{TemplateBinding Foreground}"
                                    Height="12"
                                    Stretch="Fill"
                                    Width="12">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="-90" />
                                    </Path.RenderTransform>
                                </Path>
                            </Button>

                            <Button
                                Background="{DynamicResource MenuBackgroundColor}"
                                BorderBrush="{DynamicResource MainBorderColor}"
                                BorderThickness="0,0,0,1"
                                Classes="menuButtonHover"
                                Command="{CompiledBinding PageUp,
                                                          RelativeSource={RelativeSource TemplatedParent}}"
                                Cursor="Hand"
                                Foreground="{TemplateBinding Foreground}"
                                Height="25"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center">
                                <Path
                                    Data="{StaticResource FilledChevronUpGeometry}"
                                    Fill="{TemplateBinding Foreground}"
                                    Height="12"
                                    Stretch="Fill"
                                    Width="12" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border
                        Background="{DynamicResource MainBackgroundColor}"
                        BorderBrush="{DynamicResource MainBorderColor}"
                        BorderThickness="0,0,0,1"
                        IsVisible="{CompiledBinding CanScrollDown,
                                                    RelativeSource={RelativeSource TemplatedParent}}"
                        VerticalAlignment="Bottom">
                        <StackPanel>
                            <Button
                                Background="{DynamicResource MainBackgroundColor}"
                                BorderBrush="{DynamicResource MainBorderColor}"
                                BorderThickness="0,0,0,1"
                                Classes="hover"
                                Command="{CompiledBinding PageDown,
                                                          RelativeSource={RelativeSource TemplatedParent}}"
                                Cursor="Hand"
                                Foreground="{TemplateBinding Foreground}"
                                Height="25"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center">
                                <Path
                                    Data="{StaticResource FilledChevronDownGeometry}"
                                    Fill="{TemplateBinding Foreground}"
                                    Height="12"
                                    Stretch="Fill"
                                    Width="12" />
                            </Button>

                            <Button
                                Background="{DynamicResource MainBackgroundColor}"
                                BorderBrush="{DynamicResource MainBorderColor}"
                                BorderThickness="0,0,0,1"
                                Classes="menuButtonHover"
                                Command="{CompiledBinding ScrollToEnd,
                                                          RelativeSource={RelativeSource TemplatedParent}}"
                                Cursor="Hand"
                                Foreground="{TemplateBinding Foreground}"
                                Height="25"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center">
                                <Path
                                    Data="{StaticResource PlaySkipForwardGeometry}"
                                    Fill="{TemplateBinding Foreground}"
                                    Height="12"
                                    Stretch="Fill"
                                    Width="12">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="-270" />
                                    </Path.RenderTransform>
                                </Path>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border
                        Background="{DynamicResource MainBackgroundColor}"
                        BorderBrush="{DynamicResource MainBorderColor}"
                        BorderThickness="0,0,1,0"
                        HorizontalAlignment="Left"
                        IsVisible="{CompiledBinding CanScrollLeft,
                                                    RelativeSource={RelativeSource TemplatedParent}}"
                        VerticalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">

                            <Button
                                Background="{DynamicResource MainBackgroundColor}"
                                BorderBrush="{DynamicResource MainBorderColor}"
                                BorderThickness="0,0,1,0"
                                Classes="hover"
                                Command="{CompiledBinding ScrollToHome,
                                                          RelativeSource={RelativeSource TemplatedParent}}"
                                Cursor="Hand"
                                Foreground="{TemplateBinding Foreground}"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Width="25">
                                <Path
                                    Data="{StaticResource PlaySkipForwardGeometry}"
                                    Fill="{TemplateBinding Foreground}"
                                    Height="12"
                                    Stretch="Fill"
                                    Width="12">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="-180" />
                                    </Path.RenderTransform>
                                </Path>
                            </Button>

                            <Button
                                Background="{DynamicResource MainBackgroundColor}"
                                BorderBrush="{DynamicResource MainBorderColor}"
                                Classes="hover"
                                Command="{CompiledBinding PageLeft,
                                                          RelativeSource={RelativeSource TemplatedParent}}"
                                Cursor="Hand"
                                Foreground="{TemplateBinding Foreground}"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Width="25">
                                <Path
                                    Data="{StaticResource FilledChevronLeftGeometry}"
                                    Fill="{TemplateBinding Foreground}"
                                    Height="12"
                                    Stretch="Fill"
                                    Width="12" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border
                        Background="{DynamicResource MainBackgroundColor}"
                        BorderBrush="{DynamicResource MainBorderColor}"
                        BorderThickness="1,0,0,0"
                        HorizontalAlignment="Right"
                        IsVisible="{CompiledBinding CanScrollRight,
                                                    RelativeSource={RelativeSource TemplatedParent}}"
                        VerticalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">

                            <Button
                                Background="{DynamicResource MainBackgroundColor}"
                                BorderBrush="{DynamicResource MainBorderColor}"
                                BorderThickness="0,0,1,0"
                                Classes="hover"
                                Command="{CompiledBinding PageRight,
                                                          RelativeSource={RelativeSource TemplatedParent}}"
                                Cursor="Hand"
                                Foreground="{TemplateBinding Foreground}"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Width="25">
                                <Path
                                    Data="{StaticResource FilledChevronRightGeometry}"
                                    Fill="{TemplateBinding Foreground}"
                                    Height="12"
                                    Stretch="Fill"
                                    Width="12" />
                            </Button>

                            <Button
                                Background="{DynamicResource MainBackgroundColor}"
                                BorderBrush="{DynamicResource MainBorderColor}"
                                Classes="hover"
                                Command="{CompiledBinding ScrollToRightEnd,
                                                          RelativeSource={RelativeSource TemplatedParent}}"
                                Cursor="Hand"
                                Foreground="{TemplateBinding Foreground}"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Width="25">
                                <Path
                                    Data="{StaticResource PlaySkipForwardGeometry}"
                                    Fill="{TemplateBinding Foreground}"
                                    Height="12"
                                    Stretch="Fill"
                                    Width="12" />
                            </Button>

                        </StackPanel>
                    </Border>

                    <ScrollBar
                        Name="PART_HorizontalScrollBar"
                        Orientation="Horizontal"
                        Theme="{StaticResource Floating}"
                        VerticalAlignment="Bottom">
                        <ScrollBar.Transitions>
                            <Transitions>
                                <DoubleTransition Duration="0:0:0.2" Property="Opacity" />
                            </Transitions>
                        </ScrollBar.Transitions>
                    </ScrollBar>

                    <ScrollBar
                        HorizontalAlignment="Right"
                        Name="PART_VerticalScrollBar"
                        Orientation="Vertical"
                        Theme="{StaticResource Floating}">
                        <ScrollBar.Transitions>
                            <Transitions>
                                <DoubleTransition Duration="0:0:0.2" Property="Opacity" />
                            </Transitions>
                        </ScrollBar.Transitions>
                    </ScrollBar>
                    <Canvas>
                        <customControls:AutoScrollSign
                            HorizontalAlignment="Center"
                            IsVisible="False"
                            Name="PART_AutoScrollSign"
                            VerticalAlignment="Center" />
                    </Canvas>
                </Panel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

</ResourceDictionary>