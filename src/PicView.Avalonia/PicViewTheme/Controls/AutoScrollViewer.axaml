<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    x:ClassModifier="internal">
    <ControlTheme x:Key="{x:Type customControls:AutoScrollViewer}" TargetType="customControls:AutoScrollViewer">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="*,Auto">
                    <ScrollContentPresenter
                        Name="PART_ContentPresenter"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        HorizontalSnapPointsAlignment="{TemplateBinding HorizontalSnapPointsAlignment}"
                        HorizontalSnapPointsType="{TemplateBinding HorizontalSnapPointsType}"
                        ScrollViewer.IsScrollInertiaEnabled="{TemplateBinding IsScrollInertiaEnabled}"
                        VerticalSnapPointsAlignment="{TemplateBinding VerticalSnapPointsAlignment}"
                        VerticalSnapPointsType="{TemplateBinding VerticalSnapPointsType}">
                        <ScrollContentPresenter.GestureRecognizers>
                            <ScrollGestureRecognizer
                                CanHorizontallyScroll="{Binding CanHorizontallyScroll, ElementName=PART_ContentPresenter}"
                                CanVerticallyScroll="{Binding CanVerticallyScroll, ElementName=PART_ContentPresenter}"
                                IsScrollInertiaEnabled="{Binding (ScrollViewer.IsScrollInertiaEnabled), ElementName=PART_ContentPresenter}" />
                        </ScrollContentPresenter.GestureRecognizers>
                    </ScrollContentPresenter>
                    <ScrollBar
                        Name="PART_HorizontalScrollBar"
                        Grid.Row="1"
                        Grid.Column="0"
                        Orientation="Horizontal" />
                    <ScrollBar
                        Name="PART_VerticalScrollBar"
                        Grid.Row="0"
                        Grid.Column="1"
                        Orientation="Vertical" />
                    <Canvas Grid.Row="0" Grid.Column="0">
                        <customControls:AutoScrollSign
                            Name="PART_AutoScrollSign"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsVisible="False" />
                    </Canvas>
                </Grid>
            </ControlTemplate>
        </Setter>

    </ControlTheme>

    <ControlTheme x:Key="Main" TargetType="customControls:AutoScrollViewer">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="*,Auto">
                    <ScrollContentPresenter
                        Name="PART_ContentPresenter"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        HorizontalSnapPointsAlignment="{TemplateBinding HorizontalSnapPointsAlignment}"
                        HorizontalSnapPointsType="{TemplateBinding HorizontalSnapPointsType}"
                        ScrollViewer.IsScrollInertiaEnabled="{TemplateBinding IsScrollInertiaEnabled}"
                        VerticalSnapPointsAlignment="{TemplateBinding VerticalSnapPointsAlignment}"
                        VerticalSnapPointsType="{TemplateBinding VerticalSnapPointsType}">
                        <ScrollContentPresenter.GestureRecognizers>
                            <ScrollGestureRecognizer
                                CanHorizontallyScroll="{Binding CanHorizontallyScroll, ElementName=PART_ContentPresenter}"
                                CanVerticallyScroll="{Binding CanVerticallyScroll, ElementName=PART_ContentPresenter}"
                                IsScrollInertiaEnabled="{Binding (ScrollViewer.IsScrollInertiaEnabled), ElementName=PART_ContentPresenter}" />
                        </ScrollContentPresenter.GestureRecognizers>
                    </ScrollContentPresenter>
                    <ScrollBar
                        Name="PART_HorizontalScrollBar"
                        Grid.Row="1"
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Theme="{StaticResource MainScrollbar}" />
                    <ScrollBar
                        Name="PART_VerticalScrollBar"
                        Grid.Row="0"
                        Grid.Column="1"
                        Orientation="Vertical"
                        Theme="{StaticResource MainScrollbar}" />
                    <Canvas Grid.Row="0" Grid.Column="0">
                        <customControls:AutoScrollSign
                            Name="PART_AutoScrollSign"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsVisible="False" />
                    </Canvas>
                </Grid>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="Inline" TargetType="customControls:AutoScrollViewer">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <ScrollContentPresenter
                        Name="PART_ContentPresenter"
                        Padding="{TemplateBinding Padding}"
                        Background="Transparent"
                        HorizontalSnapPointsAlignment="{TemplateBinding HorizontalSnapPointsAlignment}"
                        HorizontalSnapPointsType="{TemplateBinding HorizontalSnapPointsType}"
                        ScrollViewer.IsScrollInertiaEnabled="{TemplateBinding IsScrollInertiaEnabled}"
                        VerticalSnapPointsAlignment="{TemplateBinding VerticalSnapPointsAlignment}"
                        VerticalSnapPointsType="{TemplateBinding VerticalSnapPointsType}">
                        <ScrollContentPresenter.GestureRecognizers>
                            <ScrollGestureRecognizer
                                CanHorizontallyScroll="{Binding CanHorizontallyScroll, ElementName=PART_ContentPresenter}"
                                CanVerticallyScroll="{Binding CanVerticallyScroll, ElementName=PART_ContentPresenter}"
                                IsScrollInertiaEnabled="{Binding (ScrollViewer.IsScrollInertiaEnabled), ElementName=PART_ContentPresenter}" />
                        </ScrollContentPresenter.GestureRecognizers>
                    </ScrollContentPresenter>
                    <ScrollBar
                        Name="PART_HorizontalScrollBar"
                        Orientation="Horizontal"
                        Theme="{StaticResource Floating}" />
                    <ScrollBar
                        Name="PART_VerticalScrollBar"
                        HorizontalAlignment="Right"
                        Orientation="Vertical"
                        Theme="{StaticResource Floating}" />
                    <Canvas>
                        <customControls:AutoScrollSign
                            Name="PART_AutoScrollSign"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsVisible="False" />
                    </Canvas>
                </Panel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="InlineSlim" TargetType="customControls:AutoScrollViewer">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <ScrollContentPresenter
                        Name="PART_ContentPresenter"
                        Padding="{TemplateBinding Padding}"
                        Background="Transparent"
                        HorizontalSnapPointsAlignment="{TemplateBinding HorizontalSnapPointsAlignment}"
                        HorizontalSnapPointsType="{TemplateBinding HorizontalSnapPointsType}"
                        ScrollViewer.IsScrollInertiaEnabled="{TemplateBinding IsScrollInertiaEnabled}"
                        VerticalSnapPointsAlignment="{TemplateBinding VerticalSnapPointsAlignment}"
                        VerticalSnapPointsType="{TemplateBinding VerticalSnapPointsType}">
                        <ScrollContentPresenter.GestureRecognizers>
                            <ScrollGestureRecognizer
                                CanHorizontallyScroll="{Binding CanHorizontallyScroll, ElementName=PART_ContentPresenter}"
                                CanVerticallyScroll="{Binding CanVerticallyScroll, ElementName=PART_ContentPresenter}"
                                IsScrollInertiaEnabled="{Binding (ScrollViewer.IsScrollInertiaEnabled), ElementName=PART_ContentPresenter}" />
                        </ScrollContentPresenter.GestureRecognizers>
                    </ScrollContentPresenter>
                    <ScrollBar
                        Name="PART_HorizontalScrollBar"
                        Opacity="0"
                        Orientation="Horizontal"
                        Theme="{StaticResource FloatingSlim}">
                        <ScrollBar.Transitions>
                            <Transitions>
                                <DoubleTransition
                                    Easing="CubicEaseOut"
                                    Property="Opacity"
                                    Duration="0:0:0.45" />
                            </Transitions>
                        </ScrollBar.Transitions>
                    </ScrollBar>
                    <ScrollBar
                        Name="PART_VerticalScrollBar"
                        HorizontalAlignment="Right"
                        Orientation="Vertical"
                        Theme="{StaticResource FloatingSlim}" />
                    <Canvas>
                        <customControls:AutoScrollSign
                            Name="PART_AutoScrollSign"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsVisible="False" />
                    </Canvas>
                </Panel>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover /template/ ScrollBar#PART_HorizontalScrollBar">
            <Setter Property="Opacity" Value="1" />
        </Style>

    </ControlTheme>

    <ControlTheme x:Key="MenuScrollerOverlay" TargetType="customControls:AutoScrollViewer">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <ScrollContentPresenter
                        Name="PART_ContentPresenter"
                        Padding="{TemplateBinding Padding}"
                        Background="Transparent"
                        HorizontalSnapPointsAlignment="{TemplateBinding HorizontalSnapPointsAlignment}"
                        HorizontalSnapPointsType="{TemplateBinding HorizontalSnapPointsType}"
                        ScrollViewer.IsScrollInertiaEnabled="{TemplateBinding IsScrollInertiaEnabled}"
                        VerticalSnapPointsAlignment="{TemplateBinding VerticalSnapPointsAlignment}"
                        VerticalSnapPointsType="{TemplateBinding VerticalSnapPointsType}">
                        <ScrollContentPresenter.GestureRecognizers>
                            <ScrollGestureRecognizer
                                CanHorizontallyScroll="{Binding CanHorizontallyScroll, ElementName=PART_ContentPresenter}"
                                CanVerticallyScroll="{Binding CanVerticallyScroll, ElementName=PART_ContentPresenter}"
                                IsScrollInertiaEnabled="{Binding (ScrollViewer.IsScrollInertiaEnabled), ElementName=PART_ContentPresenter}" />
                        </ScrollContentPresenter.GestureRecognizers>
                    </ScrollContentPresenter>

                    <customControls:IconButton
                        Height="30"
                        VerticalAlignment="Top"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Command="{Binding PageUp, RelativeSource={RelativeSource TemplatedParent}}"
                        Cursor="Hand"
                        Data="{StaticResource FilledArrowUpGeometry}"
                        Foreground="{TemplateBinding Foreground}"
                        IconHeight="16"
                        IconWidth="16"
                        IsVisible="{Binding CanScrollUp, RelativeSource={RelativeSource TemplatedParent}}">
                        <customControls:IconButton.Background>
                            <LinearGradientBrush Opacity=".7" StartPoint="50%,0%" EndPoint="50%,100%">
                                <GradientStop Offset="0" Color="#EE161616" />
                                <GradientStop Offset="1" Color="#9B161616" />
                            </LinearGradientBrush>
                        </customControls:IconButton.Background>

                    </customControls:IconButton>

                    <customControls:IconButton
                        Height="30"
                        VerticalAlignment="Bottom"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Command="{Binding PageDown, RelativeSource={RelativeSource TemplatedParent}}"
                        Cursor="Hand"
                        Data="{StaticResource FilledArrowDownGeometry}"
                        Foreground="{TemplateBinding Foreground}"
                        IconHeight="16"
                        IconWidth="16"
                        IsVisible="{Binding CanScrollDown, RelativeSource={RelativeSource TemplatedParent}}">
                        <customControls:IconButton.Background>
                            <LinearGradientBrush Opacity=".7" StartPoint="50%,0%" EndPoint="50%,100%">
                                <GradientStop Offset="0" Color="#EE161616" />
                                <GradientStop Offset="1" Color="#9B161616" />
                            </LinearGradientBrush>
                        </customControls:IconButton.Background>

                    </customControls:IconButton>

                    <ScrollBar
                        Name="PART_HorizontalScrollBar"
                        Orientation="Horizontal"
                        Theme="{StaticResource FloatingSlim}" />
                    <ScrollBar
                        Name="PART_VerticalScrollBar"
                        HorizontalAlignment="Right"
                        Orientation="Vertical"
                        Theme="{StaticResource FloatingSlim}"
                        Visibility="Hidden" />

                    <Canvas>
                        <customControls:AutoScrollSign
                            Name="PART_AutoScrollSign"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsVisible="False" />
                    </Canvas>
                </Panel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="ClickableMenuScrollButtons" TargetType="customControls:AutoScrollViewer">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <DockPanel>

                    <customControls:IconButton
                        Width="35"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="{DynamicResource MenuButtonColor}"
                        BorderBrush="{DynamicResource MainBorderColor}"
                        BorderThickness="1,0,0,0"
                        Command="{Binding PageRight, RelativeSource={RelativeSource TemplatedParent}}"
                        Cursor="Hand"
                        Data="{StaticResource FilledChevronRightGeometry}"
                        DockPanel.Dock="Right"
                        Foreground="{TemplateBinding Foreground}"
                        IconHeight="16"
                        IconWidth="16"
                        IsVisible="{Binding CanScrollRight, RelativeSource={RelativeSource TemplatedParent}}" />

                    <customControls:IconButton
                        Width="35"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="{DynamicResource MenuButtonColor}"
                        BorderBrush="{DynamicResource MainBorderColor}"
                        BorderThickness="0,0,1,0"
                        Command="{Binding PageLeft, RelativeSource={RelativeSource TemplatedParent}}"
                        Cursor="Hand"
                        Data="{StaticResource FilledChevronLeftGeometry}"
                        DockPanel.Dock="Left"
                        Foreground="{TemplateBinding Foreground}"
                        IconHeight="16"
                        IconWidth="16"
                        IsVisible="{Binding CanScrollLeft, RelativeSource={RelativeSource TemplatedParent}}" />

                    <Panel>
                        <ScrollContentPresenter
                            Name="PART_ContentPresenter"
                            Padding="{TemplateBinding Padding}"
                            Background="Transparent"
                            HorizontalSnapPointsAlignment="{TemplateBinding HorizontalSnapPointsAlignment}"
                            HorizontalSnapPointsType="{TemplateBinding HorizontalSnapPointsType}"
                            ScrollViewer.IsScrollInertiaEnabled="{TemplateBinding IsScrollInertiaEnabled}"
                            VerticalSnapPointsAlignment="{TemplateBinding VerticalSnapPointsAlignment}"
                            VerticalSnapPointsType="{TemplateBinding VerticalSnapPointsType}">
                            <ScrollContentPresenter.GestureRecognizers>
                                <ScrollGestureRecognizer
                                    CanHorizontallyScroll="{Binding CanHorizontallyScroll, ElementName=PART_ContentPresenter}"
                                    CanVerticallyScroll="{Binding CanVerticallyScroll, ElementName=PART_ContentPresenter}"
                                    IsScrollInertiaEnabled="{Binding (ScrollViewer.IsScrollInertiaEnabled), ElementName=PART_ContentPresenter}" />
                            </ScrollContentPresenter.GestureRecognizers>
                        </ScrollContentPresenter>

                        <Canvas>
                            <customControls:AutoScrollSign
                                Name="PART_AutoScrollSign"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsVisible="False" />
                        </Canvas>
                    </Panel>

                </DockPanel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

</ResourceDictionary>