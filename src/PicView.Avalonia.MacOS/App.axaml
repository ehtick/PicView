<Application
    Name="PicView"
    RequestedThemeVariant="Default"
    x:Class="PicView.Avalonia.MacOS.App"
    x:CompileBindings="True"
    x:DataType="viewModels:CoreViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <NativeMenu.Menu>
        <NativeMenu>

            <!--  Show about window  -->
            <NativeMenuItem Command="{CompiledBinding MainWindows.ActiveWindow.Value.AboutWindowCommand}" Header="{CompiledBinding Translation.About.Value, Mode=OneWay}" />

            <!--  Check for updates  -->
            <NativeMenuItem Command="{CompiledBinding MainWindows.ActiveWindow.Value.CheckForUpdatesCommand}" Header="{CompiledBinding Translation.CheckForUpdates.Value, Mode=OneWay}" />

            <!--  Show settings window  -->
            <NativeMenuItem
                Command="{CompiledBinding MainWindows.ActiveWindow.Value.SettingsWindowCommand}"
                Header="{CompiledBinding Translation.Settings.Value,
                                         Mode=OneWay}"
                ToolTip="{CompiledBinding Translation.ShowAllSettingsWindow.Value,
                                          Mode=OneWay}" />
        </NativeMenu>
    </NativeMenu.Menu>

    <Application.Styles>
        <StyleInclude Source="avares://PicView.Avalonia/PicViewTheme/AllControls.axaml" />
    </Application.Styles>
</Application>