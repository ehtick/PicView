<Window
    BorderThickness="1"
    CanResize="True"
    ExtendClientAreaTitleBarHeightHint="-1"
    ExtendClientAreaToDecorationsHint="True"
    MinWidth="600"
    Title="SettingsWindow"
    x:Class="PicView.Avalonia.MacOS.Views.SettingsWindow"
    x:DataType="viewModels:CoreViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:buttons="clr-namespace:PicView.Avalonia.Views.UC.Buttons;assembly=PicView.Avalonia"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls;assembly=PicView.Avalonia"
    xmlns:main="clr-namespace:PicView.Avalonia.Views.Main;assembly=PicView.Avalonia"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border
        BorderBrush="{DynamicResource MainBorderColor}"
        BorderThickness="1"
        CornerRadius="8"
        PointerPressed="MoveWindow"
        x:Name="MainBorder">
        <DockPanel>
            <Panel DockPanel.Dock="Top">
                <customControls:IconButton
                    Background="Transparent"
                    Classes="noBorderHover"
                    Command="{CompiledBinding SettingsViewModel.GoBackCommand}"
                    Data="{StaticResource ArrowLeftGeometry}"
                    Foreground="{DynamicResource MainTextColor}"
                    Height="28"
                    HorizontalAlignment="Left"
                    IconHeight="12"
                    IconWidth="12"
                    Margin="75,0,0,0"
                    Width="35"
                    ZIndex="1"
                    x:Name="GoBackButton" />

                <customControls:IconButton
                    Background="Transparent"
                    Classes="noBorderHover"
                    Command="{CompiledBinding SettingsViewModel.GoForwardCommand}"
                    Data="{StaticResource ArrowRightGeometry}"
                    Foreground="{DynamicResource MainTextColor}"
                    HorizontalAlignment="Left"
                    IconHeight="12"
                    IconWidth="12"
                    Margin="110,0,0,0"
                    Width="35"
                    ZIndex="1"
                    x:Name="GoForwardButton" />

                <customControls:IconButton
                    Background="Transparent"
                    Classes="noBorderHover"
                    Command="{CompiledBinding SettingsViewModel.GoHomeCommand}"
                    CornerRadius="4"
                    Foreground="{StaticResource SecondaryTextColor}"
                    HorizontalAlignment="Left"
                    Icon="{StaticResource HomeImage}"
                    IconHeight="12"
                    IconWidth="12"
                    Margin="145,0,0,0"
                    Width="35"
                    ZIndex="1"
                    x:Name="HomeButton" />

                <TextBlock
                    Background="{DynamicResource WindowBackgroundColor}"
                    Classes="txt"
                    Foreground="{DynamicResource MainTextColor}"
                    Height="28"
                    LineHeight="28"
                    Text="{CompiledBinding Translation.Settings.Value,
                                           Mode=OneWay}"
                    TextAlignment="Center"
                    x:Name="TitleText" />

                <buttons:SettingsMenuButton
                    HorizontalAlignment="Right"
                    ZIndex="1"
                    x:Name="SettingsButton" />
            </Panel>

            <main:SettingsView Background="{DynamicResource WindowBackgroundColor}" x:Name="SettingsView" />
        </DockPanel>
    </Border>
</Window>