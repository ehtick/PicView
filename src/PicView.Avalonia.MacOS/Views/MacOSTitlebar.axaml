<UserControl
    IsVisible="{CompiledBinding IsTopToolbarShown.Value,
                                Mode=OneWay}"
    mc:Ignorable="d"
    x:Class="PicView.Avalonia.MacOS.Views.MacOSTitlebar"
    x:DataType="viewModels:MainWindowViewModel"
    x:Name="Titlebar"
    xmlns="https://github.com/avaloniaui"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls;assembly=PicView.Avalonia"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:PicView.Avalonia.Views.UC;assembly=PicView.Avalonia"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel
        Background="{DynamicResource MainBackgroundColor}"
        LastChildFill="True"
        x:Name="TopWindowBorder">
        <Rectangle DockPanel.Dock="Left" Width="70" />

        <customControls:IconButton
            Background="Transparent"
            BorderBrush="{DynamicResource MainBorderColor}"
            BorderThickness="0"
            Classes="altHover"
            Command="{CompiledBinding TopTitlebarViewModel.ToggleDropDownMenuCommand}"
            Data="{StaticResource FilledArrowDownGeometry}"
            DockPanel.Dock="Right"
            Foreground="{DynamicResource MainTextColor}"
            IconHeight="17"
            IconWidth="17"
            IsRepeatEnabled="False"
            IsTabStop="False"
            Width="30"
            x:Name="MenuButton" />

        <customControls:IconButton
            Background="Transparent"
            BorderBrush="{DynamicResource MainBorderColor}"
            BorderThickness="0"
            Classes="altHover"
            Command="{CompiledBinding WindowTabs.CreateTab}"
            Data="{StaticResource AddGeometry}"
            DockPanel.Dock="Right"
            Foreground="{DynamicResource MainTextColor}"
            IconHeight="13"
            IconWidth="13"
            IsRepeatEnabled="False"
            IsTabStop="False"
            Margin="0"
            Width="30"
            x:Name="CreateTabButton" />

        <customControls:IconButton
            Background="Transparent"
            BorderBrush="{DynamicResource MainBorderColor}"
            BorderThickness="0"
            Classes="altHover"
            DockPanel.Dock="Right"
            Foreground="{DynamicResource MainTextColor}"
            Icon="{StaticResource SearchImage}"
            IconHeight="13"
            IconWidth="13"
            IsRepeatEnabled="False"
            IsTabStop="False"
            Margin="0"
            Width="30"
            x:Name="SearchButton" />

        <uc:EditableTitlebar
            Background="Transparent"
            Foreground="{DynamicResource MainTextColor}"
            x:Name="EditableTitlebar" />
    </DockPanel>
</UserControl>