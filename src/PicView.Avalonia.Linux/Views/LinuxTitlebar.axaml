<customControls:MainTitleBar
    Height="{CompiledBinding TitlebarHeight.Value,
                             Mode=OneWay}"
    IsVisible="{CompiledBinding IsTopToolbarShown.Value,
                                Mode=OneWay}"
    Margin="{CompiledBinding TopScreenMargin.Value,
                             Mode=OneWay}"
    x:Class="PicView.Avalonia.Linux.Views.LinuxTitlebar"
    x:DataType="vm:MainWindowViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls;assembly=PicView.Avalonia"
    xmlns:uc="clr-namespace:PicView.Avalonia.Views.UC;assembly=PicView.Avalonia"
    xmlns:vm="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Background="{DynamicResource WindowSecondaryBackgroundColor}"
        BorderBrush="{DynamicResource MainBorderColor}"
        BorderThickness="0,0,0,1"
        x:Name="TopWindowBorder">
        <Panel>
            <Menu
                Background="{DynamicResource WindowSecondaryBackgroundColor}"
                BorderBrush="{DynamicResource MainBorderColor}"
                BorderThickness="0,0,0,1"
                Foreground="{DynamicResource MainTextColor}"
                Height="{CompiledBinding TitlebarHeight.Value,
                                         Mode=OneWay}"
                HorizontalAlignment="Left"
                IsVisible="{CompiledBinding TopTitlebarViewModel.IsMainMenuVisible.Value}"
                Margin="34,0,0,0"
                ZIndex="9"
                x:Name="MainMenu">
                <MenuItem
                    Header="{CompiledBinding Translation.File}"
                    Height="{CompiledBinding TitlebarHeight.Value,
                                             Mode=OneWay}"
                    x:Name="FileMenuItem">

                    <!--  Open  -->
                    <MenuItem
                        Command="{CompiledBinding OpenCommand}"
                        Header="{CompiledBinding Translation.Open.Value,
                                                 Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image Classes="OpenImage" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Save  -->
                    <MenuItem
                        Command="{CompiledBinding SaveCommand}"
                        Header="{CompiledBinding Translation.Save.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull},
                                                    FallbackValue=False}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="SavePath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Save as  -->
                    <MenuItem
                        Command="{CompiledBinding SaveAsCommand}"
                        Header="{CompiledBinding Translation.SaveAs.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull},
                                                    FallbackValue=False}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="SavePath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Print  -->
                    <MenuItem
                        Command="{CompiledBinding PrintCommand}"
                        Header="{CompiledBinding Translation.Print.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull},
                                                    FallbackValue=False}"
                        Theme="{StaticResource MainBg}"
                        x:Name="PrintMenuItem">
                        <MenuItem.Icon>
                            <Path Classes="PrintPath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Open with  -->
                    <MenuItem
                        Command="{CompiledBinding OpenWithCommand}"
                        Header="{CompiledBinding Translation.OpenWith.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull},
                                                    FallbackValue=False}"
                        Theme="{StaticResource MainBg}"
                        x:Name="OpenWithMenuItem">
                        <MenuItem.Icon>
                            <Image Height="12" Width="12">
                                <Image.Source>
                                    <DrawingImage>
                                        <DrawingGroup>
                                            <GeometryDrawing Geometry="F1 M12 6L6 6Q5.90175 6 5.80397 6.00963Q5.70618 6.01926 5.60982 6.03843Q5.51345 6.0576 5.41943 6.08612Q5.32541 6.11464 5.23463 6.15224Q5.14386 6.18984 5.05721 6.23616Q4.97055 6.28247 4.88886 6.33706Q4.80716 6.39165 4.73121 6.45398Q4.65526 6.51631 4.58579 6.58579Q4.51631 6.65526 4.45398 6.73121Q4.39165 6.80717 4.33706 6.88886Q4.28247 6.97056 4.23616 7.05721Q4.18984 7.14386 4.15224 7.23463Q4.11464 7.32541 4.08612 7.41943Q4.0576 7.51345 4.03843 7.60982Q4.01926 7.70619 4.00963 7.80397Q4 7.90175 4 8L4 18Q4 18.0983 4.00963 18.196Q4.01926 18.2938 4.03843 18.3902Q4.0576 18.4865 4.08612 18.5806Q4.11464 18.6746 4.15224 18.7654Q4.18984 18.8561 4.23616 18.9428Q4.28247 19.0294 4.33706 19.1111Q4.39165 19.1928 4.45398 19.2688Q4.51631 19.3447 4.58579 19.4142Q4.65526 19.4837 4.73121 19.546Q4.80716 19.6083 4.88886 19.6629Q4.97055 19.7175 5.05721 19.7638Q5.14386 19.8102 5.23463 19.8478Q5.32541 19.8854 5.41943 19.9139Q5.51345 19.9424 5.60982 19.9616Q5.70618 19.9807 5.80397 19.9904Q5.90175 20 6 20L16 20Q16.0983 20 16.196 19.9904Q16.2938 19.9807 16.3902 19.9616Q16.4865 19.9424 16.5806 19.9139Q16.6746 19.8854 16.7654 19.8478Q16.8561 19.8102 16.9428 19.7638Q17.0294 19.7175 17.1111 19.6629Q17.1928 19.6084 17.2688 19.546Q17.3447 19.4837 17.4142 19.4142Q17.4837 19.3447 17.546 19.2688Q17.6084 19.1928 17.6629 19.1111Q17.7175 19.0294 17.7638 18.9428Q17.8102 18.8561 17.8478 18.7654Q17.8854 18.6746 17.9139 18.5806Q17.9424 18.4865 17.9616 18.3902Q17.9807 18.2938 17.9904 18.196Q18 18.0983 18 18L18 12">
                                                <GeometryDrawing.Pen>
                                                    <Pen
                                                        Brush="{DynamicResource MainTextColor}"
                                                        LineCap="Round"
                                                        LineJoin="Round"
                                                        MiterLimit="4"
                                                        Thickness="2" />
                                                </GeometryDrawing.Pen>
                                            </GeometryDrawing>
                                            <GeometryDrawing Geometry="F1 M11 13L20 4">
                                                <GeometryDrawing.Pen>
                                                    <Pen
                                                        Brush="{DynamicResource MainTextColor}"
                                                        LineCap="Round"
                                                        LineJoin="Round"
                                                        MiterLimit="4"
                                                        Thickness="2" />
                                                </GeometryDrawing.Pen>
                                            </GeometryDrawing>
                                            <GeometryDrawing Geometry="F1 M15 4L20 4L20 9">
                                                <GeometryDrawing.Pen>
                                                    <Pen
                                                        Brush="{DynamicResource MainTextColor}"
                                                        LineCap="Round"
                                                        LineJoin="Round"
                                                        MiterLimit="4"
                                                        Thickness="2" />
                                                </GeometryDrawing.Pen>
                                            </GeometryDrawing>
                                        </DrawingGroup>
                                    </DrawingImage>
                                </Image.Source>
                            </Image>
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Locate on disk  -->
                    <MenuItem
                        Command="{CompiledBinding OpenInExplorerCommand}"
                        Header="{CompiledBinding Translation.ShowInFolder.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull},
                                                    FallbackValue=False}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="ShowInFolderPath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource MainBorderColor}"
                        Margin="0"
                        Opacity=".3" />

                    <!--  Close  -->
                    <MenuItem
                        Command="{CompiledBinding ExitCommand}"
                        Header="{CompiledBinding Translation.Close.Value,
                                                 Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="ClosePath" />
                        </MenuItem.Icon>
                    </MenuItem>

                </MenuItem>

                <!--  Edit  -->
                <MenuItem Header="{CompiledBinding Translation.Edit, Mode=OneWay}">

                    <!--  Copy image  -->
                    <MenuItem
                        Command="{CompiledBinding CopyImageCommand}"
                        Header="{CompiledBinding Translation.CopyImage.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="CopyPath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Copy file  -->
                    <MenuItem
                        Command="{CompiledBinding CopyFileCommand}"
                        Header="{Binding Translation.CopyFile.Value, Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull},
                                                    FallbackValue=False}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="CopyPath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Copy file path  -->
                    <MenuItem
                        Command="{CompiledBinding CopyFilePathCommand}"
                        Header="{Binding Translation.FileCopyPath.Value, Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull},
                                                    FallbackValue=False}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="CopyPath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Copy base64  -->
                    <MenuItem
                        Command="{CompiledBinding CopyBase64Command}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Header>
                            <TextBlock>
                                <Run Text="{CompiledBinding Translation.Copy.Value, Mode=OneWay}" />
                                <Run Text=" base64" />
                            </TextBlock>
                        </MenuItem.Header>
                        <MenuItem.Icon>
                            <Path Classes="CopyPath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Duplicate file  -->
                    <MenuItem
                        Command="{CompiledBinding DuplicateFileCommand}"
                        Header="{CompiledBinding Translation.DuplicateFile.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="DuplicatePath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Paste  -->
                    <MenuItem
                        Command="{CompiledBinding PasteCommand}"
                        Header="{CompiledBinding Translation.Paste.Value,
                                                 Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="PastePath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Delete file  -->
                    <MenuItem
                        Command="{CompiledBinding DeleteFileCommand}"
                        Header="{CompiledBinding Translation.DeleteFile.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="RecyclePath" />
                        </MenuItem.Icon>
                    </MenuItem>

                </MenuItem>

                <!--  View  -->
                <MenuItem Header="{CompiledBinding Translation.View, Mode=OneWay}">

                    <!--  Change background  -->
                    <MenuItem
                        Command="{CompiledBinding ChangeBackgroundCommand}"
                        Header="{CompiledBinding Translation.ChangeBackground.Value,
                                                 Mode=OneWay}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource PaletteImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Toggle UI  -->
                    <MenuItem
                        Command="{CompiledBinding ToggleInterfaceCommand}"
                        Header="{CompiledBinding Translation.IsShowingUI.Value,
                                                 Mode=OneWay}"
                        IsVisible="{CompiledBinding IsUIShown.Value,
                                                    Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource EyeOffImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Toggle bottom bar  -->
                    <MenuItem
                        Command="{CompiledBinding ToggleBottomToolbarCommand}"
                        Header="{CompiledBinding Translation.ShowBottomToolbar.Value,
                                                 Mode=OneWay}"
                        IsVisible="{CompiledBinding !IsBottomToolbarShown.Value}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource Panel-Bottom}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Command="{CompiledBinding ToggleBottomToolbarCommand}"
                        Header="{CompiledBinding Translation.HideBottomToolbar.Value,
                                                 Mode=OneWay}"
                        IsVisible="{CompiledBinding IsBottomToolbarShown.Value}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource Panel-Bottom}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Toggle side-by-side  -->
                    <!--  <MenuItem  -->
                    <!--  Command="{CompiledBinding SideBySideCommand}"  -->
                    <!--  Header="{CompiledBinding Translation.SideBySide.Value,  -->
                    <!--  Mode=OneWay}"  -->
                    <!--  Theme="{StaticResource MainBg}"  -->
                    <!--  ToggleType="CheckBox" />  -->


                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />


                    <!--  Toggle bottom gallery  -->
                    <!--  <MenuItem  -->
                    <!--  Command="{CompiledBinding Gallery.ToggleBottomGalleryCommand}"  -->
                    <!--  Header="{CompiledBinding Translation.IsShowingDockedGallery.Value,  -->
                    <!--  Mode=OneWay}"  -->
                    <!--  IsChecked="{CompiledBinding Gallery.IsBottomGalleryShown.Value}"  -->
                    <!--  Theme="{StaticResource MainBg}">  -->
                    <!--     <MenuItem.Icon> -->
                    <!--  <Image  -->
                    <!--  Height="12"  -->
                    <!--  Source="{StaticResource GalleryImage}"  -->
                    <!--  Width="12" />  -->
                    <!--     </MenuItem.Icon> -->
                    <!-- </MenuItem> -->
                    <!--    -->
                    <!--  <Separator  -->
                    <!--  Background="{DynamicResource ContextMenuBackgroundColor}"  -->
                    <!--  Margin="0"  -->
                    <!--  Opacity=".9" />  -->

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Fullscreen  -->
                    <MenuItem
                        Command="{CompiledBinding ToggleFullscreenCommand}"
                        Header="{CompiledBinding Translation.Fullscreen.Value,
                                                 Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="FullscreenPath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Maximize  -->
                    <MenuItem
                        Command="{CompiledBinding MaximizeCommand}"
                        Header="{CompiledBinding Translation.Maximize.Value,
                                                 Mode=OneWay}"
                        IsVisible="{CompiledBinding ShouldMaximizeBeShown.Value,
                                                    Mode=OneWay}"
                        Theme="{StaticResource MainBg}"
                        x:Name="MaximizeMenuItem">
                        <MenuItem.Icon>
                            <Image Classes="MaximizeImage" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Restore  -->
                    <MenuItem
                        Command="{CompiledBinding RestoreCommand}"
                        Header="{CompiledBinding Translation.RestoreDown.Value,
                                                 Mode=OneWay}"
                        IsVisible="{CompiledBinding ShouldRestoreBeShown.Value,
                                                    Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="RestorePath" />
                        </MenuItem.Icon>
                    </MenuItem>

                </MenuItem>

                <!--  Image  -->
                <MenuItem Header="{CompiledBinding Translation.Image, Mode=OneWay}">

                    <!--  Exif window  -->
                    <!--  <MenuItem  -->
                    <!--  Command="{CompiledBinding Window.ShowImageInfoWindow}"  -->
                    <!--  Header="{CompiledBinding Translation.ImageInfo.Value,  -->
                    <!--  Mode=OneWay}"  -->
                    <!--  Theme="{StaticResource MainBg}">  -->
                    <!--     <MenuItem.Icon> -->
                    <!--         <Path Classes="ImageInfoPath" /> -->
                    <!--     </MenuItem.Icon> -->
                    <!-- </MenuItem> -->

                    <!--  File properties  -->
                    <MenuItem
                        Command="{CompiledBinding ShowFilePropertiesCommand}"
                        Header="{CompiledBinding Translation.FileProperties.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource FileUserImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Image effects  -->
                    <!--  <MenuItem  -->
                    <!--  Command="{CompiledBinding Window.ShowEffectsWindow}"  -->
                    <!--  Header="{CompiledBinding Translation.Effects.Value,  -->
                    <!--  Mode=OneWay}"  -->
                    <!--  Theme="{StaticResource MainBg}"  -->
                    <!--  ToolTip.Tip="{CompiledBinding Translation.EffectsTooltip.Value,  -->
                    <!--  Mode=OneWay}">  -->
                    <!--     <MenuItem.Icon> -->
                    <!--  <Image  -->
                    <!--  Height="12"  -->
                    <!--  Source="{StaticResource FlaskImage}"  -->
                    <!--  Width="12" />  -->
                    <!--     </MenuItem.Icon> -->
                    <!-- </MenuItem> -->

                    <!--  Batch resize  -->
                    <!--  <MenuItem  -->
                    <!--  Command="{CompiledBinding Window.ShowBatchResizeWindow}"  -->
                    <!--  Header="{CompiledBinding Translation.BatchResize.Value,  -->
                    <!--  Mode=OneWay}"  -->
                    <!--  Theme="{StaticResource MainBg}">  -->
                    <!--     <MenuItem.Icon> -->
                    <!--  <Image  -->
                    <!--  Height="12"  -->
                    <!--  Source="{StaticResource UpscaleImage}"  -->
                    <!--  Width="12" />  -->
                    <!--     </MenuItem.Icon> -->
                    <!-- </MenuItem> -->

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Optimize image  -->
                    <!--  IsEnabled="{CompiledBinding PicViewer.ShouldOptimizeImageBeEnabled.Value,  -->
                    <!--  Mode=OneWay}"  -->
                    <MenuItem
                        Command="{CompiledBinding OptimizeImageCommand}"
                        Header="{CompiledBinding Translation.OptimizeImage.Value,
                                                 Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource PortalImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Crop  -->
                    <MenuItem
                        Command="{CompiledBinding CropCommand}"
                        Header="{CompiledBinding Translation.Crop.Value,
                                                 Mode=OneWay}"
                        Theme="{StaticResource MainBg}"
                        x:Name="CropMenuItem">
                        <MenuItem.Icon>
                            <Image Classes="CropImage" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Flip  -->
                    <MenuItem
                        Command="{CompiledBinding FlipCommand}"
                        Header="{CompiledBinding Translation.IsFlipped.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="FlipPath">
                                <Path.RenderTransform>
                                    <!-- <ScaleTransform ScaleX="{CompiledBinding PicViewer.ScaleX.Value}" /> -->
                                </Path.RenderTransform>
                            </Path>
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Rotate left  -->
                    <MenuItem
                        Command="{CompiledBinding RotateLeftCommand}"
                        Header="{CompiledBinding Translation.RotateLeft.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="RotateLeftPath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Rotate right  -->
                    <MenuItem
                        Command="{CompiledBinding RotateRightCommand}"
                        Header="{CompiledBinding Translation.RotateRight.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.Image.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="RotateRightPath" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <!--  Navigate  -->
                <MenuItem Header="{CompiledBinding Translation.Navigate, Mode=OneWay}">

                    <!--  Next  -->
                    <MenuItem
                        Command="{CompiledBinding NextCommand}"
                        Header="{CompiledBinding Translation.NextImage,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource NextImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Prev  -->
                    <MenuItem
                        Command="{CompiledBinding PrevCommand}"
                        Header="{CompiledBinding Translation.PrevImage,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource PrevImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />


                    <!--  Next 10  -->
                    <MenuItem
                        Command="{CompiledBinding Next10Command}"
                        Header="{CompiledBinding Translation.AdvanceBy10Images,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource NextImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Next 100  -->
                    <MenuItem
                        Command="{CompiledBinding Next100Command}"
                        Header="{CompiledBinding Translation.AdvanceBy100Images.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource NextImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Prev 10  -->
                    <MenuItem
                        Command="{CompiledBinding Prev10Command}"
                        Header="{CompiledBinding Translation.GoBackBy10Images.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource PrevImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Prev 100  -->
                    <MenuItem
                        Command="{CompiledBinding Prev100Command}"
                        Header="{CompiledBinding Translation.GoBackBy100Images.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource PrevImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  First Image  -->
                    <MenuItem
                        Command="{CompiledBinding FirstCommand}"
                        Header="{CompiledBinding Translation.FirstImage.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource FirstImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Last Image  -->
                    <MenuItem
                        Command="{CompiledBinding LastCommand}"
                        Header="{CompiledBinding Translation.LastImage.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource LastImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Next folder  -->
                    <MenuItem
                        Command="{CompiledBinding NextFolderCommand}"
                        Header="{CompiledBinding Translation.NextFolder.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="14"
                                Source="{StaticResource NextFolderImage}"
                                Width="14" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Prev folder  -->
                    <MenuItem
                        Command="{CompiledBinding PrevFolderCommand}"
                        Header="{CompiledBinding Translation.PrevFolder.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{CompiledBinding WindowTabs.ActiveTab.Value.FileInfo.Value,
                                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="14"
                                Source="{StaticResource PrevFolderImage}"
                                Width="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

