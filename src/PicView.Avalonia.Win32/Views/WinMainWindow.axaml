<customControls:MainWindow
    Title="{CompiledBinding WindowTabs.ActiveTab.Value.WindowTitle.Value,
                            FallbackValue=''}"
    x:Class="PicView.Avalonia.Win32.Views.WinMainWindow"
    x:DataType="viewModels:MainWindowViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls;assembly=PicView.Avalonia"
    xmlns:main="clr-namespace:PicView.Avalonia.Views.Main;assembly=PicView.Avalonia"
    xmlns:uc="clr-namespace:PicView.Avalonia.Views.UC;assembly=PicView.Avalonia"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:views="clr-namespace:PicView.Avalonia.Win32.Views"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border BorderBrush="{DynamicResource WindowBorderColor}" BorderThickness="1">
        <DockPanel LastChildFill="True">
            <views:WinTitleBar DockPanel.Dock="Top" x:Name="Titlebar" />
            <uc:BottomBar DockPanel.Dock="Bottom" x:Name="BottomBar" />
            <main:MainView x:Name="MainView" />
        </DockPanel>
    </Border>
</customControls:MainWindow>