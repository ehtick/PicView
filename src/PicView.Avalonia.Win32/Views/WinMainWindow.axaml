<Window
    x:Class="PicView.Avalonia.Win32.Views.WinMainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:main="clr-namespace:PicView.Avalonia.Views.Main;assembly=PicView.Avalonia"
    xmlns:uc="clr-namespace:PicView.Avalonia.Views.UC;assembly=PicView.Avalonia"
    xmlns:viewModels="clr-namespace:PicView.Avalonia.ViewModels;assembly=PicView.Avalonia"
    xmlns:views1="clr-namespace:PicView.Avalonia.Win32.Views"
    Title="{CompiledBinding PicViewer.WindowTitle.Value,
                            Mode=OneWay}"
    MinWidth="{CompiledBinding MainWindow.WindowMinWidth.Value}"
    MinHeight="{CompiledBinding MainWindow.WindowMinHeight.Value}"
    x:DataType="viewModels:MainViewModel"
    CanResize="{CompiledBinding MainWindow.CanResize.Value}"
    Icon="/icon.ico"
    SizeChanged="Control_OnSizeChanged"
    SizeToContent="{CompiledBinding MainWindow.SizeToContent.Value}"
    TransparencyLevelHint="AcrylicBlur">

    <Window.Styles>
        <Style Selector="Window[WindowState=Maximized]">
            <Setter Property="SystemDecorations" Value="None" />
            <Setter Property="ExtendClientAreaToDecorationsHint" Value="False" />
        </Style>
        <Style Selector="Window[WindowState=Minimized]">
            <Setter Property="SystemDecorations" Value="None" />
            <Setter Property="ExtendClientAreaToDecorationsHint" Value="False" />
        </Style>
    </Window.Styles>

    <Border BorderBrush="{DynamicResource WindowBorderColor}" BorderThickness="1">
        <DockPanel LastChildFill="True">
            <views1:WinTitleBar x:Name="Titlebar" DockPanel.Dock="Top" />
            <uc:BottomBar x:Name="BottomBar" DockPanel.Dock="Bottom" />
            <main:MainView x:Name="MainView" />
        </DockPanel>
    </Border>
</Window>