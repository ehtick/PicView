<customControls:MainTitleBar
    Height="{Binding TitlebarHeight.Value, Mode=OneWay}"
    IsVisible="{Binding IsTopToolbarShown.Value, Mode=OneWay}"
    x:Class="PicView.Avalonia.Win32.Views.WinTitleBar"
    x:DataType="vm:MainWindowViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls;assembly=PicView.Avalonia"
    xmlns:uc="clr-namespace:PicView.Avalonia.Views.UC;assembly=PicView.Avalonia"
    xmlns:vm="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Background="{DynamicResource WindowSecondaryBackgroundColor}"
        BorderBrush="{DynamicResource MainBorderColor}"
        BorderThickness="0,0,0,1"
        x:Name="TopWindowBorder">
        <DockPanel LastChildFill="True">

            <Border
                Background="{DynamicResource WindowButtonBackgroundColor}"
                BorderBrush="{DynamicResource MainBorderColor}"
                BorderThickness="0,0,1,0"
                x:Name="LogoBorder">
                <Image
                    Height="25"
                    Margin="7,1,7,1"
                    Source="{StaticResource LogoImage}"
                    Width="20" />
            </Border>

            <Menu
                Background="{DynamicResource WindowSecondaryBackgroundColor}"
                BorderBrush="{DynamicResource MainBorderColor}"
                BorderThickness="0,0,0,1"
                Foreground="{DynamicResource MainTextColor}"
                Height="{Binding TitlebarHeight.Value, Mode=OneWay}"
                HorizontalAlignment="Left"
                IsVisible="{Binding TopTitlebarViewModel.IsMainMenuVisible.Value}"
                ZIndex="9"
                x:Name="MainMenu">
                <MenuItem
                    Header="{Binding Translation.File}"
                    Height="{Binding TitlebarHeight.Value, Mode=OneWay}"
                    x:Name="FileMenuItem">

                    <!--  Open  -->
                    <MenuItem
                        Command="{CompiledBinding OpenCommand}"
                        Header="{CompiledBinding Translation.Open.Value,
                                                 Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image Classes="OpenImage" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Save  -->
                    <MenuItem
                        Command="{CompiledBinding SaveCommand}"
                        Header="{CompiledBinding Translation.Save.Value,
                                                 Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="SavePath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Save as  -->
                    <MenuItem
                        Command="{Binding SaveAsCommand}"
                        Header="{Binding Translation.SaveAs.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="SavePath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Print  -->
                    <MenuItem
                        Command="{Binding PrintCommand}"
                        Header="{Binding Translation.Print.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.Image.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}"
                        Theme="{StaticResource MainBg}"
                        x:Name="PrintMenuItem">
                        <MenuItem.Icon>
                            <Path Classes="PrintPath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Open with  -->
                    <MenuItem
                        Command="{Binding OpenWithCommand}"
                        Header="{Binding Translation.OpenWith.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}"
                        Theme="{StaticResource MainBg}"
                        x:Name="OpenWithMenuItem">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource OpenExternalImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Locate on disk  -->
                    <MenuItem
                        Command="{Binding OpenInExplorerCommand}"
                        Header="{Binding Translation.ShowInFolder.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="ShowInFolderPath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource MainBorderColor}"
                        Margin="0"
                        Opacity=".3" />

                    <!--  Close  -->
                    <MenuItem
                        Command="{CompiledBinding ExitCommand}"
                        Header="{CompiledBinding Translation.Close.Value,
                                                 Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="ClosePath" />
                        </MenuItem.Icon>
                    </MenuItem>

                </MenuItem>

                <!--  Edit  -->
                <MenuItem Header="{CompiledBinding Translation.Edit, Mode=OneWay}">

                    <!--  Copy image  -->
                    <MenuItem
                        Command="{Binding CopyImageCommand}"
                        Header="{Binding Translation.CopyImage.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.Image.Value, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="CopyPath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Copy file  -->
                    <MenuItem
                        Command="{Binding CopyFileCommand}"
                        Header="{Binding Translation.CopyFile.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="CopyPath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Copy file path  -->
                    <MenuItem
                        Command="{Binding CopyFilePathCommand}"
                        Header="{Binding Translation.FileCopyPath.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}, FallbackValue=False}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="CopyPath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Copy base64  -->
                    <MenuItem
                        Command="{Binding CopyBase64Command}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.Image.Value, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Header>
                            <TextBlock>
                                <Run Text="{Binding Translation.Copy.Value, Mode=OneWay}" />
                                <Run Text=" base64" />
                            </TextBlock>
                        </MenuItem.Header>
                        <MenuItem.Icon>
                            <Path Classes="CopyPath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Duplicate file  -->
                    <MenuItem
                        Command="{Binding DuplicateFileCommand}"
                        Header="{Binding Translation.DuplicateFile.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="DuplicatePath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Paste  -->
                    <MenuItem
                        Command="{Binding PasteCommand}"
                        Header="{Binding Translation.Paste.Value, Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="PastePath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Delete file  -->
                    <MenuItem
                        Command="{Binding DeleteFileCommand}"
                        Header="{Binding Translation.DeleteFile.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="RecyclePath" />
                        </MenuItem.Icon>
                    </MenuItem>

                </MenuItem>

                <!--  View  -->
                <MenuItem Header="{CompiledBinding Translation.View, Mode=OneWay}">

                    <!--  Change background  -->
                    <MenuItem
                        Command="{CompiledBinding ChangeBackgroundCommand}"
                        Header="{CompiledBinding Translation.ChangeBackground.Value,
                                                 Mode=OneWay}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource PaletteImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Toggle UI  -->
                    <MenuItem
                        Command="{Binding ToggleInterfaceCommand}"
                        Header="{Binding Translation.IsShowingUI.Value, Mode=OneWay}"
                        IsVisible="{Binding IsUIShown.Value, Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource EyeOffImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Toggle bottom bar  -->
                    <MenuItem
                        Command="{Binding ToggleBottomToolbarCommand}"
                        Header="{Binding Translation.ShowBottomToolbar.Value, Mode=OneWay}"
                        IsVisible="{Binding !IsBottomToolbarShown.Value}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource Panel-Bottom}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Toggle side-by-side  -->
                    <MenuItem
                        Command="{Binding SideBySideCommand}"
                        Header="{Binding Translation.SideBySide.Value, Mode=OneWay}"
                        Theme="{StaticResource MainBg}"
                        ToggleType="CheckBox" />

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Toggle gallery  -->
                    <MenuItem
                        Command="{Binding ToggleGalleryCommand}"
                        Header="{Binding Translation.ShowImageGallery.Value, Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource GalleryImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Fullscreen  -->
                    <MenuItem
                        Command="{Binding ToggleFullscreenCommand}"
                        Header="{Binding Translation.Fullscreen.Value, Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="FullscreenPath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Maximize  -->
                    <MenuItem
                        Command="{Binding MaximizeCommand}"
                        Header="{Binding Translation.Maximize.Value, Mode=OneWay}"
                        IsVisible="{Binding ShouldMaximizeBeShown.Value, Mode=OneWay}"
                        Theme="{StaticResource MainBg}"
                        x:Name="MaximizeMenuItem">
                        <MenuItem.Icon>
                            <Image Classes="MaximizeImage" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Restore  -->
                    <MenuItem
                        Command="{Binding RestoreCommand}"
                        Header="{Binding Translation.RestoreDown.Value, Mode=OneWay}"
                        IsVisible="{Binding ShouldRestoreBeShown.Value, Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="RestorePath" />
                        </MenuItem.Icon>
                    </MenuItem>

                </MenuItem>

                <!--  Image  -->
                <MenuItem Header="{CompiledBinding Translation.Image, Mode=OneWay}">

                    <!--  Exif window  -->
                    <MenuItem
                        Command="{CompiledBinding ImageInfoWindowCommand}"
                        Header="{CompiledBinding Translation.ImageInfo.Value,
                                                 Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource CameraImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  File properties  -->
                    <MenuItem
                        Command="{Binding ShowFilePropertiesCommand}"
                        Header="{Binding Translation.FileProperties.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource FileUserImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Image effects  -->
                    <MenuItem
                        Command="{Binding EffectsWindowCommand}"
                        Header="{Binding Translation.Effects.Value, Mode=OneWay}"
                        Theme="{StaticResource MainBg}"
                        ToolTip.Tip="{Binding Translation.EffectsTooltip.Value, Mode=OneWay}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource SparklesImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Single image resize  -->
                    <MenuItem
                        Command="{Binding ResizeWindowCommand}"
                        Header="{Binding Translation.ResizeImage.Value, Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource UpscaleImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Batch resize  -->
                    <MenuItem
                        Command="{Binding BatchResizeWindowCommand}"
                        Header="{Binding Translation.BatchResize.Value, Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource UpscaleImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Optimize image  -->
                    <MenuItem
                        Command="{Binding OptimizeImageCommand}"
                        Header="{Binding Translation.OptimizeImage.Value, Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource PortalImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Crop  -->
                    <MenuItem
                        Command="{Binding CropCommand}"
                        Header="{Binding Translation.Crop.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.Image.Value, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}"
                        x:Name="CropMenuItem">
                        <MenuItem.Icon>
                            <Image Classes="CropImage" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Flip  -->
                    <MenuItem
                        Command="{Binding FlipCommand}"
                        Header="{Binding Translation.IsFlipped.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.Image.Value, Converter={x:Static ObjectConverters.IsNotNull}}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image Classes="FlipImage">
                                <Image.RenderTransform>
                                    <ScaleTransform ScaleX="{Binding WindowTabs.ActiveTab.Value.ScaleX.Value}" />
                                </Image.RenderTransform>
                            </Image>
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Rotate left  -->
                    <MenuItem
                        Command="{Binding RotateLeftCommand}"
                        Header="{Binding Translation.RotateLeft.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.Image.Value, Converter={x:Static ObjectConverters.IsNotNull}}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="RotateLeftPath" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Rotate right  -->
                    <MenuItem
                        Command="{Binding RotateRightCommand}"
                        Header="{Binding Translation.RotateRight.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.Image.Value, Converter={x:Static ObjectConverters.IsNotNull}}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="RotateRightPath" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <!--  Navigate  -->
                <MenuItem Header="{Binding Translation.Navigate, Mode=OneWay}">

                    <!--  Sort files by  -->
                    <MenuItem Header="{Binding Translation.SortFilesBy.Value, Mode=OneWay}" Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Path Classes="SortFilesPath" />
                        </MenuItem.Icon>

                        <!--  Sort files by name  -->
                        <MenuItem
                            Command="{Binding SortFilesByNameCommand}"
                            GroupName="Sort"
                            Header="{Binding Translation.FileName.Value, Mode=OneWay}"
                            IsChecked="{Binding WindowTabs.IsSortedByName.Value}"
                            Theme="{StaticResource MainBg}"
                            ToggleType="Radio" />

                        <!--  Sort files by size  -->
                        <MenuItem
                            Command="{Binding SortFilesBySizeCommand}"
                            GroupName="Sort"
                            Header="{Binding Translation.FileSize.Value, Mode=OneWay}"
                            IsChecked="{Binding WindowTabs.IsSortedByFileSize.Value}"
                            Theme="{StaticResource MainBg}"
                            ToggleType="Radio" />

                        <!--  Sort files by extension  -->
                        <MenuItem
                            Command="{Binding SortFilesByExtensionCommand}"
                            GroupName="Sort"
                            Header="{Binding Translation.FileExtension.Value, Mode=OneWay}"
                            IsChecked="{Binding WindowTabs.IsSortedByExtension.Value}"
                            Theme="{StaticResource MainBg}"
                            ToggleType="Radio" />

                        <!--  Sort files by creation time  -->
                        <MenuItem
                            Command="{Binding SortFilesByCreationTimeCommand}"
                            GroupName="Sort"
                            Header="{Binding Translation.Created.Value, Mode=OneWay}"
                            IsChecked="{Binding WindowTabs.IsSortedByCreationTime.Value}"
                            Theme="{StaticResource MainBg}"
                            ToggleType="Radio" />

                        <!--  Sort files by last access time  -->
                        <MenuItem
                            Command="{Binding SortFilesByLastAccessTimeCommand}"
                            GroupName="Sort"
                            Header="{Binding Translation.LastAccessTime.Value, Mode=OneWay}"
                            IsChecked="{Binding WindowTabs.IsSortedByLastAccessTime.Value}"
                            Theme="{StaticResource MainBg}"
                            ToggleType="Radio" />

                        <!--  Sort files by last write time  -->
                        <MenuItem
                            Command="{Binding SortFilesByLastAccessTimeCommand}"
                            GroupName="Sort"
                            Header="{Binding Translation.Modified.Value, Mode=OneWay}"
                            IsChecked="{Binding WindowTabs.IsSortedByLastWriteTime.Value}"
                            Theme="{StaticResource MainBg}"
                            ToggleType="Radio" />

                        <!--  Sort files randomly  -->
                        <MenuItem
                            Command="{Binding SortFilesRandomlyCommand}"
                            GroupName="Sort"
                            Header="{Binding Translation.Random.Value, Mode=OneWay}"
                            IsChecked="{Binding WindowTabs.IsSortedByRandomization.Value}"
                            Theme="{StaticResource MainBg}"
                            ToggleType="Radio" />

                        <Separator
                            Background="{DynamicResource ContextMenuBackgroundColor}"
                            Margin="0"
                            Opacity=".9" />

                        <!--  Sort files ascending  -->
                        <MenuItem
                            Command="{Binding SortFilesAscendingCommand}"
                            GroupName="Order"
                            Header="{Binding Translation.Ascending.Value, Mode=OneWay}"
                            IsChecked="{Binding WindowTabs.IsAscending.Value}"
                            Theme="{StaticResource MainBg}"
                            ToggleType="Radio" />

                        <!--  Sort files descending  -->
                        <MenuItem
                            Command="{Binding SortFilesDescendingCommand}"
                            GroupName="Order"
                            Header="{Binding Translation.Descending.Value, Mode=OneWay}"
                            IsChecked="{Binding !WindowTabs.IsAscending.Value}"
                            Theme="{StaticResource MainBg}"
                            ToggleType="Radio" />

                    </MenuItem>

                    <!--  Next  -->
                    <MenuItem
                        Command="{Binding NextCommand}"
                        Header="{Binding Translation.NextImage, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.CanNavigateForwards.Value}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource NextImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Prev  -->
                    <MenuItem
                        Command="{Binding PrevCommand}"
                        Header="{Binding Translation.PrevImage, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.CanNavigateForwards.Value}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource PrevImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />


                    <!--  Next 10  -->
                    <MenuItem
                        Command="{Binding Next10Command}"
                        Header="{Binding Translation.AdvanceBy10Images, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.CanNavigateForwards.Value}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource NextImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Next 100  -->
                    <MenuItem
                        Command="{Binding Next100Command}"
                        Header="{Binding Translation.AdvanceBy100Images, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.CanNavigateForwards.Value}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource NextImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Prev 10  -->
                    <MenuItem
                        Command="{Binding Prev10Command}"
                        Header="{Binding Translation.GoBackBy10Images.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.CanNavigateBackwards.Value}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource PrevImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Prev 100  -->
                    <MenuItem
                        Command="{Binding Prev100Command}"
                        Header="{Binding Translation.GoBackBy100Images.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.CanNavigateBackwards.Value}"
                        StaysOpenOnClick="True"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource PrevImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  First Image  -->
                    <MenuItem
                        Command="{Binding FirstCommand}"
                        Header="{Binding Translation.FirstImage.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.CanNavigateBackwards.Value}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource FirstImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Last Image  -->
                    <MenuItem
                        Command="{Binding LastCommand}"
                        Header="{Binding Translation.LastImage.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.CanNavigateForwards.Value}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource LastImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Next folder  -->
                    <MenuItem
                        Command="{Binding NextFolderCommand}"
                        Header="{Binding Translation.NextFolder.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="14"
                                Source="{StaticResource NextFolderImage}"
                                Width="14" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Prev folder  -->
                    <MenuItem
                        Command="{Binding PrevFolderCommand}"
                        Header="{Binding Translation.PrevFolder.Value, Mode=OneWay}"
                        IsEnabled="{Binding WindowTabs.ActiveTab.Value.FileInfo.Value, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="14"
                                Source="{StaticResource PrevFolderImage}"
                                Width="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <!--  Settings  -->
                <MenuItem Header="{CompiledBinding Translation.Settings.Value, Mode=OneWay}">

                    <!--  Toggle Subdirectories  -->
                    <MenuItem
                        Command="{CompiledBinding ToggleSubdirectoriesCommand}"
                        Header="{CompiledBinding Translation.SearchSubdirectory.Value,
                                                 Mode=OneWay}"
                        IsChecked="{Binding GlobalSettings.IsIncludingSubdirectories.Value}"
                        Theme="{StaticResource MainBg}"
                        ToggleType="CheckBox" />

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Toggle looping  -->
                    <MenuItem
                        Command="{CompiledBinding ToggleLoopingCommand}"
                        Header="{CompiledBinding Translation.IsLooping.Value,
                                                 Mode=OneWay}"
                        IsChecked="{Binding GlobalSettings.IsLooping.Value}"
                        Theme="{StaticResource MainBg}"
                        ToggleType="CheckBox" />

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Toggle scrolling  -->
                    <MenuItem
                        Header="{CompiledBinding Translation.IsScrolling.Value,
                                                 Mode=OneWay}"
                        IsChecked="{CompiledBinding IsScrollingEnabled.Value}"
                        Theme="{StaticResource MainBg}"
                        ToggleType="CheckBox" />

                    <!--  Toggle stretching  -->
                    <MenuItem
                        Command="{CompiledBinding StretchCommand}"
                        Header="{CompiledBinding Translation.Stretch.Value,
                                                 Mode=OneWay}"
                        IsChecked="{CompiledBinding IsStretched.Value}"
                        Theme="{StaticResource MainBg}"
                        ToggleType="CheckBox" />

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Toggle topmost  -->
                    <MenuItem
                        Command="{CompiledBinding SetTopMostCommand}"
                        Header="{CompiledBinding Translation.StayTopMost.Value,
                                                 Mode=OneWay}"
                        IsChecked="{CompiledBinding IsTopMost.Value}"
                        Theme="{StaticResource MainBg}"
                        ToggleType="CheckBox" />

                    <!--  Toggle auto fit  -->
                    <MenuItem
                        Command="{CompiledBinding AutoFitWindowCommand}"
                        Header="{CompiledBinding Translation.AutoFitWindow.Value,
                                                 Mode=OneWay}"
                        IsChecked="{CompiledBinding IsAutoFit.Value}"
                        Theme="{StaticResource MainBg}"
                        ToggleType="CheckBox" />

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Toggle ctrl zoom  -->
                    <MenuItem
                        Command="{CompiledBinding ChangeCtrlZoomCommand}"
                        Header="{CompiledBinding Translation.IsCtrlToZoom.Value,
                                                 Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <!-- <MenuItem.Icon> -->
                        <!--  <Image  -->
                        <!--  Height="12"  -->
                        <!--  Source="{CompiledBinding MainWindow.ChangeCtrlZoomImage.Value}"  -->
                        <!--  Width="12" />  -->
                        <!-- </MenuItem.Icon> -->
                    </MenuItem>

                    <Separator
                        Background="{DynamicResource ContextMenuBackgroundColor}"
                        Margin="0"
                        Opacity=".9" />

                    <!--  Show Settings window  -->
                    <MenuItem
                        Command="{CompiledBinding SettingsWindowCommand}"
                        Header="{CompiledBinding Translation.ShowAllSettingsWindow.Value,
                                                 Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image Classes="CogImage" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <!--  Help  -->
                <MenuItem Header="{CompiledBinding Translation.Help, Mode=OneWay}">

                    <!--  Show about window  -->
                    <MenuItem
                        Command="{CompiledBinding AboutWindowCommand}"
                        Header="{CompiledBinding Translation.About.Value,
                                                 Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource AboutImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Check for updates  -->
                    <MenuItem
                        Command="{CompiledBinding CheckForUpdatesCommand}"
                        Header="{CompiledBinding Translation.CheckForUpdates.Value,
                                                 Mode=OneWay}"
                        Theme="{StaticResource MainBg}">
                        <MenuItem.Icon>
                            <Image
                                Height="12"
                                Source="{StaticResource DownloadImage}"
                                Width="12" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
            </Menu>

            <customControls:IconButton
                Background="{DynamicResource WindowButtonBackgroundColor}"
                BorderBrush="{DynamicResource MainBorderColor}"
                BorderThickness="0,0,1,0"
                Classes="noBorderHover"
                Command="{CompiledBinding TopTitlebarViewModel.OpenMenuCommand}"
                Foreground="{DynamicResource MainTextColor}"
                Icon="{StaticResource MenuImage}"
                IconHeight="16"
                IconWidth="16"
                IsRepeatEnabled="False"
                IsVisible="{Binding TopTitlebarViewModel.IsMenuButtonVisible.Value}"
                Margin="0"
                Width="30"
                x:Name="MenuButton" />

            <Button
                Background="Transparent"
                BorderBrush="{DynamicResource MainBorderColor}"
                Classes="noBorderHover"
                CornerRadius="6"
                DockPanel.Dock="Left"
                Foreground="{DynamicResource MainTextColor}"
                IsTabStop="False"
                IsVisible="{Binding TopTitlebarViewModel.IsMenuButtonVisible.Value}"
                Margin="2,3,7,3"
                Width="30"
                x:Name="SearchButton">
                <Image
                    Height="13"
                    Source="{StaticResource SearchImage}"
                    Width="13" />
            </Button>

            <StackPanel
                DockPanel.Dock="Right"
                IsVisible="{CompiledBinding TopTitlebarViewModel.IsBtnPanelVisible.Value}"
                Orientation="Horizontal"
                x:Name="WinBtnPanel">

                <customControls:IconButton
                    Background="{DynamicResource WindowButtonBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1,0,1,0"
                    Classes="hover "
                    ClickMode="Release"
                    Command="{CompiledBinding MinimizeCommand}"
                    Data="{StaticResource MinimizeGeometry}"
                    Foreground="{DynamicResource MainTextColor}"
                    IconHeight="12"
                    IconWidth="12"
                    IsRepeatEnabled="False"
                    Margin="0,0"
                    Width="30"
                    x:Name="MinimizeButton" />

                <customControls:IconButton
                    Background="{DynamicResource WindowButtonBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    Classes="hover"
                    ClickMode="Release"
                    Command="{CompiledBinding ToggleFullscreenCommand}"
                    Data="{StaticResource FullscreenGeometry}"
                    Foreground="{DynamicResource MainTextColor}"
                    IconHeight="12"
                    IconWidth="12"
                    IsRepeatEnabled="False"
                    IsVisible="{CompiledBinding ShouldMaximizeBeShown.Value,
                                                Mode=OneWay}"
                    Width="30"
                    x:Name="FullscreenButton" />

                <customControls:IconButton
                    Background="{DynamicResource WindowButtonBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="0,0,1,0"
                    Classes="hover"
                    Command="{CompiledBinding RestoreCommand}"
                    Data="{StaticResource RestoreGeometry}"
                    Foreground="{DynamicResource MainTextColor}"
                    IconHeight="12"
                    IconWidth="12"
                    IsRepeatEnabled="False"
                    IsVisible="{CompiledBinding !ShouldMaximizeBeShown.Value,
                                                Mode=OneWay}"
                    Width="30"
                    x:Name="RestoreButton" />

                <customControls:IconButton
                    Background="{DynamicResource WindowButtonBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    Classes="hover"
                    ClickMode="Release"
                    Command="{CompiledBinding ExitCommand}"
                    Data="{StaticResource CloseGeometry}"
                    Foreground="{DynamicResource MainTextColor}"
                    IconHeight="10"
                    IconWidth="10"
                    IsRepeatEnabled="False"
                    Width="30"
                    x:Name="CloseButton" />

            </StackPanel>

            <Button
                Background="Transparent"
                BorderBrush="{DynamicResource MainBorderColor}"
                Classes="noBorderHover"
                Command="{CompiledBinding TopTitlebarViewModel.ToggleDropDownMenuCommand}"
                CommandParameter="{CompiledBinding}"
                CornerRadius="6"
                DockPanel.Dock="Right"
                IsTabStop="False"
                IsVisible="{Binding TopTitlebarViewModel.IsMenuButtonVisible.Value}"
                Margin="2,3,7,3"
                Width="30"
                x:Name="DropDownMenuButton">
                <Path
                    Data="{StaticResource FilledArrowDownGeometry}"
                    Fill="{DynamicResource MainTextColor}"
                    Height="17"
                    Stretch="Fill"
                    Width="17" />
            </Button>

            <Button
                Background="Transparent"
                BorderBrush="{DynamicResource MainBorderColor}"
                Classes="noBorderHover"
                Command="{CompiledBinding WindowTabs.CreateTab}"
                CornerRadius="6"
                DockPanel.Dock="Right"
                Foreground="{DynamicResource MainTextColor}"
                IsTabStop="False"
                IsVisible="{Binding TopTitlebarViewModel.IsMenuButtonVisible.Value}"
                Margin="0,3,2,3"
                Width="30"
                x:Name="CreateTabButton">
                <Path
                    Data="{StaticResource AddGeometry}"
                    Fill="{DynamicResource MainTextColor}"
                    Height="13"
                    Stretch="Fill"
                    Width="13" />
            </Button>

            <uc:EditableTitlebar
                Background="{DynamicResource WindowSecondaryBackgroundColor}"
                BorderBrush="{DynamicResource MainBorderColor}"
                BorderThickness="0,0,0,1"
                Foreground="{DynamicResource MainTextColor}"
                IsVisible="{Binding TopTitlebarViewModel.IsEditableTitlebarVisible.Value}"
                x:Name="EditableTitlebar" />

        </DockPanel>
    </Border>
</customControls:MainTitleBar>
